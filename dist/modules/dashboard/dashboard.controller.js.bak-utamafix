const CreateSettlementFormSchema = zod_1.z.object({
    fromWallet: zod_1.z.enum(['qris', 'utama', 'madera']),
    toWallet: zod_1.z.enum(['utama', 'madera', 'bank']),
    amount: zod_1.z.string().transform((v) => parseInt(v.replace(/\D/g, ''), 10)),
    qrisAccountId: zod_1.z.string().optional(),
    bankCode: zod_1.z.string().max(50).optional(),
    bankAccount: zod_1.z.string().max(50).optional(),
    bankName: zod_1.z.string().max(100).optional(),
    note: zod_1.z.string().max(500).optional(),
});
async function handleCreateSettlement(req, res) {
    try {
        const parsed = CreateSettlementFormSchema.safeParse(req.body);
        if (!parsed.success) {
            req.session.flash = {
                type: 'error',
                message: 'Data tidak valid: ' + parsed.error.errors.map((e) => e.message).join(', '),
            };
            res.redirect((0, base_path_1.withBasePath)('/dashboard/settlement', config_1.config.APP_BASE_PATH));
            return;
        }
        const { fromWallet, toWallet, amount, qrisAccountId, bankCode, bankAccount, bankName, note } = parsed.data;
        if (isNaN(amount) || amount < 1) {
            req.session.flash = { type: 'error', message: 'Jumlah harus berupa angka positif' };
            res.redirect((0, base_path_1.withBasePath)('/dashboard/settlement', config_1.config.APP_BASE_PATH));
            return;
        }
        await (0, settlement_service_1.createSettlement)({ fromWallet, toWallet, amount, qrisAccountId, bankCode, bankAccount, bankName, note }, req.session.user?.id, req.ip);
        req.session.flash = {
            type: 'success',
            message: `Permintaan settlement Rp ${amount.toLocaleString('id-ID')} dibuat. Worker akan memprosesnya.`,
        };
        res.redirect((0, base_path_1.withBasePath)('/dashboard/settlement', config_1.config.APP_BASE_PATH));
    }
    catch (err) {
        logger_1.logger.error({ err }, 'handleCreateSettlement error');
        const msg = err instanceof Error ? err.message : 'Gagal membuat settlement';
        req.session.flash = { type: 'error', message: msg };
        res.redirect((0, base_path_1.withBasePath)('/dashboard/settlement', config_1.config.APP_BASE_PATH));
    }
}
