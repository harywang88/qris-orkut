                amounts: {
                    totalPaid: paidAggregate._sum.finalAmount ?? 0,
                    totalFee: paidAggregate._sum.feeAmount ?? 0,
                    netAmount: (paidAggregate._sum.finalAmount ?? 0) - (paidAggregate._sum.feeAmount ?? 0),
