                paid: paidAll,
                expired: expiredAll,
                open: openAll,
                depositSuccess: depSuccessAll,
                depositFailed: depFailedAll,
                manualReview: manualReviewAll,
                totalPaid: overallTotalPaid,
                totalFee: overallTotalFee,
                netAmount: overallTotalPaid - overallTotalFee,
