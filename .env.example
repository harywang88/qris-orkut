# =============================================================
# QRIS Dashboard — Environment Variables
# =============================================================
# Copy this file to .env and fill in the values before running.
# Run: cp .env.example .env
# =============================================================

# Server
NODE_ENV=development
PORT=3333
APP_BASE_PATH=/qris

# Database (PostgreSQL - aktif di mesin ini)
DATABASE_PROVIDER=postgresql
DATABASE_URL="postgresql://wangchat:wangchat123@127.0.0.1:5432/qris_dashboard?schema=public"
SQLITE_SOURCE_URL="file:./prisma/data/dev.db"

# ---------------------------------------------------------------
# PostgreSQL Alternative via docker-compose repo ini
# If you use docker-compose.postgres.yml from this repo:
#   user     : qris_admin
#   password : QrisAdmin_2026!
# DATABASE_URL="postgresql://qris_admin:QrisAdmin_2026!@127.0.0.1:5432/qris_dashboard?schema=public"

# Session secret — use a long random string
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-secret-string-please

# Encryption key for API secrets stored in DB — MUST be exactly 64 hex chars (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=4a7b9c2e1f8d3a6b5c0e9f2d7a4b8c1e3f6a9d2b5e8c1f4a7d0b3e6c9f2a5b8

# QR expiry in minutes (default: 12)
QR_EXPIRY_MINUTES=12

# Default admin credentials (used only during first seed)
# IMPORTANT: Change these before running in production
ADMIN_DEFAULT_USERNAME=Harywang
ADMIN_DEFAULT_PASSWORD=Vinisia1234@@

# ---------------------------------------------------------------
# OPTIONAL: Real Orkut gateway credentials
# Leave blank to use MockOrkutGateway (safe for development)
# ---------------------------------------------------------------
# ORKUT_BASE_URL=
# ORKUT_SESSION_TOKEN=
# ORKUT_BALANCE_BASE_URL=
# Optional outbound proxy dedicated to app.orderkuota.com requests.
# ORKUT_PROXY_URL=http://127.0.0.1:31808
# ORKUT_PHONE_MODEL=SM-N976N
# ORKUT_ANDROID_VERSION=7.1.2
# Optional richer QRIS web report endpoint.
# Use {account} as placeholder for the remote account index, for example:
# ORKUT_QRIS_WEB_REPORT_URL_TEMPLATE=https://your-panel.example/merchant/mutasi-qr?action=fetch_web&account={account}&cache=0&_={ts}
# ORKUT_QRIS_WEB_REPORT_URL_TEMPLATE=

# ---------------------------------------------------------------
# OPTIONAL: Telegram control bot (group panel)
# ---------------------------------------------------------------
# Bot token dari @BotFather
TELEGRAM_BOT_TOKEN=
# Chat ID group target, contoh: -4855635582
TELEGRAM_GROUP_ID=
# Command kontrol server (default akan dipakai jika dikosongkan)
TELEGRAM_CONTROL_START_COMMAND=npx pm2 start ecosystem.config.cjs --only qris-app
TELEGRAM_CONTROL_STOP_COMMAND=npx pm2 stop qris-app
TELEGRAM_CONTROL_RESTART_COMMAND=npx pm2 restart qris-app
TELEGRAM_CONTROL_STATUS_COMMAND=npx pm2 describe qris-app
TELEGRAM_CONTROL_PM2_LIST_COMMAND=npx pm2 jlist
# Timeout command dalam milidetik
TELEGRAM_CONTROL_TIMEOUT_MS=60000
