<header class="qris-navbar">
  <div class="flex items-center gap-3">
    <!-- Mobile menu button -->
    <button class="lg:hidden qris-icon-btn" onclick="openSidebar()">
      <i class="fa-solid fa-bars text-xs"></i>
    </button>

    <!-- Breadcrumb -->
    <div class="qris-breadcrumb">
      <i class="fa-solid fa-house text-[11px] opacity-60"></i>
      <span class="qris-breadcrumb-sep">/</span>
      <span class="text-ink/80 font-medium"><%- typeof title !== 'undefined' ? title : 'Dashboard' %></span>
    </div>

    <!-- Badge Tenant: tampil saat login sebagai alias-tenant (scoped ke 1 site) -->
    <% if (user && user.siteScopeName) { %>
      <span title="Anda login sebagai tenant — hanya melihat data site ini"
            style="display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:999px;background:rgba(139,92,246,.16);border:1px solid rgba(139,92,246,.45);color:#c4b5fd;font-size:11.5px;font-weight:800;white-space:nowrap">
        <i class="fa-solid fa-store" style="font-size:10px"></i> <%= user.siteScopeName %>
      </span>
    <% } %>
  </div>

  <div class="flex items-center gap-2">
    <% if (user && user.mustChangePassword) { %>
      <a href="<%= url('/settings/change-password') %>"
         class="flex items-center gap-1.5 rounded-xl bg-red-950/60 px-3 py-1.5 text-xs font-semibold text-red-300 ring-1 ring-red-800/60 hover:ring-red-700/80 transition">
        <i class="fa-solid fa-triangle-exclamation text-[10px]"></i>
        Ganti Password
      </a>
    <% } %>

    <!-- Clock -->
    <div class="qris-clock-badge hidden md:flex">
      <i class="fa-regular fa-clock text-[11px]"></i>
      <span id="clock" class="font-mono tracking-tight"></span>
    </div>

    <!-- Theme Toggle (Light/Dark) -->
    <button class="qris-theme-toggle" id="themeToggle" type="button" title="Toggle light/dark mode" onclick="toggleTheme()">
      <i class="fa-solid fa-sun theme-icon theme-icon-sun"></i>
      <i class="fa-solid fa-moon theme-icon theme-icon-moon"></i>
    </button>

    <!-- User badge -->
    <div class="qris-user-badge hidden md:flex">
      <div class="qris-avatar">
        <%= user ? user.fullName.charAt(0).toUpperCase() : 'A' %>
      </div>
      <div class="leading-tight">
        <p class="text-xs font-semibold text-ink"><%= user ? user.username : '' %></p>
        <p class="text-[10px] text-muted"><%= user ? user.fullName : '' %></p>
      </div>
    </div>

    <!-- Divider -->
    <div style="width:1px;height:22px;background:rgba(255,255,255,0.1)" class="hidden md:block"></div>

    <!-- Settings -->
    <a href="<%= url('/settings/change-password') %>"
       title="Pengaturan"
       style="
         display:inline-flex;align-items:center;justify-content:center;
         width:34px;height:34px;border-radius:10px;
         background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);
         color:var(--color-muted);transition:all .2s;text-decoration:none;
       "
       onmouseover="this.style.background='rgba(255,255,255,0.08)';this.style.color='var(--color-ink)'"
       onmouseout="this.style.background='rgba(255,255,255,0.04)';this.style.color='var(--color-muted)'">
      <i class="fa-solid fa-gear" style="font-size:13px"></i>
    </a>

    <!-- Logout -->
    <form action="<%= url('/logout') %>" method="POST" style="margin:0">
      <button type="submit"
              title="Keluar"
              style="
                display:inline-flex;align-items:center;gap:6px;
                padding:6px 12px;border-radius:10px;border:1px solid rgba(239,68,68,0.25);
                background:rgba(239,68,68,0.08);color:#fca5a5;
                font-size:12px;font-weight:600;cursor:pointer;
                transition:all .2s;white-space:nowrap;
              "
              onmouseover="this.style.background='rgba(239,68,68,0.16)';this.style.borderColor='rgba(239,68,68,0.4)'"
              onmouseout="this.style.background='rgba(239,68,68,0.08)';this.style.borderColor='rgba(239,68,68,0.25)'">
        <i class="fa-solid fa-right-from-bracket" style="font-size:11px"></i>
        <span class="hidden sm:inline">Keluar</span>
      </button>
    </form>
  </div>
</header>

<script>
  (function () {
    function updateClock() {
      const el = document.getElementById('clock');
      if (!el) return;
      el.textContent = new Date().toLocaleTimeString('id-ID', {
        hour: '2-digit', minute: '2-digit', second: '2-digit',
      });
    }
    updateClock();
    setInterval(updateClock, 1000);
  })();
</script>
