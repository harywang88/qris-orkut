<style>
  /* ── Change Password Page ────────────────────── */
  .chpw-wrap {
    max-width: 520px;
    animation: chpwFadeIn 0.6s cubic-bezier(0.22, 0.84, 0.2, 1) both;
  }

  @keyframes chpwFadeIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Shield hero ─────────────────────────────── */
  .chpw-hero {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 28px;
    padding: 22px 24px;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(232, 69, 69, 0.08) 0%, rgba(232, 69, 69, 0.02) 100%);
    border: 1px solid rgba(232, 69, 69, 0.12);
  }

  .chpw-hero-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, var(--accent, #e84545), #15803d);
    box-shadow:
      0 12px 28px rgba(232, 69, 69, 0.25),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset;
    flex-shrink: 0;
  }

  .chpw-hero-icon i {
    font-size: 1.35rem;
    color: #fff;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.2));
  }

  .chpw-hero-text {
    display: grid;
    gap: 4px;
  }

  .chpw-hero-text strong {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink, #f1ece4);
    letter-spacing: 0.01em;
  }

  .chpw-hero-text span {
    font-size: 0.82rem;
    color: var(--muted, #9a9085);
    line-height: 1.5;
  }

  /* ── Card ─────────────────────────────────────── */
  .chpw-card {
    background: var(--card, #181b22);
    border: 1px solid var(--line, #252a35);
    border-radius: 18px;
    padding: 28px;
    transition: border-color 0.3s ease;
  }

  .chpw-card:hover {
    border-color: rgba(232, 69, 69, 0.18);
  }

  /* ── Form ─────────────────────────────────────── */
  .chpw-form {
    display: grid;
    gap: 18px;
  }

  .chpw-field {
    display: grid;
    gap: 8px;
  }

  .chpw-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted, #9a9085);
  }

  .chpw-label .chpw-label-hint {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.7;
    font-size: 0.72rem;
  }

  .chpw-input-wrap {
    position: relative;
  }

  .chpw-input-icon {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(154, 144, 133, 0.5);
    font-size: 0.88rem;
    pointer-events: none;
    transition: color 0.25s ease;
  }

  .chpw-input-wrap:focus-within .chpw-input-icon {
    color: var(--accent, #e84545);
  }

  .chpw-input {
    width: 100%;
    border: 1px solid var(--line, #252a35);
    border-radius: 14px;
    background: var(--panel, #12141a);
    padding: 14px 46px 14px 44px;
    color: var(--ink, #f1ece4);
    font-size: 0.94rem;
    outline: none;
    transition:
      border-color 0.22s ease,
      background 0.22s ease,
      box-shadow 0.22s ease,
      transform 0.22s ease;
  }

  .chpw-input::placeholder {
    color: rgba(154, 144, 133, 0.35);
  }

  .chpw-input:focus {
    border-color: rgba(232, 69, 69, 0.45);
    background: rgba(18, 20, 26, 0.9);
    box-shadow: 0 0 0 3px rgba(232, 69, 69, 0.1);
    transform: translateY(-1px);
  }

  /* Toggle visibility button */
  .chpw-eye-btn {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border: 0;
    border-radius: 10px;
    background: transparent;
    color: rgba(154, 144, 133, 0.45);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    font-size: 0.82rem;
  }

  .chpw-eye-btn:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--ink, #f1ece4);
  }

  /* ── Divider ─────────────────────────────────── */
  .chpw-divider {
    height: 1px;
    background: var(--line, #252a35);
    margin: 4px 0;
    opacity: 0.6;
  }

  /* ── Submit button ───────────────────────────── */
  .chpw-submit {
    margin-top: 6px;
    border: 0;
    border-radius: 14px;
    padding: 14px 20px;
    width: 100%;
    background: linear-gradient(135deg, var(--accent, #e84545) 0%, #15803d 100%);
    color: #fff;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    box-shadow:
      0 12px 28px rgba(232, 69, 69, 0.22),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset;
    transition: transform 0.22s ease, box-shadow 0.22s ease, filter 0.22s ease;
  }

  .chpw-submit:hover {
    transform: translateY(-2px);
    box-shadow:
      0 18px 36px rgba(232, 69, 69, 0.30),
      0 0 0 1px rgba(255, 255, 255, 0.08) inset;
    filter: brightness(1.08);
  }

  .chpw-submit:active {
    transform: translateY(0);
  }

  /* ── Tips card ───────────────────────────────── */
  .chpw-tips {
    margin-top: 20px;
    padding: 20px 22px;
    border-radius: 16px;
    background: var(--card, #181b22);
    border: 1px solid var(--line, #252a35);
  }

  .chpw-tips-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted, #9a9085);
    margin-bottom: 14px;
  }

  .chpw-tips-title i {
    color: rgba(232, 69, 69, 0.6);
    font-size: 0.82rem;
  }

  .chpw-tips-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .chpw-tips-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.82rem;
    color: var(--muted, #9a9085);
    line-height: 1.5;
  }

  .chpw-tips-list li i {
    flex-shrink: 0;
    margin-top: 3px;
    font-size: 0.6rem;
    color: rgba(232, 69, 69, 0.5);
  }

  /* ── Flash messages ──────────────────────────── */
  .chpw-flash-warning {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 22px;
    padding: 14px 18px;
    border-radius: 14px;
    border: 1px solid rgba(251, 191, 36, 0.2);
    background: rgba(251, 191, 36, 0.07);
    color: #fbbf24;
    font-size: 0.86rem;
    line-height: 1.55;
    animation: chpwFlashIn 0.4s ease both;
  }

  .chpw-flash-error {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 18px;
    padding: 13px 16px;
    border-radius: 14px;
    border: 1px solid rgba(248, 113, 113, 0.2);
    background: rgba(248, 113, 113, 0.08);
    color: #fca5a5;
    font-size: 0.84rem;
    line-height: 1.55;
    animation: chpwFlashIn 0.4s ease both;
  }

  @keyframes chpwFlashIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Responsive ──────────────────────────────── */
  @media (max-width: 640px) {
    .chpw-wrap { max-width: none; }
    .chpw-hero { padding: 18px 16px; gap: 14px; }
    .chpw-hero-icon { width: 46px; height: 46px; border-radius: 13px; }
    .chpw-hero-icon i { font-size: 1.1rem; }
    .chpw-card { padding: 20px 18px; }
  }
</style>

<div class="chpw-wrap">
  <!-- Page header -->
  <div class="qris-page-header">
    <h1 class="qris-page-title">Ganti <span>Password</span></h1>
    <p class="qris-section-sub mt-1">Perbarui kredensial akun Anda untuk menjaga keamanan sistem</p>
  </div>

  <!-- Shield hero block -->
  <div class="chpw-hero">
    <div class="chpw-hero-icon">
      <i class="fa-solid fa-shield-halved"></i>
    </div>
    <div class="chpw-hero-text">
      <strong>Keamanan Akun</strong>
      <span>Gunakan password yang kuat dan unik. Jangan gunakan password yang sama dengan akun lain.</span>
    </div>
  </div>

  <!-- Must-change warning -->
  <% if (mustChange) { %>
    <div class="chpw-flash-warning">
      <i class="fa-solid fa-triangle-exclamation flex-shrink-0" style="margin-top:2px"></i>
      <span>Anda diwajibkan mengganti password sebelum melanjutkan. Password default harus segera diubah demi keamanan.</span>
    </div>
  <% } %>

  <!-- Main form card -->
  <div class="chpw-card">
    <% if (error) { %>
      <div class="chpw-flash-error">
        <i class="fa-solid fa-circle-xmark flex-shrink-0" style="margin-top:2px"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <form action="<%= url('/settings/change-password') %>" method="POST" class="chpw-form">
      <!-- Current password -->
      <div class="chpw-field">
        <label class="chpw-label">Password Saat Ini</label>
        <div class="chpw-input-wrap">
          <i class="fa-solid fa-lock chpw-input-icon"></i>
          <input
            type="password"
            name="currentPassword"
            required
            class="chpw-input"
            placeholder="Masukkan password saat ini"
            autocomplete="current-password"
          />
          <button class="chpw-eye-btn" type="button" onclick="chpwToggle(this)" aria-label="Tampilkan password">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
      </div>

      <div class="chpw-divider"></div>

      <!-- New password -->
      <div class="chpw-field">
        <label class="chpw-label">Password Baru <span class="chpw-label-hint">(min. 8 karakter)</span></label>
        <div class="chpw-input-wrap">
          <i class="fa-solid fa-key chpw-input-icon"></i>
          <input
            type="password"
            name="newPassword"
            required
            minlength="8"
            class="chpw-input"
            placeholder="Masukkan password baru"
            autocomplete="new-password"
          />
          <button class="chpw-eye-btn" type="button" onclick="chpwToggle(this)" aria-label="Tampilkan password">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
      </div>

      <!-- Confirm password -->
      <div class="chpw-field">
        <label class="chpw-label">Konfirmasi Password Baru</label>
        <div class="chpw-input-wrap">
          <i class="fa-solid fa-lock chpw-input-icon"></i>
          <input
            type="password"
            name="confirmPassword"
            required
            class="chpw-input"
            placeholder="Ketik ulang password baru"
            autocomplete="new-password"
          />
          <button class="chpw-eye-btn" type="button" onclick="chpwToggle(this)" aria-label="Tampilkan password">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="chpw-submit">
        <i class="fa-solid fa-key" style="font-size:0.82rem"></i>
        Perbarui Password
      </button>
    </form>
  </div>

  <!-- Security tips -->
  <div class="chpw-tips">
    <div class="chpw-tips-title">
      <i class="fa-solid fa-lightbulb"></i>
      Tips Keamanan
    </div>
    <ul class="chpw-tips-list">
      <li>
        <i class="fa-solid fa-diamond"></i>
        <span>Gunakan minimal 8 karakter dengan kombinasi huruf besar, kecil, angka, dan simbol</span>
      </li>
      <li>
        <i class="fa-solid fa-diamond"></i>
        <span>Hindari menggunakan informasi pribadi seperti nama, tanggal lahir, atau nomor telepon</span>
      </li>
      <li>
        <i class="fa-solid fa-diamond"></i>
        <span>Ganti password secara berkala, idealnya setiap 3 bulan sekali</span>
      </li>
      <li>
        <i class="fa-solid fa-diamond"></i>
        <span>Jangan bagikan password Anda kepada siapapun termasuk administrator lain</span>
      </li>
    </ul>
  </div>
</div>

<script>
  function chpwToggle(btn) {
    const input = btn.parentElement.querySelector('input');
    const icon = btn.querySelector('i');
    const showing = input.type === 'text';
    input.type = showing ? 'password' : 'text';
    icon.className = showing ? 'fa-regular fa-eye' : 'fa-regular fa-eye-slash';
  }
</script>
