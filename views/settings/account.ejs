<style>
/* ── Account Settings Page ───────────────────────────────────────── */
.acset-tab-bar {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 6px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.acset-tab-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  border-radius: 10px;
  font-size: 0.85rem;
  font-weight: 600;
  border: none;
  cursor: pointer;
  transition: all 0.2s ease;
  background: transparent;
  color: var(--muted);
}

.acset-tab-btn:hover {
  background: rgba(255,255,255,0.05);
  color: var(--ink);
}

.acset-tab-btn.active {
  background: var(--accent, #e84545);
  color: #fff;
  box-shadow: 0 4px 14px rgba(232,69,69,0.3);
}

html.light .acset-tab-btn:hover {
  background: rgba(0,0,0,0.05);
}

.acset-tab-content { display: none; }
.acset-tab-content.active { display: block; }

.acset-card {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 28px;
  margin-bottom: 20px;
}

.acset-card-header {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
}

.acset-card-icon {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  flex-shrink: 0;
  font-size: 1.2rem;
}

.acset-card-icon.purple { background: rgba(124,58,237,0.12); color: #a78bfa; }
.acset-card-icon.red    { background: rgba(232,69,69,0.12);  color: #f87171; }
.acset-card-icon.blue   { background: rgba(59,130,246,0.12); color: #60a5fa; }

.acset-card-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--ink);
  margin: 0 0 3px;
}

.acset-card-sub {
  font-size: 0.78rem;
  color: var(--muted);
  margin: 0;
}

.acset-label {
  display: block;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--muted);
  margin-bottom: 8px;
}

.acset-input {
  width: 100%;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 12px;
  padding: 12px 16px;
  color: var(--ink);
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.acset-input::placeholder { color: rgba(154,144,133,0.4); }

.acset-input:focus {
  border-color: rgba(232,69,69,0.45);
  box-shadow: 0 0 0 3px rgba(232,69,69,0.1);
}

.acset-info-box {
  border-radius: 12px;
  padding: 16px 18px;
  margin-top: 8px;
}

.acset-info-box.purple {
  background: rgba(124,58,237,0.07);
  border: 1px solid rgba(124,58,237,0.18);
}

.acset-info-box.blue {
  background: rgba(59,130,246,0.07);
  border: 1px solid rgba(59,130,246,0.18);
}

.acset-info-box.yellow {
  background: rgba(245,158,11,0.07);
  border: 1px solid rgba(245,158,11,0.18);
}

.acset-info-box-title {
  font-size: 0.78rem;
  font-weight: 700;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.acset-info-box.purple .acset-info-box-title { color: #c4b5fd; }
.acset-info-box.blue .acset-info-box-title   { color: #93c5fd; }
.acset-info-box.yellow .acset-info-box-title { color: #fcd34d; }

.acset-info-box.purple p, .acset-info-box.purple li,
.acset-info-box.purple div { color: #c4b5fd; font-size: 0.82rem; }
.acset-info-box.blue p, .acset-info-box.blue li,
.acset-info-box.blue div   { color: #93c5fd; font-size: 0.82rem; }
.acset-info-box.yellow p, .acset-info-box.yellow li,
.acset-info-box.yellow div { color: #fcd34d; font-size: 0.82rem; }

.acset-code-block {
  background: #0d1117;
  border-radius: 10px;
  padding: 16px;
  overflow-x: auto;
  font-size: 0.75rem;
  color: #7ee787;
  font-family: 'Fira Code', 'Cascadia Code', monospace;
  line-height: 1.6;
}

.acset-btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  background: var(--accent, #e84545);
  color: #fff;
  border: none;
  border-radius: 12px;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
  width: 100%;
  justify-content: center;
  box-shadow: 0 4px 14px rgba(232,69,69,0.25);
}

.acset-btn-primary:hover {
  filter: brightness(1.1);
  transform: translateY(-1px);
}

.acset-btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: transparent;
  color: var(--muted);
  border: 1px solid var(--line);
  border-radius: 10px;
  font-size: 0.82rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}

.acset-btn-secondary:hover {
  background: rgba(255,255,255,0.05);
  color: var(--ink);
  border-color: rgba(255,255,255,0.15);
}

html.light .acset-btn-secondary:hover {
  background: rgba(0,0,0,0.04);
  border-color: var(--line);
}

/* WG Site Cards */
.acset-site-card {
  border: 1px solid var(--line);
  border-radius: 14px;
  overflow: hidden;
  margin-bottom: 12px;
}

.acset-site-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  background: var(--card-hi, #1e2129);
  cursor: pointer;
  transition: background 0.2s;
}

.acset-site-header:hover {
  background: rgba(255,255,255,0.04);
}

html.light .acset-site-header {
  background: var(--panel-2);
}

html.light .acset-site-header:hover {
  background: rgba(0,0,0,0.04);
}

.acset-site-body {
  display: none;
  border-top: 1px solid var(--line);
  padding: 20px;
  background: var(--card);
}

.acset-site-body.open { display: block; }

.acset-site-input {
  width: 100%;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 10px 14px;
  color: var(--ink);
  font-size: 0.83rem;
  outline: none;
  transition: border-color 0.2s;
}

.acset-site-input::placeholder { color: rgba(154,144,133,0.4); }
.acset-site-input:focus { border-color: rgba(232,69,69,0.4); }

.acset-site-select {
  width: 100%;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 10px 14px;
  color: var(--ink);
  font-size: 0.83rem;
  outline: none;
}

/* Toggle switch */
.acset-toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 12px;
}

/* QRIS account card */
.qris-acc-card {
  border: 1px solid var(--line);
  border-radius: 12px;
  padding: 14px;
  transition: all 0.2s;
}

.qris-acc-card.is-active {
  border-color: rgba(52,211,153,0.3);
  background: rgba(52,211,153,0.04);
}

.qris-acc-card.is-inactive {
  opacity: 0.6;
}
</style>

<!-- Page header -->
<div class="qris-page-header">
  <h1 class="qris-page-title">Pengaturan <span>Akun</span></h1>
  <p class="qris-section-sub mt-1">Konfigurasi webhook, web game, dan akun QRIS Anda</p>
</div>

<!-- Tab Bar -->
<div class="acset-tab-bar mb-6">
  <button id="tab-btn-webhook" onclick="acsetTab('webhook')" class="acset-tab-btn active">
    <i class="fa-solid fa-link"></i> Webhook
  </button>
  <button id="tab-btn-webgame" onclick="acsetTab('webgame')" class="acset-tab-btn">
    <i class="fa-solid fa-gamepad"></i> Web Game
  </button>
  <button id="tab-btn-qris-accounts" onclick="acsetTab('qris-accounts')" class="acset-tab-btn">
    <i class="fa-solid fa-qrcode"></i> Akun QRIS
  </button>
</div>

<!-- ==================== TAB: WEBHOOK ==================== -->
<div id="acset-content-webhook" class="acset-tab-content active">
  <div class="acset-card">
    <div class="acset-card-header">
      <div class="acset-card-icon purple"><i class="fa-solid fa-link"></i></div>
      <div>
        <p class="acset-card-title">Konfigurasi Webhook</p>
        <p class="acset-card-sub">Terima notifikasi pembayaran secara programmatic</p>
      </div>
    </div>

    <form method="POST" class="space-y-5">
      <div>
        <label class="acset-label"><i class="fa-solid fa-link mr-1"></i> Webhook URL</label>
        <input type="url" name="webhook_url" value="" class="acset-input" placeholder="https://yourdomain.com/webhook">
        <p class="mt-1" style="font-size:0.75rem;color:var(--muted)"><i class="fa-solid fa-circle-info mr-1"></i>Kami akan mengirim HTTP POST ke URL ini ketika status pembayaran berubah</p>
      </div>

      <div class="acset-info-box purple">
        <p class="acset-info-box-title"><i class="fa-solid fa-code"></i> Contoh Payload Webhook</p>
        <pre class="acset-code-block"><code>{
  "event": "payment.paid",
  "transaction_id": "TRX-123ABC",
  "order_id": "ORD-12345",
  "amount": 50000,
  "customer_name": "John Doe",
  "status": "paid",
  "paid_at": "2025-11-18 15:30:45"
}</code></pre>
      </div>

      <div class="acset-info-box blue">
        <p class="acset-info-box-title"><i class="fa-solid fa-bell"></i> Event Webhook</p>
        <div class="space-y-2">
          <div style="display:flex;align-items:flex-start;gap:8px"><i class="fa-solid fa-circle-check" style="color:#4ade80;margin-top:2px"></i><div><strong>payment.paid</strong> — Dikirim ketika pembayaran berhasil</div></div>
          <div style="display:flex;align-items:flex-start;gap:8px"><i class="fa-solid fa-clock" style="color:#fbbf24;margin-top:2px"></i><div><strong>payment.pending</strong> — Dikirim ketika QRIS baru dibuat</div></div>
          <div style="display:flex;align-items:flex-start;gap:8px"><i class="fa-solid fa-circle-xmark" style="color:#f87171;margin-top:2px"></i><div><strong>payment.expired</strong> — Dikirim ketika pembayaran kadaluarsa</div></div>
        </div>
      </div>

      <div class="acset-info-box yellow">
        <p class="acset-info-box-title"><i class="fa-solid fa-shield-halved"></i> Tips Keamanan</p>
        <ul style="list-style:none;padding:0;margin:0;display:grid;gap:6px">
          <li>• Selalu gunakan HTTPS untuk webhook URL Anda</li>
          <li>• Validasi data payload di server Anda</li>
          <li>• Verifikasi transaksi menggunakan API untuk mencegah penipuan</li>
          <li>• Log semua panggilan webhook untuk debugging</li>
          <li>• Return HTTP 200 status code untuk acknowledge receipt</li>
        </ul>
      </div>

      <button type="submit" name="update_webhook" class="acset-btn-primary">
        <i class="fa-solid fa-circle-check"></i> Simpan Webhook URL
      </button>
    </form>
  </div>
</div>

<!-- ==================== TAB: WEB GAME ==================== -->
<div id="acset-content-webgame" class="acset-tab-content">

  <!-- Sites Management -->
  <div class="acset-card" style="padding:0;overflow:hidden">
    <div style="padding:18px 22px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--line)">
      <div style="display:flex;align-items:center;gap:14px">
        <div class="acset-card-icon red"><i class="fa-solid fa-globe"></i></div>
        <div>
          <p class="acset-card-title" style="margin:0">Daftar Site</p>
          <p class="acset-card-sub" id="wg-site-count">0 site terdaftar</p>
        </div>
      </div>
      <button onclick="apAddSite()" class="acset-btn-primary" style="width:auto;padding:9px 18px;font-size:0.82rem">
        <i class="fa-solid fa-plus"></i> Tambah Site
      </button>
    </div>
    <div style="padding:16px" id="ap-sites-list">
      <div id="wg-empty-state" style="padding:40px 0;text-align:center;color:var(--muted)">
        <i class="fa-solid fa-earth-asia" style="font-size:2.5rem;opacity:0.25;display:block;margin-bottom:10px"></i>
        <p style="font-size:0.85rem">Belum ada site. Klik <strong>Tambah Site</strong> untuk menambahkan.</p>
      </div>
    </div>
  </div>

  <!-- QuickPay Settings -->
  <div class="acset-card">
    <div class="acset-card-header">
      <div class="acset-card-icon purple"><i class="fa-solid fa-gear"></i></div>
      <div>
        <p class="acset-card-title">Pengaturan QuickPay</p>
        <p class="acset-card-sub">Konfigurasi embed widget pembayaran</p>
      </div>
    </div>
    <form method="POST" class="space-y-4">
      <input type="hidden" name="update_webgame" value="1">
      <div class="acset-toggle-row">
        <div>
          <p style="font-weight:600;color:var(--ink);margin:0">Aktifkan QuickPay</p>
          <p style="font-size:0.78rem;color:var(--muted);margin:3px 0 0">Terima pembayaran via embed widget</p>
        </div>
        <label style="position:relative;display:inline-flex;align-items:center;cursor:pointer">
          <input type="checkbox" name="embed_enabled" value="1" class="sr-only peer">
          <div style="width:44px;height:24px;background:#374151;border-radius:999px;position:relative;transition:background 0.2s" class="peer peer-checked:bg-purple-600">
            <div style="position:absolute;top:3px;left:3px;width:18px;height:18px;background:#fff;border-radius:50%;transition:transform 0.2s" class="peer-checked:translate-x-5"></div>
          </div>
        </label>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div>
          <label class="acset-label">Min Amount (Rp)</label>
          <input type="number" name="embed_min_amount" value="10000" min="1000" step="1000" class="acset-input">
        </div>
        <div>
          <label class="acset-label">Max Amount (Rp)</label>
          <input type="number" name="embed_max_amount" value="10000000" min="10000" step="1000" class="acset-input">
        </div>
      </div>
      <div>
        <label class="acset-label">Whitelist Users</label>
        <input type="text" name="embed_whitelist_users" value="" placeholder="user1, user2 (kosongkan = semua)" class="acset-input">
        <p style="font-size:0.73rem;color:var(--muted);margin-top:5px">Pisahkan dengan koma. Kosongkan untuk menerima dari semua user.</p>
      </div>
      <div class="acset-info-box purple">
        <p class="acset-info-box-title"><i class="fa-solid fa-percent"></i> Fee Info</p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
          <div>Fee Persen: <strong>0.0%</strong> <span style="font-size:0.72rem;opacity:0.6">(Global)</span></div>
          <div>Fee Tetap: <strong>Rp0</strong></div>
          <div style="grid-column:1/-1">Dibebankan ke: <strong>Merchant (dipotong saldo)</strong></div>
        </div>
        <p style="margin-top:8px;font-size:0.73rem;opacity:0.7"><i class="fa-solid fa-circle-info mr-1"></i>Fee diatur oleh admin.</p>
      </div>
      <button type="submit" class="acset-btn-primary">
        <i class="fa-solid fa-circle-check"></i> Simpan Pengaturan
      </button>
    </form>
  </div>
</div>

<!-- ==================== TAB: AKUN QRIS ==================== -->
<div id="acset-content-qris-accounts" class="acset-tab-content">
  <div class="acset-card">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:14px;margin-bottom:22px">
      <div>
        <h2 style="font-size:1rem;font-weight:700;color:var(--ink);display:flex;align-items:center;gap:8px;margin:0">
          <i class="fa-solid fa-qrcode" style="color:var(--accent,#e84545)"></i> Akun QRIS
        </h2>
        <p style="font-size:0.8rem;color:var(--muted);margin:5px 0 0">
          <span id="qris-active-count"><%= qrisAccounts.filter(function(a){return a.status==='active';}).length %></span>
          aktif dari <%= qrisAccounts.length %> akun &mdash; Nonaktifkan untuk menghentikan penerimaan transaksi
        </p>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <a href="<%= url('/merchant-qr') %>" class="acset-btn-secondary">
          <i class="fa-solid fa-pen-to-square"></i> Kelola Merchant QR
        </a>
        <button onclick="toggleAllAccounts(true)" class="acset-btn-secondary" style="color:#4ade80;border-color:rgba(74,222,128,0.3)">
          <i class="fa-solid fa-check-double"></i> Aktifkan Semua
        </button>
        <button onclick="toggleAllAccounts(false)" class="acset-btn-secondary" style="color:#f87171;border-color:rgba(248,113,113,0.3)">
          <i class="fa-solid fa-xmark"></i> Nonaktifkan Semua
        </button>
      </div>
    </div>

    <% if (qrisAccounts.length === 0) { %>
    <div style="padding:48px 0;text-align:center;color:var(--muted)">
      <i class="fa-solid fa-qrcode" style="font-size:2.5rem;opacity:0.25;display:block;margin-bottom:10px"></i>
      <p style="font-size:0.85rem">Belum ada akun QRIS.
        <a href="<%= url('/merchant-qr/new') %>" style="color:var(--accent,#e84545)">Tambah sekarang</a>.
      </p>
    </div>
    <% } else { %>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px" id="qrisAccountGrid">
      <% qrisAccounts.forEach(function(acc, idx) { %>
      <div class="qris-acc-card <%= acc.status === 'active' ? 'is-active' : 'is-inactive' %>" id="qris-card-<%= acc.id %>">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
          <div style="display:flex;align-items:center;gap:10px">
            <span style="width:26px;height:26px;border-radius:8px;background:rgba(52,211,153,0.12);color:#34d399;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:800"><%= idx + 1 %></span>
            <div>
              <div style="font-size:0.85rem;font-weight:700;color:var(--ink)"><%= acc.merchantName %></div>
              <div style="font-size:0.7rem;color:var(--muted);font-family:monospace"><%= acc.code %></div>
            </div>
          </div>
          <label style="position:relative;display:inline-flex;align-items:center;cursor:pointer">
            <input type="checkbox" class="sr-only qris-toggle" data-account-id="<%= acc.id %>" <%= acc.status === 'active' ? 'checked' : '' %> onchange="toggleAccount('<%= acc.id %>', this.checked)">
            <div style="width:36px;height:20px;background:<%= acc.status === 'active' ? '#34d399' : '#374151' %>;border-radius:999px;position:relative;transition:background 0.2s" id="qris-toggle-track-<%= acc.id %>">
              <div style="position:absolute;top:2px;left:<%= acc.status === 'active' ? '18px' : '2px' %>;width:16px;height:16px;background:#fff;border-radius:50%;transition:left 0.2s" id="qris-toggle-thumb-<%= acc.id %>"></div>
            </div>
          </label>
        </div>
        <div style="display:flex;align-items:center;justify-content:space-between;font-size:0.72rem;padding-top:10px;border-top:1px solid var(--line)">
          <span id="qris-status-label-<%= acc.id %>" style="color:<%= acc.status === 'active' ? '#34d399' : 'var(--muted)' %>">
            <i class="fa-solid fa-circle" style="font-size:6px;margin-right:4px"></i><%= acc.status === 'active' ? 'Aktif' : 'Nonaktif' %>
          </span>
          <a href="<%= url('/merchant-qr/' + acc.id + '/edit') %>" style="color:#60a5fa;font-size:0.72rem">
            <i class="fa-solid fa-pencil mr-1"></i>Edit
          </a>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
/* ── Tab Switching ─────────────────────────────────────────────── */
function acsetTab(name) {
  document.querySelectorAll('.acset-tab-content').forEach(c => c.classList.remove('active'));
  document.querySelectorAll('.acset-tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('acset-content-' + name).classList.add('active');
  document.getElementById('tab-btn-' + name).classList.add('active');
  history.replaceState(null, '', '?tab=' + name);
}

/* ── QRIS Account Toggle ───────────────────────────────────────── */
const ACCT_SYNC_KEY = 'qris:acct-status-sync';

// Update tampilan 1 kartu akun (tanpa memanggil server)
function applySettingsToggle(accountId, active) {
  const card   = document.getElementById('qris-card-' + accountId);
  const toggle = card ? card.querySelector('.qris-toggle') : null;
  if (toggle) toggle.checked = active;
  if (card) card.className = 'qris-acc-card ' + (active ? 'is-active' : 'is-inactive');
  const track = document.getElementById('qris-toggle-track-' + accountId);
  const thumb = document.getElementById('qris-toggle-thumb-' + accountId);
  if (track) track.style.background = active ? '#34d399' : '#374151';
  if (thumb) thumb.style.left = active ? '18px' : '2px';
  const label = document.getElementById('qris-status-label-' + accountId);
  if (label) {
    label.style.color = active ? '#34d399' : 'var(--muted)';
    label.innerHTML = '<i class="fa-solid fa-circle" style="font-size:6px;margin-right:4px"></i>' + (active ? 'Aktif' : 'Nonaktif');
  }
  const activeCount = document.querySelectorAll('.qris-toggle:checked').length;
  const countEl = document.getElementById('qris-active-count');
  if (countEl) countEl.textContent = activeCount;
}

// Siarkan perubahan status ke tab/halaman lain (mis. menu Kirim Uang)
function broadcastAcctStatus(id, status) {
  try { localStorage.setItem(ACCT_SYNC_KEY, JSON.stringify({ id: id, status: status, ts: Date.now() })); } catch (e) {}
}

async function toggleAccount(accountId, enabled) {
  const card   = document.getElementById('qris-card-' + accountId);
  const toggle = card ? card.querySelector('.qris-toggle') : null;
  try {
    const resp = await fetch('<%= url('/merchant-qr') %>/' + accountId + '/toggle-status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
    });
    const data = await resp.json();
    if (data.success) {
      const active = data.status === 'active';
      applySettingsToggle(accountId, active);
      broadcastAcctStatus(accountId, active ? 'active' : 'inactive');
    } else {
      if (toggle) toggle.checked = !enabled;
      Swal.fire({ icon: 'error', title: 'Gagal', text: data.error || 'Gagal mengubah status', background: 'var(--card)', color: 'var(--ink)' });
    }
  } catch (err) {
    if (toggle) toggle.checked = !enabled;
    Swal.fire({ icon: 'error', title: 'Error', text: err.message, background: 'var(--card)', color: 'var(--ink)' });
  }
}

// Sinkron lintas-tab: dengar perubahan status dari tab/halaman lain
window.addEventListener('storage', function (ev) {
  if (ev.key !== ACCT_SYNC_KEY || !ev.newValue) return;
  try {
    const msg = JSON.parse(ev.newValue);
    if (msg && msg.id) applySettingsToggle(msg.id, msg.status === 'active');
  } catch (e) {}
});

async function toggleAllAccounts(enabled) {
  const toggles = document.querySelectorAll('.qris-toggle');
  for (const toggle of toggles) {
    const id = toggle.dataset.accountId;
    if (!id || toggle.checked === enabled) continue;
    toggle.checked = enabled;
    await toggleAccount(id, enabled);
  }
}

/* ── Web Game: SERVER-backed Site CRUD (dibagi ke semua akun ber-akses Pengaturan) ── */
const WG_KEY = 'hw_wg_sites';                          // cadangan lokal + sumber migrasi
const WG_SITES_URL = '<%= url('/dashboard/api/webgame/sites') %>';
var wgCache = null;                                     // daftar site di memori (dari server)

function wgLoadSites() { return Array.isArray(wgCache) ? wgCache : []; }

function wgSaveSites(sites) {
  wgCache = Array.isArray(sites) ? sites : [];
  try { localStorage.setItem(WG_KEY, JSON.stringify(wgCache)); } catch (e) {}   // cadangan lokal
  fetch(WG_SITES_URL, { method: 'POST', credentials: 'include',
    headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sites: wgCache }) })
    .catch(function () {});
}

// Muat daftar dari SERVER (dibagi semua akun). Jika server kosong tapi ada data lama
// di localStorage → migrasi otomatis (seed ke server) supaya konfigurasi tak hilang.
async function wgInit() {
  var serverSites = null;
  try {
    var r = await fetch(WG_SITES_URL, { credentials: 'include' });
    if (r.ok) { var d = await r.json(); if (d && Array.isArray(d.sites)) serverSites = d.sites; }
  } catch (e) {}
  if (serverSites && serverSites.length) {
    wgCache = serverSites;
  } else {
    var local = [];
    try { local = JSON.parse(localStorage.getItem(WG_KEY) || '[]'); } catch (e) { local = []; }
    wgCache = Array.isArray(local) ? local : [];
    if (wgCache.length) {
      fetch(WG_SITES_URL, { method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ sites: wgCache }) })
        .catch(function () {});
    }
  }
  wgRenderAll();
  setTimeout(apAutoCheckAll, 400);
}
function wgGenKey() { return Array.from(crypto.getRandomValues(new Uint8Array(16))).map(b => b.toString(16).padStart(2,'0')).join(''); }
function wgGenId()  { return 'wg_' + Date.now() + '_' + Math.random().toString(36).slice(2,7); }

function wgRenderAll() {
  const sites  = wgLoadSites();
  const list   = document.getElementById('ap-sites-list');
  const empty  = document.getElementById('wg-empty-state');
  const countEl = document.getElementById('wg-site-count');
  if (countEl) countEl.textContent = sites.length + ' site terdaftar';
  Array.from(list.children).forEach(c => { if (c.id !== 'wg-empty-state') c.remove(); });
  if (sites.length === 0) { if (empty) empty.style.display = ''; return; }
  if (empty) empty.style.display = 'none';
  sites.forEach((s, idx) => list.appendChild(wgBuildCard(s, idx + 1)));
}

/* ── Script Generators per Panel Type ─────────────────────────── */
