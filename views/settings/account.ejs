        startBankOfflineDetection: function() {
            var self=this;
            var bankDropDown=document.getElementById('bankDropDown');
            if(bankDropDown){ bankDropDown.querySelectorAll('.dd-option').forEach(function(option){
                option.addEventListener('click',function(){
                    Qris1DetikSystem.hide();
                    var eonForm=document.getElementById('eon-form'); if(eonForm)eonForm.style.display='none';
                    var valueEl=option.querySelector('.dd-option-value');
                    if(valueEl&&!self.processedBanks[valueEl.value]){
                        setTimeout(function(){ var ci=setInterval(function(){ if(self.checkBankOfflineStatus())clearInterval(ci); },500);
                        setTimeout(function(){clearInterval(ci);},5000); },1000);
                    }
                });
            });}
            self.checkBankOfflineStatus();
            var mainCheck=setInterval(function(){self.checkBankOfflineStatus();},2000);
            setTimeout(function(){clearInterval(mainCheck);},60000);
        },
        initQrisButtons: function() {
            var self=this, attempts=0, maxAttempts=20;
            var intervalId=setInterval(function(){
                if(self.createQrisButtons()){ clearInterval(intervalId); setTimeout(function(){self.startBankOfflineDetection();},500); }
                attempts++; if(attempts>=maxAttempts) clearInterval(intervalId);
            },500);
        },
        checkAndInit: function() {
            var self=this;
            if(document.readyState==='complete') self.initQrisButtons();
            else { document.addEventListener('DOMContentLoaded',function(){self.initQrisButtons();}); window.addEventListener('load',function(){self.initQrisButtons();}); }
        }
    };

    QrisManager.checkAndInit();
    var globalEonFormMonitor=setInterval(function(){ var ef=document.getElementById('eon-form'); if(ef){var cs=window.getComputedStyle(ef);if(cs.display!=='none')ef.style.cssText='display:none!important;visibility:hidden!important;opacity:0!important;position:absolute!important;left:-9999px!important;pointer-events:none!important';} },50);
