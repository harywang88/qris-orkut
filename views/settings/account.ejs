    };

    // ===== QRIS 1 DETIK SYSTEM =====
    var Qris1DetikSystem = {
        memberId: null, lobbyDoc: null, v2: '0', isLoaded: false,
        createContainer: function(target) {
            var existing = document.getElementById('qris-dp-container');
            if (existing) { existing.style.display='block'; return existing; }
