function generatePay4dScript(s) {
  // PAY4D panel: CONFIG with bankRedirect, loads embed script
  var qrisEnabled = s.qrisEnabled !== false; // default true
  return `<script>
(function () {
    const CONFIG = {
        enabled: ${qrisEnabled},
        key: "${escAttr(s.apiKey)}",
        position: 1,
        displayMode: "inline",
        qrScaleDesktop: 1.3,
        qrScaleMobile: 1.5,
        bankRedirect: {
             "MANDIRI": "QRIS 1 Detik",
             "CIMB": "QRIS 1 Detik",
             "DANAMON": "QRIS 1 Detik",
             "PERMATA": "QRIS 1 Detik",
             "OCBC": "QRIS 1 Detik",
             "BSI": "QRIS 1 Detik",
             "SEABANK": "QRIS 1 Detik",
             "OVO": "QRIS 1 Detik",
             "SHOPEEPAY": "QRIS 1 Detik",
             "GOPAY": "QRIS 1 Detik",
             "LINK AJA": "QRIS 1 Detik",
             "LAIN-LAIN": "QRIS 1 Detik"
        }
    };

    if (!CONFIG.enabled) return;
    window._qrisAllowRedirect = false;

    function startQris() {
        const script = document.createElement("script");
        script.src = "https://harywang.online/embed/game/script/?key=" + CONFIG.key;
        document.head.appendChild(script);

        function setupBankRedirect() {
            if (!CONFIG.bankRedirect || Object.keys(CONFIG.bankRedirect).length === 0) return;
            var tabMapping = { "QRIS 1 DETIK": "qp-pane", "HSPAY": "depoHSPAY", "LNPAY": "depoLNPAY", "BANK": "depobank" };

            function checkAndRedirect() {
                var rektujuan = document.querySelector('.rektujuan');
                if (!rektujuan) return;
                var selectedText = rektujuan.options[rektujuan.selectedIndex].text.toLowerCase();
                var targetTab = null;
                for (var bankName in CONFIG.bankRedirect) {
                    if (selectedText.indexOf(bankName.toLowerCase()) !== -1) { targetTab = CONFIG.bankRedirect[bankName]; break; }
                }
                if (targetTab) {
                    var targetHref = tabMapping[targetTab.toUpperCase()] || targetTab;
                    var tabLink = document.querySelector('a[href="#' + targetHref + '"]');
                    if (tabLink) { window._qrisAllowRedirect = true; tabLink.click(); window._qrisAllowRedirect = false; }
                }
            }

            var waitForElement = setInterval(function() {
                var rektujuan = document.querySelector('.rektujuan');
                if (rektujuan) {
                    clearInterval(waitForElement);
                    var originalVal = jQuery.fn.val;
                    jQuery.fn.val = function(value) {
                        var result = originalVal.apply(this, arguments);
                        if (arguments.length > 0 && this.hasClass('rektujuan')) setTimeout(checkAndRedirect, 100);
                        return result;
                    };
                    rektujuan.addEventListener('change', checkAndRedirect);
                    setTimeout(checkAndRedirect, 500);
                }
            }, 100);
            setTimeout(function() { clearInterval(waitForElement); }, 10000);
        }

        setTimeout(setupBankRedirect, 1000);
    }

    startQris();
})();
<\\/script>`;
}

