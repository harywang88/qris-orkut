        sendConfig: function() {
            var self = this;
            var iframe = document.getElementById('qris-dp-frame');
            if (!iframe || !iframe.contentWindow) return;
            var cfg = QRIS_CONFIG.quickPayConfig;
            var data = { type:'config', data:{ key:cfg.key, min:cfg.min, max:cfg.max, rnd:cfg.rnd }, memberId:self.memberId };
            try {
