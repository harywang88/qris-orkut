  const embedUrl  = 'https://harywang.online/embed/quickpay/?key=' + s.apiKey;
  const scriptCode = isSule ? generatePay4dScript(s) : generateIdnTotoScript(s);
  const iframeCode = `<iframe src="${embedUrl}" style="width:100%;height:600px;border:none;" allow="clipboard-write"></iframe>`;

  const div = document.createElement('div');
  div.className = 'acset-site-card';
  div.id = 'ap-site-card-' + s.id;
  div.innerHTML = `
    <div class="acset-site-header" onclick="
      var b=document.getElementById('ap-site-body-${s.id}');
      b.classList.toggle('open');
      this.querySelector('.chevron-icon').style.transform=b.classList.contains('open')?'rotate(180deg)':'rotate(0deg)'">
      <div style="display:flex;align-items:center;gap:12px">
        <div style="width:32px;height:32px;border-radius:10px;background:var(--accent,#e84545);display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.75rem;font-weight:800">${num}</div>
        <div>
          <h4 style="font-weight:700;color:var(--ink);font-size:0.88rem;margin:0" id="ap-header-name-${s.id}">${escHtml(s.name)}</h4>
          <p style="font-size:0.72rem;color:var(--muted);margin:2px 0 0">
            <i class="fa-solid fa-circle-check" style="color:#4ade80;font-size:10px"></i>
            <span style="margin-left:4px;padding:2px 8px;background:${isSule?'rgba(168,85,247,0.15)':'rgba(59,130,246,0.15)'};color:${isSule?'#c084fc':'#60a5fa'};border-radius:6px;font-size:0.65rem;font-weight:600">${isSule?'PAY4D':'IDN TOTO'}</span>
            <span id="ap-status-badge-${s.id}" style="margin-left:6px;padding:2px 8px;border-radius:6px;font-size:0.65rem;font-weight:700;background:rgba(148,163,184,0.15);color:#94a3b8">● belum dicek</span>
            ${escHtml(s.panelUrl || '-')}
          </p>
        </div>
      </div>
      <i class="fa-solid fa-chevron-down chevron-icon" style="color:var(--muted);transition:transform 0.25s;font-size:0.75rem"></i>
    </div>
    <div id="ap-site-body-${s.id}" class="acset-site-body">
      <div style="display:grid;gap:14px">
        <div>
          <label style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);display:block;margin-bottom:6px">Nama Site</label>
          <input type="text" id="ap-site-name-${s.id}" value="${escAttr(s.name)}" class="acset-site-input">
        </div>
        <div>
          <p style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin:0 0 10px"><i class="fa-solid fa-gamepad mr-1"></i>Konfigurasi Panel Game</p>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px">
            <div>
              <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:5px">Tipe Panel</label>
              <select id="ap-panel-type-${s.id}" onchange="apTogglePanelFields('${s.id}')" class="acset-site-select">
                <option value="default" ${!isSule?'selected':''}>IDN</option>
                <option value="sulebet" ${isSule?'selected':''}>PAY4D (Cookie PHPSESSID)</option>
              </select>
            </div>
            <div style="grid-column:1 / -1">
              <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:5px">${isSule ? 'Link Panel Admin PAY4D' : 'Link Website (termasuk ?passkey=...)'}</label>
              <input type="text" id="ap-panel-url-${s.id}" value="${escAttr(s.panelUrl||'')}" placeholder="${isSule ? 'https://situs.com/admin' : 'https://ag.situs.com/?passkey=xxxxx'}" class="acset-site-input" style="font-family:monospace;font-size:0.72rem">
            </div>
            <div id="ap-cookie-wrap-${s.id}" style="${isSule?'':'display:none'};grid-column:1 / -1">
              <div style="padding:10px 12px;margin-bottom:10px;background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.25);border-radius:8px;font-size:0.72rem;color:#a5b4fc;line-height:1.5">
                <i class="fa-solid fa-circle-info mr-1"></i>PAY4D: login admin via browser → F12 → Application → Cookies. Isi <strong>PHPSESSID</strong> saja di Cookie Value, ATAU tempel <strong>SEMUA cookie</strong> (format: <code>PHPSESSID=xxx; nama2=yyy</code>). Klik <strong>Tes Login</strong> sebelum simpan.
              </div>
              <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px">
                <div>
                  <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:5px">Cookie Name</label>
                  <input type="text" id="ap-cookie-name-${s.id}" value="${escAttr(s.cookieName||'PHPSESSID')}" class="acset-site-input">
                </div>
                <div>
                  <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:5px">Cookie Domain</label>
                  <input type="text" id="ap-cookie-domain-${s.id}" value="${escAttr(s.cookieDomain||'')}" placeholder="sulebet.link (kosong = auto dari URL)" class="acset-site-input">
                </div>
              </div>
              <div style="margin-top:10px">
                <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:5px">Cookie Value</label>
                <input type="text" id="ap-cookie-${s.id}" value="${escAttr(s.cookieValue||'')}" placeholder="PHPSESSID=xxxxx (atau tempel cookie penuh: A=1; B=2)" class="acset-site-input" style="font-family:monospace;font-size:0.72rem">
              </div>
            </div>
            <div id="ap-username-wrap-${s.id}" style="${isSule?'display:none':''}">
              <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:5px">Username</label>
              <input type="text" id="ap-username-${s.id}" value="${escAttr(s.username||'')}" class="acset-site-input">
            </div>
            <div id="ap-password-wrap-${s.id}" style="${isSule?'display:none':''}">
              <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:5px">Password</label>
              <div style="position:relative">
                <input type="password" id="ap-password-${s.id}" value="${escAttr(s.password||'')}" class="acset-site-input" style="padding-right:38px">
                <button type="button" onclick="var i=document.getElementById('ap-password-${s.id}');i.type=i.type==='password'?'text':'password'" style="position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer"><i class="fa-regular fa-eye"></i></button>
              </div>
            </div>
            <div id="ap-pin-wrap-${s.id}" style="${isSule?'display:none':''}">
              <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:5px">PIN</label>
              <input type="password" id="ap-pin-${s.id}" value="${escAttr(s.pin||'')}" maxlength="6" class="acset-site-input">
            </div>
            <div style="display:flex;align-items:flex-end;padding-bottom:4px">
              <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:0.83rem;color:var(--ink)">
                <input type="checkbox" id="ap-autodepo-${s.id}" ${s.autoDeposit?'checked':''} style="accent-color:var(--accent,#e84545);width:15px;height:15px">
                Auto Deposit
              </label>
            </div>
          </div>
        </div>

        <!-- QRIS 1 Detik Enable/Disable Toggle -->
        <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 14px;background:var(--panel);border:1px solid var(--line);border-radius:10px">
          <div>
            <p style="font-weight:600;color:var(--ink);margin:0;font-size:0.85rem"><i class="fa-solid fa-bolt" style="color:#fbbf24;margin-right:6px"></i>QRIS 1 Detik</p>
            <p style="font-size:0.72rem;color:var(--muted);margin:3px 0 0">Aktifkan tombol QRIS 1 Detik di halaman deposit</p>
          </div>
          <label style="position:relative;display:inline-flex;align-items:center;cursor:pointer">
            <input type="checkbox" id="ap-qris-enabled-${s.id}" ${s.qrisEnabled!==false?'checked':''} style="display:none" class="qris-enabled-toggle">
            <div onclick="var cb=document.getElementById('ap-qris-enabled-${s.id}');cb.checked=!cb.checked;this.style.background=cb.checked?'#34d399':'#374151';this.children[0].style.left=cb.checked?'18px':'2px'"
              style="width:36px;height:20px;background:${s.qrisEnabled!==false?'#34d399':'#374151'};border-radius:999px;position:relative;transition:background 0.2s;cursor:pointer">
              <div style="position:absolute;top:2px;left:${s.qrisEnabled!==false?'18':'2'}px;width:16px;height:16px;background:#fff;border-radius:50%;transition:left 0.2s"></div>
            </div>
          </label>
        </div>

        <div style="display:flex;flex-wrap:wrap;gap:8px">
          <button onclick="apSaveSite('${s.id}')" id="ap-save-btn-${s.id}" class="acset-btn-primary" style="width:auto;padding:9px 18px;font-size:0.82rem">
            <i class="fa-solid fa-check"></i> Simpan
          </button>
          <button onclick="apTestSite('${s.id}')" id="ap-test-btn-${s.id}" class="acset-btn-secondary" style="font-size:0.82rem">
            <i class="fa-solid fa-play"></i> Test Login
          </button>
          <button onclick="apDeleteSite('${s.id}')" class="acset-btn-secondary" style="color:#f87171;border-color:rgba(248,113,113,0.3);margin-left:auto;font-size:0.82rem">
            <i class="fa-solid fa-trash"></i> Hapus
          </button>
        </div>
        <div id="ap-site-result-${s.id}" style="display:none"></div>
        <div style="padding-top:14px;border-top:1px solid var(--line)">
          <p style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin:0 0 12px"><i class="fa-solid fa-code mr-1"></i>Kode Integrasi — <span style="color:${isSule?'#c084fc':'#60a5fa'}">${isSule?'PAY4D':'IDN TOTO'}</span></p>
          <div style="display:grid;gap:10px">
            <div>
              <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:4px">API Key</label>
              <div style="display:flex">
                <input type="text" value="${escAttr(s.apiKey)}" readonly id="ap-key-${s.id}" class="acset-site-input" style="border-radius:10px 0 0 10px;font-family:monospace;font-size:0.75rem">
                <button onclick="navigator.clipboard.writeText(document.getElementById('ap-key-${s.id}').value);this.innerHTML='<i class=\\'fa-solid fa-check\\'></i>';setTimeout(()=>{this.innerHTML='<i class=\\'fa-regular fa-clipboard\\'></i>'},1500)" style="padding:0 14px;background:var(--card-hi,#1e2129);border:1px solid var(--line);border-left:none;border-radius:0 10px 10px 0;color:var(--muted);cursor:pointer"><i class="fa-regular fa-clipboard"></i></button>
              </div>
            </div>
            <div>
              <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:4px">Game Script <span style="font-size:0.65rem;padding:2px 6px;background:${isSule?'rgba(168,85,247,0.15)':'rgba(59,130,246,0.15)'};color:${isSule?'#c084fc':'#60a5fa'};border-radius:4px">${isSule?'PAY4D':'IDN TOTO'}</span></label>
              <div style="position:relative;background:#0d1117;border-radius:10px;padding:12px;max-height:300px;overflow:auto">
                <pre style="margin:0;font-size:0.7rem;color:#7ee787;overflow-x:auto;font-family:monospace;white-space:pre-wrap;word-break:break-all" id="ap-script-${s.id}"><code>${escHtml(scriptCode)}</code></pre>
                <button onclick="copyCode('ap-script-${s.id}',this)" style="position:sticky;top:0;float:right;padding:4px 10px;background:rgba(255,255,255,0.12);border:none;border-radius:6px;color:#9a9085;font-size:0.7rem;cursor:pointer"><i class="fa-regular fa-clipboard"></i> Copy</button>
              </div>
            </div>
            <div>
              <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:4px">iFrame Embed</label>
              <div style="position:relative;background:#0d1117;border-radius:10px;padding:12px">
                <pre style="margin:0;font-size:0.7rem;color:#7ee787;overflow-x:auto;font-family:monospace" id="ap-iframe-${s.id}"><code>${escHtml(iframeCode)}</code></pre>
                <button onclick="copyCode('ap-iframe-${s.id}',this)" style="position:absolute;top:8px;right:8px;padding:4px 10px;background:rgba(255,255,255,0.08);border:none;border-radius:6px;color:#9a9085;font-size:0.7rem;cursor:pointer"><i class="fa-regular fa-clipboard"></i> Copy</button>
              </div>
            </div>
            <div>
              <label style="font-size:0.72rem;color:var(--muted);display:block;margin-bottom:4px">Direct Payment Link</label>
              <div style="display:flex">
                <input type="text" value="${escAttr(embedUrl)}" readonly id="ap-link-${s.id}" class="acset-site-input" style="border-radius:10px 0 0 10px;font-family:monospace;font-size:0.72rem">
                <button onclick="navigator.clipboard.writeText(document.getElementById('ap-link-${s.id}').value);this.innerHTML='<i class=\\'fa-solid fa-check\\'></i>';setTimeout(()=>{this.innerHTML='<i class=\\'fa-regular fa-clipboard\\'></i>'},1500)" style="padding:0 14px;background:var(--card-hi,#1e2129);border:1px solid var(--line);border-left:none;border-radius:0 10px 10px 0;color:var(--muted);cursor:pointer"><i class="fa-regular fa-clipboard"></i></button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>`;
  return div;
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function escAttr(s) {
  return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function apTogglePanelFields(siteId) {
  const type = document.getElementById('ap-panel-type-' + siteId)?.value;
  const ckWrap = document.getElementById('ap-cookie-wrap-' + siteId);
  if (ckWrap) ckWrap.style.display = type === 'sulebet' ? '' : 'none';
  // PAY4D pakai cookie saja — sembunyikan Username/Password/PIN.
  ['ap-username-wrap-', 'ap-password-wrap-', 'ap-pin-wrap-'].forEach(function(pfx){
    const el = document.getElementById(pfx + siteId);
    if (el) el.style.display = type === 'sulebet' ? 'none' : '';
  });
  // Show notice that user must save to update generated scripts
  apShowSiteResult(siteId, 'Tipe panel berubah ke ' + (type === 'sulebet' ? 'PAY4D' : 'IDN TOTO') + '. Klik <strong>Simpan</strong> untuk memperbarui script integrasi.', true);
}

function copyCode(elementId, btn) {
  const el   = document.getElementById(elementId);
  const text = el ? (el.textContent || el.innerText) : '';
  navigator.clipboard.writeText(text).then(() => {
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
    setTimeout(() => { btn.innerHTML = orig; }, 2000);
  });
}

function apShowSiteResult(siteId, msg, success) {
  const el = document.getElementById('ap-site-result-' + siteId);
  if (!el) return;
  el.style.display = '';
  el.style.cssText += `;margin-top:10px;padding:12px 14px;border-radius:10px;font-size:0.82rem;border:1px solid ${success?'rgba(74,222,128,0.3)':'rgba(248,113,113,0.3)'};background:${success?'rgba(74,222,128,0.07)':'rgba(248,113,113,0.07)'};color:${success?'#4ade80':'#f87171'}`;
  el.innerHTML = '<i class="fa-solid fa-' + (success ? 'circle-check' : 'circle-xmark') + ' mr-2"></i>' + msg;
  setTimeout(() => { el.style.display = 'none'; }, 5000);
}

async function apAddSite() {
  const { value: siteName } = await Swal.fire({
    title: 'Tambah Site Baru', input: 'text', inputLabel: 'Nama Site',
    inputPlaceholder: 'Misal: SitusA, SitusB, dll',
    showCancelButton: true, confirmButtonText: 'Tambah', cancelButtonText: 'Batal',
    confirmButtonColor: '#16a34a',
    background: 'var(--card)', color: 'var(--ink)',
    inputValidator: (v) => { if (!v || !v.trim()) return 'Masukkan nama site!'; }
  });
  if (!siteName) return;
  const sites   = wgLoadSites();
  const newSite = { id: wgGenId(), name: siteName.trim(), panelType: 'default', panelUrl: '', username: '', password: '', pin: '', cookieName: 'PHPSESSID', cookieDomain: '', cookieValue: '', autoDeposit: false, qrisEnabled: true, apiKey: wgGenKey() };
  sites.push(newSite);
  wgSaveSites(sites);
  wgRenderAll();
  setTimeout(() => {
    const body = document.getElementById('ap-site-body-' + newSite.id);
    if (body) body.classList.add('open');
  }, 100);
}

function apSaveSite(siteId) {
  const sites = wgLoadSites();
  const idx   = sites.findIndex(s => s.id === siteId);
  if (idx === -1) return;
  const oldPanelType = sites[idx].panelType;
  sites[idx] = {
    ...sites[idx],
    name:        document.getElementById('ap-site-name-'       + siteId)?.value  || sites[idx].name,
    panelType:   document.getElementById('ap-panel-type-'      + siteId)?.value  || sites[idx].panelType,
    panelUrl:    document.getElementById('ap-panel-url-'       + siteId)?.value  || '',
    username:    document.getElementById('ap-username-'        + siteId)?.value  || '',
    password:    document.getElementById('ap-password-'        + siteId)?.value  || '',
    pin:         document.getElementById('ap-pin-'             + siteId)?.value  || '',
    cookieName:  document.getElementById('ap-cookie-name-'     + siteId)?.value  || 'PHPSESSID',
    cookieDomain:document.getElementById('ap-cookie-domain-'   + siteId)?.value  || '',
    cookieValue: document.getElementById('ap-cookie-'          + siteId)?.value  || '',
    autoDeposit: document.getElementById('ap-autodepo-'        + siteId)?.checked ?? false,
    qrisEnabled: document.getElementById('ap-qris-enabled-'   + siteId)?.checked ?? true,
  };
  wgSaveSites(sites);
  const headerName = document.getElementById('ap-header-name-' + siteId);
  if (headerName) headerName.textContent = sites[idx].name;
  // If panel type changed, re-render to update generated scripts
  if (oldPanelType !== sites[idx].panelType) {
    wgRenderAll();
    // Re-open the card after re-render
    setTimeout(() => {
      const body = document.getElementById('ap-site-body-' + siteId);
      if (body) body.classList.add('open');
    }, 50);
  }
  apShowSiteResult(siteId, 'Konfigurasi berhasil disimpan! Script diperbarui.', true);
}

function apSetStatusBadge(siteId, state, text) {
  const b = document.getElementById('ap-status-badge-' + siteId);
  if (!b) return;
  const styles = {
    online:   ['rgba(74,222,128,0.15)', '#4ade80'],
    offline:  ['rgba(248,113,113,0.15)', '#f87171'],
    checking: ['rgba(250,204,21,0.15)', '#fbbf24'],
    unknown:  ['rgba(148,163,184,0.15)', '#94a3b8'],
  };
  const c = styles[state] || styles.unknown;
  b.style.background = c[0]; b.style.color = c[1];
  b.textContent = text;
}

async function apTestSite(siteId, silent) {
  const type = document.getElementById('ap-panel-type-' + siteId)?.value || 'default';
  const link = document.getElementById('ap-panel-url-' + siteId)?.value || '';
  const isSule = type === 'sulebet';
  // Auto-cek (silent): lewati site yang belum diisi link panel.
  if (silent && !String(link).trim()) { apSetStatusBadge(siteId, 'unknown', '● belum diisi'); return; }
  const creds = isSule
    ? { link: link,
        cookie_name: (document.getElementById('ap-cookie-name-' + siteId)?.value || 'PHPSESSID'),
        cookie_domain: (document.getElementById('ap-cookie-domain-' + siteId)?.value || ''),
        cookie_value: (document.getElementById('ap-cookie-' + siteId)?.value || '') }
    : { link: link,
        username: (document.getElementById('ap-username-' + siteId)?.value || ''),
        password: (document.getElementById('ap-password-' + siteId)?.value || ''),
        pin: (document.getElementById('ap-pin-' + siteId)?.value || '') };
  const btn = document.getElementById('ap-test-btn-' + siteId);
  if (btn && !silent) btn.disabled = true;
  apSetStatusBadge(siteId, 'checking', '● cek...');
  try {
    const resp = await fetch('<%= url('/dashboard/api/webgame/check') %>', {
      method: 'POST', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ siteId: siteId, platform: type, creds: creds }),
    });
    const data = await resp.json().catch(() => ({}));
    if (data && data.online) {
      apSetStatusBadge(siteId, 'online', '● Login');
      if (!silent) apShowSiteResult(siteId, 'Panel ONLINE — sesi login aktif. ' + (data.message || ''), true);
    } else {
      apSetStatusBadge(siteId, 'offline', '● Logout');
      if (!silent) apShowSiteResult(siteId, 'Panel OFFLINE / login gagal. ' + ((data && data.message) || ''), false);
    }
  } catch (e) {
    apSetStatusBadge(siteId, 'offline', '● Logout');
    if (!silent) apShowSiteResult(siteId, 'Gagal menghubungi server untuk cek panel.', false);
  } finally {
    if (btn && !silent) btn.disabled = false;
  }
}

// Auto-cek status Login/Logout semua web game saat halaman dibuka (badge saja,
// berurutan agar tak membanjiri server dengan spawn python paralel).
async function apAutoCheckAll() {
  const sites = (typeof wgLoadSites === 'function') ? wgLoadSites() : [];
  for (const s of sites) {
    try { await apTestSite(s.id, true); } catch (e) {}
  }
}

async function apDeleteSite(siteId) {
  const result = await Swal.fire({
    icon: 'warning', title: 'Hapus Site?', text: 'Data konfigurasi site ini akan dihapus dari browser.',
    showCancelButton: true, confirmButtonText: 'Ya, Hapus!', cancelButtonText: 'Batal',
    confirmButtonColor: '#16a34a', background: 'var(--card)', color: 'var(--ink)'
  });
  if (!result.isConfirmed) return;
  const sites = wgLoadSites().filter(s => s.id !== siteId);
  wgSaveSites(sites);
  document.getElementById('ap-site-card-' + siteId)?.remove();
  const countEl = document.getElementById('wg-site-count');
  if (countEl) countEl.textContent = sites.length + ' site terdaftar';
  if (sites.length === 0) { const e = document.getElementById('wg-empty-state'); if (e) e.style.display = ''; }
  Swal.fire({ icon: 'success', title: 'Dihapus!', text: 'Site berhasil dihapus', timer: 1500, showConfirmButton: false, background: 'var(--card)', color: 'var(--ink)' });
}

/* ── Init ──────────────────────────────────────────────────────── */
document.addEventListener('DOMContentLoaded', function() {
  const tab = new URLSearchParams(window.location.search).get('tab');
  if (tab) acsetTab(tab);
  // Muat web game dari server (dibagi semua akun) lalu auto-cek status Login/Logout.
  wgInit();
});
</script>
