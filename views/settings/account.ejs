                context.memberId = cu.innerText.split('IDR')[0].trim();
                callback();
            } else {
                if (context.memberId) { callback(); return; }
                context.memberId = self.detectUsername();
                if (context.memberId) { callback(); return; }
                self.getMemberName(context.lobbyDoc).then(function(doc) {
                    if (!doc) { callback(); return; }
                    context.lobbyDoc = doc;
                    for (var i = 0; i < usernameSelectors.length; i++) {
                        var el = doc.querySelector(usernameSelectors[i]);
                        if (el) {
                            var text = (el.innerText||el.textContent||'').split('IDR')[0].trim();
                            if (text && text.length > 0 && text.length < 50) {
                                context.memberId = text;
                                if (usernameSelectors[i]==='.user-login') context.v2='1';
                                break;
                            }
                        }
                    }
                    callback();
                });
            }
