            var bankContainer=document.getElementById('bank');
            if(bankContainer){ bankContainer.insertBefore(notice,bankContainer.firstChild);
                setTimeout(function(){ var old=document.querySelector('.bank-offline-notice'); if(old)old.remove(); self.handleQris1DetikClick(); },1000);
