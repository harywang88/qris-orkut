            return whitelist.indexOf(username.toLowerCase()) !== -1;
        },
        getMemberName: async function(lobbyDocCache) {
            if (lobbyDocCache) return lobbyDocCache;
            var paths = ['/lobby', '/home.php', '/m/deposit'];
            for (var i = 0; i < paths.length; i++) {
                try {
                    var r = await fetch(location.origin + paths[i], { method:'GET', credentials:'include',
                        headers:{'accept':'text/html','cache-control':'max-age=0','sec-fetch-dest':'document','sec-fetch-mode':'navigate','sec-fetch-site':'same-origin','upgrade-insecure-requests':'1'}});
                    var t = await r.text();
