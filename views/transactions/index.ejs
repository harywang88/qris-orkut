          <% if (typeof pendingCarryProcessed !== 'undefined' && pendingCarryProcessed) { %><div class="tx-stat-sub" style="color:#93c5fd" title="Uang pending kemarin yg diproses hari ini — di luar omset">&#8617; pending kemarin: Rp <%= pendingCarryProcessed.toLocaleString('id-ID') %></div><% } %>
