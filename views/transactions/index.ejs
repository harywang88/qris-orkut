<% if (transactions.length > 0) { %>
<script>
const tableData = <%- JSON.stringify(transactions.map((tx) => {
  const fallbackMutation = (tx.mutations || []).find((mutation) => mutation.rrn || mutation.issuerName) || tx.mutations?.[0] || null;

  return {
    id: tx.id,
    qrId: tx.qrId,
    qrisAccountId: tx.qrisAccountId,
    clientName: tx.client?.name || '-',
    panelCode: tx.client?.panelCode || '-',
    accountCode: tx.qrisAccount.code,
    merchantName: tx.qrisAccount.merchantName,
    requestedAmount: tx.requestedAmount,
    finalAmount: tx.finalAmount,
    feeAmount: tx.feeAmount || 0,
    uniqueCode: tx.uniqueCode,
    statusPay: tx.statusPay,
    statusBot: tx.statusBot,
    expiresAt: tx.expiresAt,
    paidAt: tx.paidAt || fallbackMutation?.transactionTime || null,
    createdAt: tx.createdAt,
    note: tx.note,
    issuerName: tx.issuerName || fallbackMutation?.issuerName || null,
    rrn: tx.rrn || fallbackMutation?.rrn || null,
    receiptUrl: tx.receiptUrl,
    qrImageBase64: tx.qrImageBase64,
    userIdExt: tx.userIdExt,
    externalReference: tx.externalReference,
    metadataJson: tx.metadataJson,
    siteName: tx.siteName || null,
  };
})) %>;

const isDev = <%= isDev ? 'true' : 'false' %>;
const basePath = <%- JSON.stringify(basePath) %>;
const fmt = (value) => 'Rp ' + Number(value || 0).toLocaleString('id-ID');
const dateFmt = (value) => {
  if (!value) return '-';
  const date = new Date(value);
  const dd = String(date.getDate()).padStart(2, '0');
  const mm = String(date.getMonth() + 1).padStart(2, '0');
  const yyyy = String(date.getFullYear());
  const hh = String(date.getHours()).padStart(2, '0');
  const mi = String(date.getMinutes()).padStart(2, '0');
  const ss = String(date.getSeconds()).padStart(2, '0');
  return `${dd}-${mm}-${yyyy} ${hh}:${mi}:${ss}`;
};
const timeFmt = (value) => {
  if (!value) return '-';
  const date = new Date(value);
  const hh = String(date.getHours()).padStart(2, '0');
  const mi = String(date.getMinutes()).padStart(2, '0');
  const ss = String(date.getSeconds()).padStart(2, '0');
  return `${hh}:${mi}:${ss}`;
};
// Warna amount ikut status (mode semua-status / History): paid=hijau, expired=merah, unpaid=teks tema (putih dark / hitam light).
const amountColorFor = (row) => {
  const s = row.statusPay;
  if (s === 'paid') return '#4ade80';
  const expired = s === 'expired' || (s === 'open' && row.expiresAt && new Date(row.expiresAt).getTime() < Date.now());
  if (expired) return '#f87171';
  return 'var(--ink)';
};
// Tanggal 2 baris: tanggal di atas, jam di bawah.
const dateFmt2 = (value) => {
  const full = dateFmt(value);
  if (full === '-') return '<span class="tx-cell-created">-</span>';
  const parts = full.split(' ');
  return `<div class="tx-cell-created2"><span class="d2-date">${parts[0] || ''}</span><span class="d2-time">${parts[1] || ''}</span></div>`;
};
const apiUrl = (pathname) => `${basePath}${pathname}`;
const merchantSyncUrl = (accountId) => apiUrl(`/merchant-qr/${encodeURIComponent(accountId)}/sync-now`);
const transactionSnapshotUrl = apiUrl('/dashboard/api/transactions/snapshot');
const latestTxUrl = apiUrl('/dashboard/api/transactions/latest');
// Injeksi baris baru hanya aman saat TANPA filter menyempit (status/akun/klien/keyword/nominal/tanggal).
const TX_HAS_FILTER = <%= ((typeof paidOnly !== 'undefined' && paidOnly) || query.statusPay || query.statusBot || query.accountCode || query.clientId || query.site || query.keyword || query.nominal || query.from || query.to) ? 'true' : 'false' %>;

const payBadge = {
  open: 'qris-pill qris-pill-open',
  paid: 'qris-pill qris-pill-paid',
  expired: 'qris-pill qris-pill-expired',
};

const botBadge = {
  pending: 'qris-pill qris-pill-muted',
  deposit_queued: 'qris-pill qris-pill-warn',
  deposit_success: 'qris-pill qris-pill-paid',
  deposit_failed: 'qris-pill qris-pill-danger',
  manual_review: 'qris-pill qris-pill-review',
};

const statusLabelMap = {
  open: 'UNPAID',
  paid: 'PAID',
  expired: 'EXPIRED',
};

function parseMetadata(metadataJson) {
  try {
    return metadataJson ? JSON.parse(metadataJson) : {};
  } catch {
    return {};
  }
}

function resolveSiteLabel(row) {
  if (row.siteName) return row.siteName;
  const metadata = parseMetadata(row.metadataJson);
  const s = metadata.site;
  return (s && s !== '-') ? s : '—';
}

function renderExpiryCountdown(expiresAt, statusPay, qrId) {
  if (statusPay !== 'open') {
    return `<div style="font-size:10px;color:var(--muted);margin-top:2px">${statusLabelMap[statusPay] || statusPay}</div>`;
  }
  return `<div style="font-size:10px;color:var(--muted);margin-top:2px"><span class="tx-exp-countdown" data-exp="${expiresAt}" data-qrid="${qrId}">12:00</span></div>`;
}

function refreshExpiryCountdowns() {
  document.querySelectorAll('.tx-exp-countdown').forEach((node) => {
    const expiresAt = new Date(node.dataset.exp).getTime();
    const qrId = node.dataset.qrid;
    const remaining = Math.max(0, Math.floor((expiresAt - Date.now()) / 1000));
    const minutes = Math.floor(remaining / 60);
    const seconds = remaining % 60;
    if (remaining > 0) {
      node.textContent = `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
      return;
    }
    node.textContent = 'EXPIRED';
    const row = tableData.find((item) => item.qrId === qrId);
    if (row && row.statusPay === 'open') {
      row.statusPay = 'expired';
      txTable.updateData([{ qrId, statusPay: 'expired' }]).catch(() => {});
    }
  });
}

<% var _po = (typeof paidOnly !== 'undefined' && paidOnly); %>
const txTable = new Tabulator('#transactions-table', {
  data: tableData,
  layout: 'fitDataStretch',
  pagination: true,
  paginationSize: 50,
  height: '660px',
  initialSort: [{ column: 'createdAt', dir: 'desc' }],
  renderComplete: refreshExpiryCountdowns,
  columnDefaults: {
    vertAlign: 'middle',
    hozAlign: 'center',
    headerHozAlign: 'center',
    resizable: true,
  },
  columns: [
    { title: '#', formatter: 'rownum', hozAlign: 'center', width: 46, headerSort: false, resizable: false },
    {
      title: 'Site',
      field: 'panelCode',
      width: 92,
      formatter: (cell) => `<span class="tx-cell-site">${resolveSiteLabel(cell.getData())}</span>`,
    },
    {
      title: 'User',
      field: 'userIdExt',
      minWidth: 96,
      width: 118,
      formatter: (cell) => `<span class="tx-cell-user">${cell.getValue() || '-'}</span>`,
    },
    {
      title: 'Akun QRIS',
      field: 'accountCode',
      minWidth: 126,
      width: 150,
      formatter: (cell) => {
        const row = cell.getData();
        return `<div class="tx-cell-stack"><span class="tx-cell-account">${cell.getValue()}</span><span class="tx-cell-merchant">${row.merchantName}</span></div>`;
      },
    },
    <% if (_po) { %>
    {
      title: 'PAID',
      field: 'paidAt',
      minWidth: 152,
      width: 168,
      formatter: (cell) => `<span class="tx-cell-created" style="color:#86efac;font-weight:800">${cell.getValue() ? dateFmt(cell.getValue()) : '-'}</span>`,
    },
    <% } else { %>
    {
      title: 'Dibuat',
      field: 'createdAt',
      minWidth: 132,
      width: 140,
      formatter: (cell) => dateFmt2(cell.getValue()),
    },
    {
      title: 'Expires',
      field: 'expiresAt',
      minWidth: 102,
      width: 112,
      formatter: (cell) => {
        const row = cell.getData();
        return `<div class="tx-cell-stack"><div class="tx-cell-expires">${timeFmt(cell.getValue())}</div>${renderExpiryCountdown(cell.getValue(), row.statusPay, row.qrId)}</div>`;
      },
    },
    <% } %>
    {
      title: 'Amount',
      field: 'finalAmount',
      minWidth: 110,
      width: 134,
      formatter: (cell) => {
        const row = cell.getData();
        <% if (!_po) { %>
        const _amtStyle = ` style="color:${amountColorFor(row)}"`;
        <% } else { %>
        const _amtStyle = '';
        <% } %>
        const _meta = parseMetadata(row.metadataJson);
        const _base = Number(_meta.roundedBase);
        const _reqTxt = (_base && _base !== row.requestedAmount)
          ? `Req ${fmt(row.requestedAmount)} <span style="color:#fbbf24;font-weight:800">&rarr; ${fmt(_base)}</span>`
          : `Req ${fmt(row.requestedAmount)}`;
        return `<div class="tx-cell-stack"><div class="tx-cell-amount"${_amtStyle}>${fmt(cell.getValue())}</div><div class="tx-cell-amount-sub">${_reqTxt}</div></div>`;
      },
    },
    {
      title: 'Ref / RRN',
      field: 'rrn',
      minWidth: 122,
      width: 134,
      formatter: (cell) => `<span class="tx-cell-rrn">${cell.getValue() || '-'}</span>`,
    },
    {
      title: 'Note / Issuer',
      field: 'note',
      minWidth: 170,
      width: 190,
      formatter: (cell) => {
        const row = cell.getData();
        return `<div class="tx-cell-stack"><div class="tx-cell-note">${cell.getValue() || '-'}</div><div class="tx-cell-issuer">${row.issuerName || '-'}</div></div>`;
      },
    },
    <% if (!_po) { %>
    {
      title: 'Status',
      field: 'statusPay',
      width: 88,
      formatter: (cell) => {
        const val = cell.getValue();
        const label = statusLabelMap[val] || String(val || '-').toUpperCase();
        const pill = `<span class="${payBadge[val] || 'qris-pill qris-pill-muted'}">${label}</span>`;
        if (val === 'paid') {
          const row = cell.getData();
          const t = row.paidAt ? timeFmt(row.paidAt).replace(/:/g, '.') : '';
          if (t) {
            return `<div class="tx-cell-stack" style="align-items:center;gap:2px">${pill}<div style="font-size:10px;font-weight:800;color:#86efac;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace">${t}</div></div>`;
          }
        }
        return pill;
      },
    },
    {
      title: 'Bot',
      field: 'statusBot',
      width: 64,
      formatter: () => `<span class="qris-pill qris-pill-muted">-</span>`,
    },
    <% } %>
    <% if (_po) { %>
    {
      title: 'RECEIPT',
      field: 'qrId',
      width: 150,
      headerSort: false,
      resizable: false,
      formatter: (cell) => {
        const row = cell.getData();
        return `<div class="tx-actions-wrap"><button type="button" onclick="downloadReceipt('${row.qrId}')" class="tx-act-btn tx-act-receipt"><i class="fa-solid fa-receipt" style="font-size:11px"></i> Receipt</button></div>`;
      },
    },
    <% } else { %>
    {
      title: 'Aksi',
      field: 'qrId',
      width: isDev ? 180 : 140,
      headerSort: false,
      resizable: false,
      formatter: (cell) => {
        const row = cell.getData();
        const buttons = [
          `<button type="button" onclick="showQr('${row.qrId}')" class="tx-act-btn">QR</button>`,
          `<button type="button" onclick="showStatus('${row.qrId}')" class="tx-act-btn tx-act-blue">Check</button>`,
        ];
        if (row.statusPay === 'paid' && ['deposit_failed', 'manual_review'].includes(row.statusBot)) {
          buttons.push(`<button type="button" onclick="retryDeposit('${row.qrId}', this)" class="tx-act-btn tx-act-accent">Retry</button>`);
        }
        if (isDev && row.statusPay === 'open') {
          buttons.push(`<button type="button" onclick="simulatePay('${row.qrId}', this)" class="tx-act-btn tx-act-green">Sim</button>`);
        }
        return `<div class="tx-actions-wrap">${buttons.join('')}</div>`;
