  ],
});

refreshExpiryCountdowns();
setInterval(refreshExpiryCountdowns, 1000);

// ── RECEIPT (struk) premium — dipakai menu Transaction (paid) ──────────────────
function _fmtPaidDate(v){ if(!v) return '-'; const d=new Date(v); if(isNaN(d.getTime())) return '-'; const p=n=>String(n).padStart(2,'0'); return `${p(d.getDate())}-${p(d.getMonth()+1)}-${d.getFullYear()} ${p(d.getHours())}:${p(d.getMinutes())}:${p(d.getSeconds())}`; }
window.downloadReceipt = function(qrId){
  const row = tableData.find(r => r.qrId === qrId);
  if(!row){ alert('Data transaksi tidak ditemukan.'); return; }
  if(!confirm('Download receipt (struk pembayaran) untuk transaksi ini?')) return;
  const details = [
    ['Tanggal Bayar', _fmtPaidDate(row.paidAt)],
    ['No. Referensi', row.rrn || '-'],
    ['ID Transaksi', row.qrId || '-'],
    ['Akun QRIS', (row.accountCode || '-') + (row.merchantName ? (' · ' + row.merchantName) : '')],
    ['Site', row.siteName || '-'],
    ['Pelanggan', row.userIdExt || '-'],
  ];
  if(row.issuerName) details.push(['Bank / Issuer', row.issuerName]);
  const W = 468, pad = 30, rowH = 30, topH = 158, amtH = 104, footH = 74;
  const H = topH + amtH + (details.length * rowH) + 30 + footH;
  const scale = 2;
  const cv = document.createElement('canvas'); cv.width = W*scale; cv.height = H*scale;
  const ctx = cv.getContext('2d'); ctx.scale(scale, scale);
  ctx.fillStyle = '#f8fafc'; ctx.fillRect(0,0,W,H);
  ctx.fillStyle = '#ffffff'; ctx.fillRect(0, topH, W, H - topH);
  const g = ctx.createLinearGradient(0,0,W,topH); g.addColorStop(0,'#15803d'); g.addColorStop(1,'#22c55e');
  ctx.fillStyle = g; ctx.fillRect(0,0,W,topH);
  ctx.beginPath(); ctx.arc(W/2, 54, 30, 0, Math.PI*2); ctx.fillStyle = 'rgba(255,255,255,0.22)'; ctx.fill();
  ctx.beginPath(); ctx.arc(W/2, 54, 22, 0, Math.PI*2); ctx.fillStyle = '#ffffff'; ctx.fill();
  ctx.strokeStyle = '#16a34a'; ctx.lineWidth = 4; ctx.lineCap='round'; ctx.lineJoin='round';
  ctx.beginPath(); ctx.moveTo(W/2-10, 54); ctx.lineTo(W/2-2, 62); ctx.lineTo(W/2+11, 46); ctx.stroke();
  ctx.textAlign='center';
  ctx.fillStyle='#ffffff'; ctx.font='800 19px Arial,sans-serif'; ctx.fillText('PEMBAYARAN BERHASIL', W/2, 104);
  ctx.fillStyle='rgba(255,255,255,0.92)'; ctx.font='600 13px Arial,sans-serif';
  ctx.fillText(String(row.siteName || row.merchantName || '-'), W/2, 128);
  let y = topH + 40;
  ctx.fillStyle='#64748b'; ctx.font='700 11px Arial,sans-serif'; ctx.fillText('TOTAL DIBAYAR', W/2, y - 14);
  ctx.fillStyle='#0f172a'; ctx.font='800 32px Arial,sans-serif';
  ctx.fillText('Rp ' + Number(row.finalAmount||0).toLocaleString('id-ID'), W/2, y + 18);
  y = topH + amtH;
  ctx.strokeStyle='#e2e8f0'; ctx.lineWidth=1.5; ctx.setLineDash([5,5]);
  ctx.beginPath(); ctx.moveTo(pad, y); ctx.lineTo(W-pad, y); ctx.stroke(); ctx.setLineDash([]);
  y += 28;
  details.forEach(function(d){
    ctx.textAlign='left'; ctx.fillStyle='#64748b'; ctx.font='600 12px Arial,sans-serif';
    ctx.fillText(d[0], pad, y);
    ctx.textAlign='right'; ctx.fillStyle='#0f172a'; ctx.font='700 12px "Courier New",monospace';
    let val = String(d[1]); const maxW = W - pad*2 - 130;
    while(ctx.measureText(val).width > maxW && val.length > 6){ val = val.slice(0, -2); }
    if(val !== String(d[1])) val += '…';
    ctx.fillText(val, W-pad, y);
    y += rowH;
  });
  y += 4;
  ctx.strokeStyle='#e2e8f0'; ctx.setLineDash([5,5]);
  ctx.beginPath(); ctx.moveTo(pad, y); ctx.lineTo(W-pad, y); ctx.stroke(); ctx.setLineDash([]);
  y += 26;
  ctx.textAlign='center'; ctx.fillStyle='#16a34a'; ctx.font='800 12.5px Arial,sans-serif';
  ctx.fillText('✓ LUNAS · Struk Pembayaran Sah', W/2, y);
  y += 18;
  ctx.fillStyle='#94a3b8'; ctx.font='500 10px Arial,sans-serif';
  ctx.fillText('qris-orkut · dicetak ' + _fmtPaidDate(new Date().toISOString()), W/2, y);
  const link = document.createElement('a');
  const safeSite = String(row.siteName || row.accountCode || 'TX').replace(/[^a-zA-Z0-9]+/g,'_');
  link.download = 'Receipt_' + safeSite + '_' + String(row.qrId||'').slice(0,8) + '.png';
  link.href = cv.toDataURL('image/png'); link.click();
};

const syncStateByAccount = new Map();
let transactionRealtimeTimer = null;
let snapshotInFlight = false;

function getOpenRows() {
  return tableData.filter((row) => row.statusPay === 'open');
}

function updateRealtimeStats() {
  const openCount = tableData.filter((row) => row.statusPay === 'open').length;
  const paidCount = tableData.filter((row) => row.statusPay === 'paid').length;
  const expiredCount = tableData.filter((row) => row.statusPay === 'expired').length;
  const reviewCount = tableData.filter((row) => row.statusBot === 'manual_review').length;

  const statValues = document.querySelectorAll('.tx-stat-value');
  if (statValues[1]) statValues[1].textContent = String(openCount);
  if (statValues[2]) statValues[2].textContent = String(paidCount);
  if (statValues[3]) statValues[3].textContent = String(reviewCount);
  return { openCount, paidCount, expiredCount };
}

async function syncMerchantForRealtime(accountId) {
  if (!accountId || document.hidden) return;
  if (syncStateByAccount.get(accountId)) return;

  syncStateByAccount.set(accountId, true);
  try {
    await fetch(merchantSyncUrl(accountId), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
    });
  } catch (_) {
  } finally {
    syncStateByAccount.set(accountId, false);
  }
}

async function refreshTransactionSnapshot() {
  if (snapshotInFlight || document.hidden) return;
  const openRows = getOpenRows();
  if (!openRows.length) return;

  snapshotInFlight = true;
  try {
    const response = await fetch(transactionSnapshotUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ qrIds: openRows.map((row) => row.qrId) }),
    });
    const json = await response.json().catch(() => ({ ok: false }));
    if (!json?.ok || !Array.isArray(json.transactions) || !json.transactions.length) return;

    const changedRows = [];
    for (const row of json.transactions) {
      const target = tableData.find((item) => item.qrId === row.qrId);
      if (!target) continue;

      const nextStatusPay = row.statusPay || target.statusPay;
      const nextStatusBot = row.statusBot || target.statusBot;
      const nextRrn = row.rrn || target.rrn || null;
      const nextIssuer = row.issuerName || target.issuerName || null;
      const nextPaidAt = row.paidAt || target.paidAt || null;

      const changed =
        target.statusPay !== nextStatusPay ||
        target.statusBot !== nextStatusBot ||
        (target.rrn || null) !== nextRrn ||
        (target.issuerName || null) !== nextIssuer ||
        String(target.paidAt || '') !== String(nextPaidAt || '');

      if (!changed) continue;

      target.statusPay = nextStatusPay;
      target.statusBot = nextStatusBot;
      target.rrn = nextRrn;
      target.issuerName = nextIssuer;
      target.paidAt = nextPaidAt;

      changedRows.push({
        qrId: target.qrId,
        statusPay: target.statusPay,
        statusBot: target.statusBot,
        rrn: target.rrn,
        issuerName: target.issuerName,
        paidAt: target.paidAt,
      });
    }

    if (changedRows.length) {
      await txTable.updateData(changedRows).catch(() => {});
      txTable.redraw(true);
      updateRealtimeStats();
    }
  } catch (_) {
  } finally {
    snapshotInFlight = false;
  }
}

async function runRealtimeSyncTick() {
  if (document.hidden) return;
  // Deteksi bayar diandalkan ke WORKER (System B). Halaman cukup BACA DB LOKAL -> tanpa OrderKuota, nol 469.
  await refreshTransactionSnapshot();   // update status baris open yang sudah ada
  await injectNewTransactions();        // suntik QR/transaksi BARU secara live
}

// Live "baris baru": ambil transaksi terbaru dari DB LOKAL, prepend yang belum ada di tabel.
let injectInFlight = false;
function canInjectNewRows() {
  if (TX_HAS_FILTER) return false; // sedang difilter -> jangan suntik (bisa langgar filter)
  try { if (txTable && typeof txTable.getPage === 'function' && txTable.getPage() !== 1) return false; } catch (_) {}
  // hanya kalau user memang di tampilan TERKINI (baris teratas < 1 jam); kalau lihat riwayat lama -> jangan suntik
  if (tableData.length) {
    let newest = 0;
    for (const r of tableData) { const t = new Date(r.createdAt).getTime() || 0; if (t > newest) newest = t; }
    if (newest && Date.now() - newest > 3600000) return false;
  }
  return true;
}
async function injectNewTransactions() {
  if (injectInFlight || document.hidden || !canInjectNewRows()) return;
  injectInFlight = true;
  try {
    const res = await fetch(latestTxUrl, { headers: { 'Accept': 'application/json' } });
    const json = await res.json().catch(() => ({ ok: false }));
    if (!json || !json.ok || !Array.isArray(json.transactions) || !json.transactions.length) return;
    const known = new Set(tableData.map((r) => r.qrId));
    const fresh = json.transactions.filter((r) => r.qrId && !known.has(r.qrId));
    if (!fresh.length) return;
    fresh.sort((a, b) => (new Date(a.createdAt).getTime() || 0) - (new Date(b.createdAt).getTime() || 0));
    for (const r of fresh) tableData.unshift(r);
    await txTable.addData(fresh, true).catch(() => {}); // true = tambah di ATAS
    txTable.redraw(true);
    refreshExpiryCountdowns();
    updateRealtimeStats();
    flashNewRows(fresh.map((r) => r.qrId));
  } catch (_) {
  } finally {
    injectInFlight = false;
  }
}
function flashNewRows(qrIds) {
  try {
    for (const qrId of qrIds) {
      const row = txTable.getRow(qrId);
      if (row && row.getElement) { const el = row.getElement(); el.style.transition = 'background .8s'; el.style.background = 'rgba(52,211,153,0.28)'; setTimeout(function(){ el.style.background = ''; }, 1600); }
    }
  } catch (_) {}
}

transactionRealtimeTimer = setInterval(() => {
  void runRealtimeSyncTick();
}, 2500);

void runRealtimeSyncTick();

document.addEventListener('visibilitychange', function () {
  if (!document.hidden) {
    void runRealtimeSyncTick();
  }
});

window.addEventListener('beforeunload', function () {
  if (transactionRealtimeTimer) clearInterval(transactionRealtimeTimer);
});

function exportTransactions() {
  const table = Tabulator.findTable('#transactions-table')[0];
  table?.download('csv', `transaksi-qr-${Date.now()}.csv`);
}

function showQr(qrId) {
  const data = tableData.find((item) => item.qrId === qrId);
  if (!data) return;
  document.getElementById('tx-qr-img').src = data.qrImageBase64 || '';
  document.getElementById('tx-qr-note').textContent = data.note || '';
  document.getElementById('tx-qr-amount').textContent = fmt(data.finalAmount);
  document.getElementById('tx-qr-expiry').textContent = `Expires: ${dateFmt(data.expiresAt)}`;
  document.getElementById('tx-qr-modal').classList.remove('hidden');
}

function closeQrModal() {
  document.getElementById('tx-qr-modal').classList.add('hidden');
}

function openStatusModalLoading(qrId) {
  const modal = document.getElementById('tx-status-modal');
  const content = document.getElementById('tx-status-content');
  content.innerHTML = `
    <div class="qris-status-loading">
      <div class="qris-status-loading-icon"><i class="fa-solid fa-spinner fa-spin"></i></div>
      <div>
        <p class="qris-status-loading-title">Mengambil status transaksi</p>
        <p class="qris-status-loading-sub">QR ID: ${qrId}</p>
      </div>
    </div>
  `;
  modal.classList.remove('hidden');
}

function renderStatusModal(data, remoteError) {
  const rows = [
    ['QR ID', data.qrId || '-'],
    ['User ID', data.userIdExt || '-'],
    ['Status Bayar', `<span class="${payBadge[data.statusPay] || 'qris-pill qris-pill-muted'}">${statusLabelMap[data.statusPay] || data.statusPay || '-'}</span>`],
    ['BOT', '<span class="qris-pill qris-pill-muted">-</span>'],
    ['Nominal', fmt(data.finalAmount || data.requestedAmount || 0)],
    ['Dibuat', dateFmt(data.createdAt)],
    ['Expire', dateFmt(data.expiresAt)],
    ['Dibayar', data.paidAt ? dateFmt(data.paidAt) : '-'],
    ['Issuer', data.issuerName || '-'],
    ['RRN', data.rrn || '-'],
    ['Receipt', data.receiptUrl ? `<a href="${data.receiptUrl}" target="_blank" class="text-[#ff7f6f] underline">Lihat</a>` : '-'],
    ['Note', data.note || '-'],
  ];

  const errorBox = remoteError
    ? `<div class="qris-status-alert">Status live belum bisa dibaca. Detail: ${remoteError}</div>`
    : '';

  const hero = `
    <div class="qris-status-hero">
      <div>
        <p class="qris-status-hero-label">Status</p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <span class="${payBadge[data.statusPay] || 'qris-pill qris-pill-muted'}">${statusLabelMap[data.statusPay] || data.statusPay || '-'}</span>
          <span class="qris-pill qris-pill-muted">-</span>
        </div>
      </div>
      <div class="text-right">
        <p class="qris-status-hero-label">Nominal</p>
        <p class="qris-status-hero-amount">${fmt(data.finalAmount || data.requestedAmount || 0)}</p>
      </div>
    </div>
  `;

  const detailGrid = `<div class="qris-status-grid">${rows.map(([label, value]) => `
    <div class="qris-status-item">
      <span class="qris-status-item-label">${label}</span>
      <span class="qris-status-item-value">${value}</span>
    </div>
  `).join('')}</div>`;

  document.getElementById('tx-status-content').innerHTML = `${errorBox}${hero}${detailGrid}`;
}

async function showStatus(qrId) {
  const fallback = tableData.find((item) => item.qrId === qrId);
  if (!fallback) return;
  openStatusModalLoading(qrId);

  let remoteData = null;
  let remoteError = '';

  try {
    const response = await fetch(apiUrl(`/api/v1/qris/${qrId}/status`), { headers: { 'Accept': 'application/json' } });
    const json = await response.json().catch(() => ({ success: false, error: 'Respons tidak valid' }));
    if (json && json.success) {
      remoteData = json.data || null;
    } else if (json && json.error) {
      remoteError = json.error;
    }
  } catch (error) {
    remoteError = error instanceof Error ? error.message : 'Gagal mengambil status';
  }

  const data = { ...fallback, ...(remoteData || {}) };
  renderStatusModal(data, remoteError);
}

function closeStatusModal() {
  document.getElementById('tx-status-modal').classList.add('hidden');
}

async function retryDeposit(qrId, button) {
  if (!confirm('Retry auto deposit untuk transaksi ini?')) return;
  button.disabled = true;
  button.textContent = 'Processing...';

  const response = await fetch(apiUrl(`/api/v1/qris/${qrId}/retry-deposit`), { method: 'POST' });
  const json = await response.json().catch(() => ({ success: false, error: 'Unknown error' }));

  if (json.success) {
    alert('Deposit dijadwalkan ulang.');
    window.location.reload();
    return;
  }

  alert(`Gagal: ${json.error}`);
  button.disabled = false;
  button.textContent = 'Retry';
}

async function simulatePay(qrId, button) {
  if (!confirm('Simulasikan pembayaran untuk QR ini?')) return;
  button.disabled = true;
  button.textContent = 'Processing...';

  const response = await fetch(apiUrl('/dev/simulate-payment'), {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ qrId }),
  });
  const json = await response.json().catch(() => ({ success: false, error: 'Unknown error' }));

  if (json.success) {
    alert('Mutasi simulasi dibuat.');
    setTimeout(() => window.location.reload(), 1800);
    return;
  }

  alert(`Gagal: ${json.error}`);
  button.disabled = false;
  button.textContent = 'Sim';
}

async function checkStatusAll() {
  const openRows = tableData.filter((row) => row.statusPay === 'open').slice(0, 20);
  if (!openRows.length) {
    alert('Tidak ada transaksi open yang perlu dicek.');
    return;
  }

  await Promise.allSettled(openRows.map((row) => fetch(apiUrl(`/api/v1/qris/${row.qrId}/status`))));
  window.location.reload();
}


</script>
<% } %>

<script>
(function () {
  const basePath = <%- JSON.stringify(basePath) %>;
  const apiUrl = (pathname) => `${basePath}${pathname}`;
// -- Sinkron ALL + Sinkron 1 akun: pola resmi Merchant QR, bulk job di server + polling status --
(function initTxSync(){
  if (window.__TxSyncReady) return;
  window.__TxSyncReady = true;
  const btnAll = document.getElementById('btnSyncAllTx');
  const lblAll = document.getElementById('btnSyncAllTxLabel');
  const sel = document.getElementById('syncOneSelTx');
  const btnOne = document.getElementById('btnSyncOneTx');
  const lblOne = document.getElementById('btnSyncOneTxLabel');
  if (!btnAll && !btnOne) return;
  const ALL_URL = apiUrl('/merchant-qr/sync-all');
  const STATUS_URL = apiUrl('/merchant-qr/sync-all/status');
  const oneUrl = function(id){ return apiUrl('/merchant-qr/' + encodeURIComponent(id) + '/sync-now'); };
  let pollTimer = null;
  let sawRunning = false;
  function toast(msg, ok){
    let box = document.getElementById('syncToastBox');
    if (!box){ box = document.createElement('div'); box.id = 'syncToastBox'; box.style.cssText = 'position:fixed;right:18px;bottom:18px;z-index:99999;display:flex;flex-direction:column;gap:8px'; document.body.appendChild(box); }
    const t = document.createElement('div');
    t.style.cssText = 'background:' + (ok ? 'rgba(16,185,129,0.96)' : 'rgba(239,68,68,0.96)') + ';color:#fff;padding:11px 16px;border-radius:12px;font-size:13px;font-weight:700;box-shadow:0 10px 28px rgba(0,0,0,.4);max-width:360px;opacity:0;transform:translateY(8px);transition:all .25s';
    t.textContent = msg; box.appendChild(t);
    requestAnimationFrame(function(){ t.style.opacity = '1'; t.style.transform = 'translateY(0)'; });
    setTimeout(function(){ t.style.opacity = '0'; t.style.transform = 'translateY(8px)'; setTimeout(function(){ t.remove(); }, 300); }, 4200);
  }
  function setButton(btn, lbl, disabled, text){
    if (!btn) return;
    btn.disabled = disabled;
    btn.style.opacity = disabled ? '.55' : '1';
    btn.style.cursor = disabled ? 'not-allowed' : 'pointer';
    if (lbl) lbl.textContent = text;
  }
  async function loadAccounts(){
    if (!sel) return;
    try {
      const list = await (fetch(apiUrl('/dashboard/api/qris-accounts'), { cache: 'no-store' }).then(function(r){ return r.json(); }).then(function(d){ return d.accounts || []; }));
      const cur = sel.value;
      sel.innerHTML = '<option value="">Pilih Akun...</option>' + (list || []).filter(function(a){ return a && a.id; }).map(function(a){
        const label = a.merchantName || a.code || a.label || a.id;
        return '<option value="' + a.id + '">' + label + '</option>';
      }).join('');
      if (cur) sel.value = cur;
      setButton(btnOne, lblOne, !sel.value, 'Sinkron');
    } catch (_) { setButton(btnOne, lblOne, true, 'Sinkron'); }
  }
  async function pollStatus(reloadOnDone){
    try {
      const res = await fetch(STATUS_URL, { cache: 'no-store', headers: { 'Accept': 'application/json' } });
      const data = await res.json().catch(function(){ return {}; });
      if (!res.ok || data.ok === false) return;
      if (data.running) {
        sawRunning = true;
        setButton(btnAll, lblAll, true, 'Sinkron ' + (data.done || 0) + '/' + (data.total || 0));
        setButton(btnOne, lblOne, true, 'Menyinkron...');
        return;
      }
      if (sawRunning) {
        sawRunning = false;
        if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
        setButton(btnAll, lblAll, false, 'Sinkron ALL');
        setButton(btnOne, lblOne, !(sel && sel.value), 'Sinkron');
        toast('Sinkron ALL selesai. Berhasil ' + (data.ok || 0) + ', gagal ' + (data.failed || 0) + ' dari ' + (data.total || 0) + '.', true);
        if (reloadOnDone !== false) setTimeout(function(){ window.location.reload(); }, 1400);
        return;
      }
      const rem = Math.max(0, Number(data.remainingMs) || 0);
      if (rem > 0) setButton(btnAll, lblAll, true, 'Tunggu ' + Math.ceil(rem / 1000) + 's');
      else setButton(btnAll, lblAll, false, 'Sinkron ALL');
      setButton(btnOne, lblOne, !(sel && sel.value), 'Sinkron');
    } catch (_) {}
  }
  function startPolling(){
    if (pollTimer) clearInterval(pollTimer);
    pollTimer = setInterval(function(){ pollStatus(true); }, 2000);
    pollStatus(true);
  }
  async function clickAll(){
    if (btnAll && btnAll.disabled) return;
    sawRunning = true;
    setButton(btnAll, lblAll, true, 'Memulai...');
    setButton(btnOne, lblOne, true, 'Menyinkron...');
    try {
      const res = await fetch(ALL_URL, { method: 'POST', headers: { 'Accept': 'application/json' } });
      const data = await res.json().catch(function(){ return {}; });
      if (res.status === 429 && data.blocked === 'cooldown') {
        sawRunning = false;
        const wait = Math.ceil((Number(data.remainingMs) || 60000) / 1000);
        toast(data.error || ('Sinkron ALL cooldown. Tunggu ' + wait + 's.'), false);
        setButton(btnAll, lblAll, true, 'Tunggu ' + wait + 's');
        setButton(btnOne, lblOne, !(sel && sel.value), 'Sinkron');
        setTimeout(function(){ pollStatus(false); }, Number(data.remainingMs) || 60000);
        return;
      }
      if (!res.ok && data.blocked !== 'running') throw new Error(data.error || ('HTTP ' + res.status));
      startPolling();
    } catch (err) {
      sawRunning = false;
      toast('Sinkron ALL gagal: ' + (err && err.message ? err.message : 'Kesalahan jaringan.'), false);
      setButton(btnAll, lblAll, false, 'Sinkron ALL');
      setButton(btnOne, lblOne, !(sel && sel.value), 'Sinkron');
    }
  }
  async function clickOne(){
    const id = sel ? sel.value : '';
    if (!id) { toast('Pilih akun QRIS dulu.', false); return; }
    setButton(btnOne, lblOne, true, 'Sinkron...');
    try {
      const res = await fetch(oneUrl(id), { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' } });
      const data = await res.json().catch(function(){ return {}; });
      if (!res.ok || data.success === false || (data.report && data.report.success === false)) throw new Error(data.error || (data.report && data.report.message) || ('HTTP ' + res.status));
      toast('Sinkron akun berhasil. Halaman akan dimuat ulang.', true);
      setTimeout(function(){ window.location.reload(); }, 1000);
    } catch (err) {
      toast('Sinkron akun gagal: ' + (err && err.message ? err.message : 'Kesalahan jaringan.'), false);
      setButton(btnOne, lblOne, false, 'Sinkron');
    }
  }
  if (btnAll) btnAll.addEventListener('click', clickAll);
  if (btnOne) btnOne.addEventListener('click', clickOne);
  if (sel) sel.addEventListener('change', function(){ setButton(btnOne, lblOne, !sel.value, 'Sinkron'); });
  loadAccounts();
  pollStatus(false);
})();
})();
</script>
