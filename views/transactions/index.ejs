<%
  const totalRecordsText = total.toLocaleString('id-ID');
  const totalPaidText = totalPaid.toLocaleString('id-ID');
  const totalFeeText = totalFee.toLocaleString('id-ID');
  const currentPeriod = query.period || 'all';
%>

<style>
  /* ── Toolbar ───────────────────────────────────── */
  .tx-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
    background: linear-gradient(135deg, rgba(59,130,246,0.04), rgba(16,185,129,0.03));
  }
  .tx-toolbar-sep {
    width: 1px; height: 28px; background: var(--line); flex-shrink: 0;
  }
  .tx-record-info {
    margin-left: auto;
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
  }
  .tx-record-info b { color: var(--ink); }

  /* ── Filter bar (horizontal) ───────────────────── */
  .tx-filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    gap: 10px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
  }
  .tx-filter-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .tx-filter-group.grow { flex: 1; min-width: 140px; }
  .tx-filter-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .tx-filter-input {
    height: 34px;
    padding: 0 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    color: var(--ink);
    font-size: 12px;
    outline: none;
    transition: border-color .2s;
  }
  .tx-filter-input:focus { border-color: rgba(99,130,255,0.5); }
  .tx-filter-input::placeholder { color: var(--muted); }
  select.tx-filter-input { cursor: pointer; }
  .tx-filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    gap: 10px;
  }

  /* ── Period pills ──────────────────────────────── */
  .tx-period-pills {
    display: flex;
    gap: 4px;
  }
  .tx-period-pill {
    padding: 6px 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: transparent;
    color: var(--muted);
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: all .18s;
    white-space: nowrap;
  }
  .tx-period-pill:hover { border-color: rgba(99,130,255,0.35); color: var(--ink); }
  .tx-period-pill.active {
    background: rgba(99,130,255,0.12);
    border-color: rgba(99,130,255,0.40);
    color: #93b4ff;
  }

  /* ── Mini stats row ────────────────────────────── */
  .tx-stats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 12px 20px;
    border-bottom: 1px solid var(--line);
  }
  .tx-stat {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--panel);
    min-width: 0;
    flex: 1;
    transition: border-color .2s;
  }
  .tx-stat:hover { border-color: rgba(99,130,255,0.25); }
  .tx-stat-icon {
    width: 32px; height: 32px;
    display: grid; place-items: center;
    border-radius: 8px;
    font-size: 13px;
    flex-shrink: 0;
  }
  .tx-stat-icon.blue   { background: rgba(59,130,246,0.12); color: #60a5fa; }
  .tx-stat-icon.violet { background: rgba(139,92,246,0.12); color: #a78bfa; }
  .tx-stat-icon.green  { background: rgba(34,197,94,0.12);  color: #4ade80; }
  .tx-stat-icon.amber  { background: rgba(249,115,22,0.12); color: #fb923c; }
  .tx-stat-icon.red    { background: rgba(239,68,68,0.12);  color: #f87171; }
  .tx-stat-body { min-width: 0; }
  .tx-stat-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tx-stat-value {
    font-size: 18px;
    font-weight: 800;
    color: var(--ink);
    line-height: 1.2;
    margin-top: 1px;
  }
  .tx-stat-sub {
    font-size: 10px;
    color: var(--muted);
    margin-top: 2px;
  }

  /* ── Table overrides (dark theme) ────────────────── */
  #transactions-table {
    font-size: 12px;
    border: none !important;
    background: var(--shell) !important;
    color: var(--ink) !important;
  }
  #transactions-table .tabulator-header {
    background:
      linear-gradient(180deg, rgba(20, 25, 35, 0.98), rgba(16, 20, 29, 0.98)) !important;
    border-bottom: 1px solid var(--line) !important;
    border-top: none !important;
    color: var(--muted) !important;
  }
  #transactions-table .tabulator-col {
    background: transparent !important;
    border-right: 1px solid var(--line) !important;
  }
  #transactions-table .tabulator-col:last-child {
    border-right: none !important;
  }
  #transactions-table .tabulator-col-title {
    font-size: 10px !important;
    font-weight: 800 !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    color: #98a5c4 !important;
    text-align: left !important;
    padding: 10px 8px !important;
  }
  #transactions-table .tabulator-col .tabulator-col-content {
    padding: 0 !important;
  }
  #transactions-table .tabulator-col-resize-handle {
    border-color: var(--line) !important;
  }
  #transactions-table .tabulator-tableholder {
    background: var(--shell) !important;
    color: var(--ink) !important;
  }
  #transactions-table .tabulator-row {
    background: var(--shell) !important;
    border-bottom: 1px solid var(--line) !important;
    min-height: 50px !important;
    color: var(--ink) !important;
  }
  #transactions-table .tabulator-row:hover {
    background: linear-gradient(90deg, rgba(36, 44, 62, 0.92), rgba(20, 26, 40, 0.92)) !important;
  }
  #transactions-table .tabulator-row:nth-child(even) {
    background: rgba(19, 24, 34, 0.96) !important;
  }
  #transactions-table .tabulator-row:nth-child(even):hover {
    background: linear-gradient(90deg, rgba(34, 40, 58, 0.96), rgba(20, 26, 40, 0.96)) !important;
  }
  #transactions-table .tabulator-cell {
    border-right: 1px solid rgba(255,255,255,0.03) !important;
    padding: 10px 10px !important;
    vertical-align: middle !important;
    text-align: left !important;
    white-space: normal !important;
    word-break: break-word !important;
    overflow: hidden !important;
    color: var(--ink) !important;
    font-weight: 700 !important;
  }
  #transactions-table .tabulator-cell:last-child {
    border-right: none !important;
  }
  /* ── Perataan kolom biar enak dibaca: teks KIRI, angka KANAN, status/aksi TENGAH ── */
  #transactions-table .tabulator-cell[tabulator-field="finalAmount"],
  #transactions-table .tabulator-col[tabulator-field="finalAmount"] .tabulator-col-title { text-align: right !important; }
  #transactions-table .tabulator-cell[tabulator-field="finalAmount"] .tx-cell-stack { align-items: flex-end !important; }
  #transactions-table .tabulator-cell[tabulator-field="statusPay"],
  #transactions-table .tabulator-cell[tabulator-field="statusBot"],
  #transactions-table .tabulator-cell[tabulator-field="qrId"],
  #transactions-table .tabulator-col[tabulator-field="statusPay"] .tabulator-col-title,
  #transactions-table .tabulator-col[tabulator-field="statusBot"] .tabulator-col-title,
  #transactions-table .tabulator-col[tabulator-field="qrId"] .tabulator-col-title { text-align: center !important; }
  #transactions-table .tabulator-cell[tabulator-field="statusPay"] .tx-cell-stack { align-items: center !important; }
  /* kolom nomor (#) tetap tengah */
  #transactions-table .tabulator-row .tabulator-cell:first-child,
  #transactions-table .tabulator-header .tabulator-col:first-child .tabulator-col-title { text-align: center !important; }
  #transactions-table .tabulator-footer {
    background: var(--panel-2) !important;
    border-top: 1px solid var(--line) !important;
    padding: 8px 12px !important;
    color: var(--muted) !important;
  }
  #transactions-table .tabulator-page {
    border-radius: 8px !important;
    font-size: 11px !important;
    padding: 5px 10px !important;
    border: 1px solid var(--line) !important;
    background: var(--panel) !important;
    color: var(--muted) !important;
    transition: all .18s !important;
  }
  #transactions-table .tabulator-page:hover {
    background: var(--panel-2) !important;
    color: var(--ink) !important;
  }
  #transactions-table .tabulator-page.active {
    background: rgba(99,130,255,0.18) !important;
    border-color: rgba(99,130,255,0.4) !important;
    color: #93b4ff !important;
  }
  #transactions-table .tabulator-pages {
    gap: 4px !important;
  }
  #transactions-table .tabulator-paginator {
    color: var(--muted) !important;
    display: flex !important;
    align-items: center !important;
    gap: 6px !important;
    justify-content: flex-end !important;
  }
  #transactions-table .tabulator-page-counter {
    color: var(--muted) !important;
    font-size: 11px !important;
  }

  /* ── Filter action buttons ──────────────────────── */
  .tx-filter-btn {
    height: 34px;
    padding: 0 16px;
    border: none;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all .18s;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }
  .tx-filter-btn-primary {
    background: rgba(99,130,255,0.18);
    color: #93b4ff;
  }
  .tx-filter-btn-primary:hover { background: rgba(99,130,255,0.28); }
  .tx-filter-btn-ghost {
    background: rgba(255,255,255,0.04);
    color: var(--muted);
  }
  .tx-filter-btn-ghost:hover { background: rgba(255,255,255,0.08); color: var(--ink); }

  /* ── Action buttons in table ────────────────────── */
  .tx-act-btn {
    font-size: 10px;
    font-weight: 600;
    padding: 3px 8px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    background: rgba(255,255,255,0.04);
    color: #c8bdb0;
    cursor: pointer;
    transition: all .18s;
    white-space: nowrap;
  }
  .tx-act-btn:hover { background: rgba(255,255,255,0.08); color: #fff; }
  .tx-act-blue { color: #7bb2ff; border-color: rgba(99,130,255,0.2); }
  .tx-act-blue:hover { background: rgba(99,130,255,0.12); color: #a3c9ff; }
  .tx-act-accent { color: #fb923c; border-color: rgba(249,115,22,0.2); }
  .tx-act-accent:hover { background: rgba(249,115,22,0.12); color: #fdba74; }
  .tx-act-green { color: #4ade80; border-color: rgba(34,197,94,0.2); }
  .tx-act-green:hover { background: rgba(34,197,94,0.12); color: #86efac; }
  .tx-act-receipt { color: #4ade80; border-color: rgba(34,197,94,0.34); background: rgba(34,197,94,0.1); font-weight: 800; display: inline-flex; align-items: center; gap: 5px; }
  .tx-act-receipt:hover { background: rgba(34,197,94,0.2); color: #86efac; }

  .tx-cell-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    line-height: 1.28;
  }
  .tx-cell-main {
    font-size: 11px;
    font-weight: 800;
    color: #f6f8fc;
    letter-spacing: 0.01em;
  }
  .tx-cell-sub {
    font-size: 9px;
    font-weight: 700;
    color: #7f8ba8;
  }
  .tx-cell-site {
    font-size: 11px;
    font-weight: 800;
    color: #fda4af;
    letter-spacing: 0.03em;
  }
  .tx-cell-user {
    font-size: 12px;
    font-weight: 800;
    color: #7dd3fc;
  }
  .tx-cell-account {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 58px;
    padding: 4px 9px;
    border-radius: 999px;
    background: rgba(59, 130, 246, 0.12);
    border: 1px solid rgba(96, 165, 250, 0.16);
    color: #93c5fd;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.04em;
  }
  .tx-cell-merchant {
    font-size: 9px;
    font-weight: 700;
    color: #c9d4ea;
  }
  .tx-cell-created {
    font-size: 11px;
    font-weight: 800;
    color: #f8fafc;
  }
  .tx-cell-expires {
    font-size: 11px;
    font-weight: 800;
    color: #fef3c7;
  }
  .tx-cell-amount {
    font-size: 13px;
    font-weight: 900;
    color: #86efac;
  }
  .tx-cell-amount-sub {
    font-size: 9px;
    font-weight: 700;
    color: #8fa2bd;
  }
  .tx-cell-created2 {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .tx-cell-created2 .d2-date {
    font-size: 12px;
    font-weight: 700;
    color: var(--ink);
  }
  .tx-cell-created2 .d2-time {
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .tx-cell-rrn {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 11px;
    font-weight: 800;
    color: #7dd3fc;
    letter-spacing: 0.02em;
  }
  .tx-cell-note {
    font-size: 10px;
    font-weight: 800;
    color: #f8fafc;
  }
  .tx-cell-issuer {
    font-size: 9px;
    font-weight: 700;
    color: #f59e0b;
  }
  .tx-actions-wrap {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px;
  }

  @media (max-width: 768px) {
    .tx-toolbar { padding: 10px 14px; }
    .tx-filter-bar { padding: 10px 14px; }
    .tx-stats-row { padding: 10px 14px; }
    .tx-stat { padding: 8px 12px; flex: none; min-width: calc(50% - 4px); }
    .tx-stat-value { font-size: 15px; }
    .tx-cell-main,
    .tx-cell-created,
    .tx-cell-expires { font-size: 10px; }
    .tx-cell-amount { font-size: 12px; }
  }
</style>

<section class="space-y-5">
  <div class="qris-page-header">
    <h1 class="qris-page-title">Transaksi <span>QR</span></h1>
    <p class="qris-section-sub mt-1">Setiap QR yang dibuat akan langsung masuk ke sini, dari status menunggu bayar sampai berhasil terproses.</p>
  </div>

  <section class="qris-card overflow-hidden">
    <!-- ── Toolbar ──────────────────────────────── -->
    <div class="tx-toolbar">
      <a href="<%= url((typeof paidOnly !== 'undefined' && paidOnly) ? '/dashboard/transactions' : '/dashboard/history') %>" class="qris-ghost-btn"><span>Reload</span></a>
      <button type="button" onclick="exportTransactions()" class="qris-ghost-btn"><span>Export</span></button>
      <div class="tx-toolbar-sep"></div>
      <button type="button" onclick="checkStatusAll()" class="qris-accent-btn">Check Status All</button>
      <button type="button" id="btnSyncAllTx" class="qris-accent-btn" title="Sinkron semua akun QRIS (maks 1x per menit)"><span id="btnSyncAllTxLabel">Sinkron ALL</span></button>
      <select id="syncOneSelTx" title="Pilih akun untuk disinkron" style="background:rgba(15,23,42,0.6);border:1px solid rgba(255,255,255,0.14);color:inherit;padding:8px 10px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;max-width:180px"><option value="">Pilih Akun…</option></select>
      <button type="button" id="btnSyncOneTx" class="qris-accent-btn" title="Sinkron akun terpilih (maks 1x per menit per akun)"><span id="btnSyncOneTxLabel">Sinkron</span></button>
      <div class="tx-record-info">
        <b><%= totalRecordsText %></b> Records &middot; Page <b><%= page %></b>
      </div>
    </div>

    <!-- ── Filter bar ───────────────────────────── -->
    <form method="GET" action="<%= url((typeof paidOnly !== 'undefined' && paidOnly) ? '/dashboard/transactions' : '/dashboard/history') %>">
      <div class="tx-filter-bar">
        <!-- Period pills -->
        <div class="tx-filter-group">
          <span class="tx-filter-label">Periode</span>
          <div class="tx-period-pills">
            <button type="submit" name="period" value="today" class="tx-period-pill <%= currentPeriod === 'today' ? 'active' : '' %>">Hari Ini</button>
            <button type="submit" name="period" value="yesterday" class="tx-period-pill <%= currentPeriod === 'yesterday' ? 'active' : '' %>">Kemarin</button>
            <button type="submit" name="period" value="7d" class="tx-period-pill <%= currentPeriod === '7d' ? 'active' : '' %>">7 Hari</button>
            <button type="submit" name="period" value="30d" class="tx-period-pill <%= currentPeriod === '30d' ? 'active' : '' %>">30 Hari</button>
            <button type="submit" name="period" value="all" class="tx-period-pill <%= currentPeriod === 'all' ? 'active' : '' %>">Semua</button>
          </div>
        </div>

        <div class="tx-toolbar-sep"></div>

        <!-- Custom range -->
        <div class="tx-filter-group">
          <span class="tx-filter-label">Dari</span>
          <input type="hidden" name="period" value="custom" disabled />
          <input type="date" name="from" value="<%= query.from || '' %>" class="tx-filter-input" style="width:130px" />
        </div>
        <div class="tx-filter-group">
          <span class="tx-filter-label">Sampai</span>
          <input type="date" name="to" value="<%= query.to || '' %>" class="tx-filter-input" style="width:130px" />
        </div>
      </div>

      <!-- ── Advanced filters row ────────────────── -->
      <div class="tx-filter-bar">
        <div class="tx-filter-group grow">
          <span class="tx-filter-label">User / Order / Ref</span>
          <input type="text" name="keyword" value="<%= query.keyword || '' %>" class="tx-filter-input" placeholder="Username, ref, note..." />
        </div>
        <% if (!(typeof paidOnly !== 'undefined' && paidOnly)) { %>
        <div class="tx-filter-group">
          <span class="tx-filter-label">Status Bayar</span>
          <select name="statusPay" class="tx-filter-input" style="width:120px">
            <option value="">Semua</option>
            <option value="open" <%= query.statusPay === 'open' ? 'selected' : '' %>>Open</option>
            <option value="paid" <%= query.statusPay === 'paid' ? 'selected' : '' %>>Paid</option>
            <option value="expired" <%= query.statusPay === 'expired' ? 'selected' : '' %>>Expired</option>
          </select>
        </div>
        <% } %>
        <div class="tx-filter-group">
          <span class="tx-filter-label">Auto Deposit</span>
          <select name="statusBot" class="tx-filter-input" style="width:140px">
            <option value="">Semua</option>
            <option value="pending" <%= query.statusBot === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="deposit_queued" <%= query.statusBot === 'deposit_queued' ? 'selected' : '' %>>Queued</option>
            <option value="deposit_success" <%= query.statusBot === 'deposit_success' ? 'selected' : '' %>>Success</option>
            <option value="deposit_failed" <%= query.statusBot === 'deposit_failed' ? 'selected' : '' %>>Failed</option>
            <option value="manual_review" <%= query.statusBot === 'manual_review' ? 'selected' : '' %>>Review</option>
          </select>
        </div>
        <div class="tx-filter-group">
          <span class="tx-filter-label">QRIS Account</span>
          <select name="accountCode" id="txFilterAccount" class="tx-filter-input" style="width:160px">
            <option value="">Semua</option>
            <% qrisAccounts.forEach((account) => { %>
              <option value="<%= account.code %>" data-site="<%= account.siteId || 'none' %>" <%= query.accountCode === account.code ? 'selected' : '' %>><%= account.code %> - <%= account.merchantName %></option>
            <% }) %>
          </select>
        </div>
        <div class="tx-filter-group">
          <span class="tx-filter-label">Site</span>
          <select name="site" id="txFilterSite" class="tx-filter-input" style="width:150px">
            <option value="">Semua</option>
            <% sites.forEach((s) => { %>
              <option value="<%= s.id %>" <%= query.site === s.id ? 'selected' : '' %>><%= s.name %></option>
            <% }) %>
            <option value="none" <%= query.site === 'none' ? 'selected' : '' %>>Tanpa site</option>
          </select>
        </div>
        <div class="tx-filter-group">
          <span class="tx-filter-label">Nominal</span>
          <input type="text" name="nominal" value="<%= query.nominal || '' %>" inputmode="numeric" class="tx-filter-input" placeholder="mis. 10.001" style="width:120px" oninput="this.value=this.value.replace(/[^0-9.,]/g,'')" />
        </div>
        <button type="submit" class="tx-filter-btn tx-filter-btn-primary" style="height:34px">
          <i class="fa-solid fa-magnifying-glass" style="font-size:11px"></i> Filter
        </button>
        <a href="<%= url((typeof paidOnly !== 'undefined' && paidOnly) ? '/dashboard/transactions' : '/dashboard/history') %>" class="tx-filter-btn tx-filter-btn-ghost" style="height:34px">Reset</a>
      </div>
    </form>
    <script>
    (function () {
      var siteSel = document.getElementById('txFilterSite');
      var acctSel = document.getElementById('txFilterAccount');
      if (!siteSel || !acctSel) return;
      function applySiteFilter(resetIfHidden) {
        var sv = siteSel.value; // '' = semua, siteId, atau 'none'
        var hiddenSelected = false;
        acctSel.querySelectorAll('option[data-site]').forEach(function (o) {
          var show = (sv === '' || o.getAttribute('data-site') === sv);
          o.hidden = !show;
          o.disabled = !show;
          if (!show && o.selected) hiddenSelected = true;
        });
        if (resetIfHidden && hiddenSelected) acctSel.value = '';
      }
      siteSel.addEventListener('change', function () { applySiteFilter(true); });
      applySiteFilter(false);
    })();
    </script>

    <!-- ── Stats row (compact horizontal) ────────── -->
    <div class="tx-stats-row">
      <div class="tx-stat">
        <div class="tx-stat-icon blue"><i class="fa-solid fa-layer-group"></i></div>
