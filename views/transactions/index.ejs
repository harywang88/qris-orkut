    <%
      var _pbBase = url((typeof paidOnly !== 'undefined' && paidOnly) ? '/dashboard/transactions' : '/dashboard/history');
      var _pbFields = { period: currentPeriod, from: (query.from||''), to: (query.to||''), keyword: (query.keyword||''), statusPay: (query.statusPay||''), statusBot: (query.statusBot||''), accountCode: (query.accountCode||''), clientId: (query.clientId||''), site: (query.site||''), all: (query.all||'') };
      var _pbUrl = function(pn, ps){ var qs=[]; Object.keys(_pbFields).forEach(function(k){ var v=_pbFields[k]; if(v!==''&&v!=null) qs.push(k+'='+encodeURIComponent(v)); }); qs.push('pageSize='+(ps||(typeof pageSize!=='undefined'?pageSize:50))); qs.push('page='+pn); return _pbBase+'?'+qs.join('&'); };
      var _tp = (typeof totalPages!=='undefined') ? totalPages : 1;
      var _lo=Math.max(1,page-2), _hi=Math.min(_tp,page+2), _plist=[];
      if(_lo>1){ _plist.push(1); if(_lo>2)_plist.push('...'); }
      for(var _i=_lo;_i<=_hi;_i++)_plist.push(_i);
      if(_hi<_tp){ if(_hi<_tp-1)_plist.push('...'); _plist.push(_tp); }
    %>
