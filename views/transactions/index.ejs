        <% if (_tp > 1) { %><span class="tx-pager-info">Hal <b><%= page %></b>/<%= _tp %> &middot; <b><%= total.toLocaleString('id-ID') %></b> data</span><% } %>
      </div>
      <% if (_tp > 1) { %>
      <div class="tx-pager-nav">
        <a href="<%= _pbUrl(Math.max(1,page-1)) %>" class="tx-pg <%= page<=1?'disabled':'' %>" title="Sebelumnya">&lsaquo;</a>
        <% _plist.forEach(function(pn){ if(pn==='...'){ %><span class="tx-pg-dots">&hellip;</span><% } else { %><a href="<%= _pbUrl(pn) %>" class="tx-pg <%= pn===page?'active':'' %>"><%= pn %></a><% } }); %>
        <a href="<%= _pbUrl(Math.min(_tp,page+1)) %>" class="tx-pg <%= page>=_tp?'disabled':'' %>" title="Berikutnya">&rsaquo;</a>
      </div>
      <% } %>
