<%
  const totalRecordsText = total.toLocaleString('id-ID');
  const totalPaidText = totalPaid.toLocaleString('id-ID');
  const totalFeeText = totalFee.toLocaleString('id-ID');
  const currentPeriod = query.period || 'today';
%>

<style>
  /* ── Toolbar ───────────────────────────────────── */
  .tx-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
    background: linear-gradient(135deg, rgba(59,130,246,0.04), rgba(16,185,129,0.03));
  }
  .tx-toolbar-sep {
    width: 1px; height: 28px; background: var(--line); flex-shrink: 0;
  }
  .tx-record-info {
    margin-left: auto;
    font-size: 12px;
    color: var(--muted);
    white-space: nowrap;
  }
  .tx-record-info b { color: var(--ink); }
  /* Pager server (navigasi ?page=N) + sembunyikan pager bawaan Tabulator (redundant "1 of 1") */
  #transactions-table .tabulator-footer { display: none !important; }
  .tx-pager { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:10px; margin-top:14px; padding-top:12px; border-top:1px solid var(--line); }
  .tx-pager-info { font-size:12px; color:var(--muted); }
  .tx-pager-info b { color: var(--ink); }
  .tx-pager-nav { display:flex; gap:6px; flex-wrap:wrap; }
  .tx-pager-left { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
  .tx-pager-info-lbl { font-size:11.5px; color:var(--muted); font-weight:600; }
  .tx-pager-ps { height:32px; border-radius:9px; border:1px solid var(--line); background:rgba(255,255,255,.04); color:var(--ink); font-size:12.5px; font-weight:700; padding:0 8px; cursor:pointer; }
  .tx-pg { min-width:34px; height:34px; padding:0 10px; display:inline-flex; align-items:center; justify-content:center; border-radius:9px; border:1px solid var(--line); background:rgba(255,255,255,.04); color:var(--ink); font-size:12.5px; font-weight:700; text-decoration:none; transition:.15s; }
  .tx-pg:hover { border-color:rgba(99,179,237,.5); background:rgba(99,179,237,.12); }
  .tx-pg.active { background:linear-gradient(135deg,#63b3ed,#3b82f6); border-color:transparent; color:#04121f; }
  .tx-pg.disabled { opacity:.4; pointer-events:none; }
  .tx-pg-dots { align-self:center; padding:0 4px; color:var(--muted); }

  /* ── Filter bar (horizontal) ───────────────────── */
  .tx-filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    gap: 10px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--line);
  }
  .tx-filter-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .tx-filter-group.grow { flex: 1; min-width: 140px; }
  .tx-filter-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .tx-filter-input {
    height: 34px;
    padding: 0 10px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    color: var(--ink);
    font-size: 12px;
    outline: none;
    transition: border-color .2s;
  }
  .tx-filter-input:focus { border-color: rgba(99,130,255,0.5); }
  .tx-filter-input::placeholder { color: var(--muted); }
  select.tx-filter-input { cursor: pointer; }
  .tx-filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    gap: 10px;
  }

  /* ── Period pills ──────────────────────────────── */
  .tx-period-pills {
    display: flex;
    gap: 4px;
  }
  .tx-period-pill {
    padding: 6px 12px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: transparent;
    color: var(--muted);
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: all .18s;
    white-space: nowrap;
  }
  .tx-period-pill:hover { border-color: rgba(99,130,255,0.35); color: var(--ink); }
  .tx-period-pill.active {
    background: rgba(99,130,255,0.12);
    border-color: rgba(99,130,255,0.40);
    color: #93b4ff;
  }

  /* ── Mini stats row ────────────────────────────── */
  .tx-stats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 12px 20px;
    border-bottom: 1px solid var(--line);
  }
  .tx-stat {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--panel);
    min-width: 0;
    flex: 1;
    transition: border-color .2s;
  }
  .tx-stat:hover { border-color: rgba(99,130,255,0.25); }
  .tx-stat-icon {
    width: 32px; height: 32px;
    display: grid; place-items: center;
    border-radius: 8px;
    font-size: 13px;
    flex-shrink: 0;
  }
  .tx-stat-icon.blue   { background: rgba(59,130,246,0.12); color: #60a5fa; }
  .tx-stat-icon.violet { background: rgba(139,92,246,0.12); color: #a78bfa; }
  .tx-stat-icon.green  { background: rgba(34,197,94,0.12);  color: #4ade80; }
  .tx-stat-icon.amber  { background: rgba(249,115,22,0.12); color: #fb923c; }
  .tx-stat-icon.red    { background: rgba(239,68,68,0.12);  color: #f87171; }
  .tx-stat-body { min-width: 0; }
  .tx-stat-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tx-stat-value {
    font-size: 18px;
    font-weight: 800;
    color: var(--ink);
    line-height: 1.2;
    margin-top: 1px;
  }
  .tx-stat-sub {
    font-size: 10px;
    color: var(--muted);
    margin-top: 2px;
  }

  /* ── Table overrides (dark theme) ────────────────── */
  #transactions-table {
    font-size: 12px;
    border: none !important;
    background: var(--shell) !important;
    color: var(--ink) !important;
  }
  #transactions-table .tabulator-header {
    background:
      linear-gradient(180deg, rgba(20, 25, 35, 0.98), rgba(16, 20, 29, 0.98)) !important;
    border-bottom: 1px solid var(--line) !important;
    border-top: none !important;
    color: var(--muted) !important;
  }
  #transactions-table .tabulator-col {
    background: transparent !important;
    border-right: 1px solid var(--line) !important;
  }
  #transactions-table .tabulator-col:last-child {
    border-right: none !important;
  }
  #transactions-table .tabulator-col-title {
    font-size: 10px !important;
    font-weight: 800 !important;
    letter-spacing: 0.06em !important;
    text-transform: uppercase !important;
    color: #98a5c4 !important;
    text-align: left !important;
    padding: 10px 8px !important;
  }
  #transactions-table .tabulator-col .tabulator-col-content {
    padding: 0 !important;
  }
  #transactions-table .tabulator-col-resize-handle {
    border-color: var(--line) !important;
  }
  #transactions-table .tabulator-tableholder {
    background: var(--shell) !important;
    color: var(--ink) !important;
  }
  #transactions-table .tabulator-row {
    background: var(--shell) !important;
    border-bottom: 1px solid var(--line) !important;
    min-height: 50px !important;
    color: var(--ink) !important;
  }
  #transactions-table .tabulator-row:hover {
    background: linear-gradient(90deg, rgba(36, 44, 62, 0.92), rgba(20, 26, 40, 0.92)) !important;
  }
  #transactions-table .tabulator-row:nth-child(even) {
    background: rgba(19, 24, 34, 0.96) !important;
  }
  #transactions-table .tabulator-row:nth-child(even):hover {
    background: linear-gradient(90deg, rgba(34, 40, 58, 0.96), rgba(20, 26, 40, 0.96)) !important;
  }
  #transactions-table .tabulator-cell {
    border-right: 1px solid rgba(255,255,255,0.03) !important;
    padding: 10px 10px !important;
    vertical-align: middle !important;
    text-align: left !important;
    white-space: normal !important;
    word-break: break-word !important;
    overflow: hidden !important;
    color: var(--ink) !important;
    font-weight: 700 !important;
  }
  #transactions-table .tabulator-cell:last-child {
    border-right: none !important;
  }
  /* ── Perataan kolom biar enak dibaca: teks KIRI, angka KANAN, status/aksi TENGAH ── */
  #transactions-table .tabulator-cell[tabulator-field="finalAmount"],
  #transactions-table .tabulator-col[tabulator-field="finalAmount"] .tabulator-col-title { text-align: right !important; }
  #transactions-table .tabulator-cell[tabulator-field="finalAmount"] .tx-cell-stack { align-items: flex-end !important; }
  #transactions-table .tabulator-cell[tabulator-field="statusPay"],
  #transactions-table .tabulator-cell[tabulator-field="statusBot"],
  #transactions-table .tabulator-cell[tabulator-field="qrId"],
  #transactions-table .tabulator-col[tabulator-field="statusPay"] .tabulator-col-title,
  #transactions-table .tabulator-col[tabulator-field="statusBot"] .tabulator-col-title,
  #transactions-table .tabulator-col[tabulator-field="qrId"] .tabulator-col-title { text-align: center !important; }
  #transactions-table .tabulator-cell[tabulator-field="statusPay"] .tx-cell-stack { align-items: center !important; }
  /* kolom nomor (#) tetap tengah */
  #transactions-table .tabulator-row .tabulator-cell:first-child,
  #transactions-table .tabulator-header .tabulator-col:first-child .tabulator-col-title { text-align: center !important; }
  #transactions-table .tabulator-footer {
    background: var(--panel-2) !important;
    border-top: 1px solid var(--line) !important;
    padding: 8px 12px !important;
    color: var(--muted) !important;
  }
  #transactions-table .tabulator-page {
    border-radius: 8px !important;
    font-size: 11px !important;
    padding: 5px 10px !important;
    border: 1px solid var(--line) !important;
    background: var(--panel) !important;
    color: var(--muted) !important;
    transition: all .18s !important;
  }
  #transactions-table .tabulator-page:hover {
    background: var(--panel-2) !important;
    color: var(--ink) !important;
  }
  #transactions-table .tabulator-page.active {
    background: rgba(99,130,255,0.18) !important;
    border-color: rgba(99,130,255,0.4) !important;
    color: #93b4ff !important;
  }
  #transactions-table .tabulator-pages {
    gap: 4px !important;
  }
  #transactions-table .tabulator-paginator {
    color: var(--muted) !important;
    display: flex !important;
    align-items: center !important;
    gap: 6px !important;
    justify-content: flex-end !important;
  }
  #transactions-table .tabulator-page-counter {
    color: var(--muted) !important;
    font-size: 11px !important;
  }

  /* ── Filter action buttons ──────────────────────── */
  .tx-filter-btn {
    height: 34px;
    padding: 0 16px;
    border: none;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all .18s;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }
  .tx-filter-btn-primary {
    background: rgba(99,130,255,0.18);
    color: #93b4ff;
  }
  .tx-filter-btn-primary:hover { background: rgba(99,130,255,0.28); }
  .tx-filter-btn-ghost {
    background: rgba(255,255,255,0.04);
    color: var(--muted);
  }
  .tx-filter-btn-ghost:hover { background: rgba(255,255,255,0.08); color: var(--ink); }

  /* ── Action buttons in table ────────────────────── */
  .tx-act-btn {
    font-size: 10px;
    font-weight: 600;
    padding: 3px 6px;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 6px;
    background: rgba(255,255,255,0.04);
    color: #c8bdb0;
    cursor: pointer;
    transition: all .18s;
    white-space: nowrap;
  }
  .tx-act-btn:hover { background: rgba(255,255,255,0.08); color: #fff; }
  .tx-act-blue { color: #7bb2ff; border-color: rgba(99,130,255,0.2); }
  .tx-act-blue:hover { background: rgba(99,130,255,0.12); color: #a3c9ff; }
  .tx-act-accent { color: #fb923c; border-color: rgba(249,115,22,0.2); }
  .tx-act-accent:hover { background: rgba(249,115,22,0.12); color: #fdba74; }
  .tx-act-green { color: #4ade80; border-color: rgba(34,197,94,0.2); }
  .tx-act-green:hover { background: rgba(34,197,94,0.12); color: #86efac; }
  .tx-act-receipt { color: #4ade80; border-color: rgba(34,197,94,0.34); background: rgba(34,197,94,0.1); font-weight: 800; display: inline-flex; align-items: center; gap: 5px; }
  .tx-act-receipt:hover { background: rgba(34,197,94,0.2); color: #86efac; }

  .tx-cell-stack {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    line-height: 1.28;
  }
  .tx-cell-main {
    font-size: 11px;
    font-weight: 800;
    color: #f6f8fc;
    letter-spacing: 0.01em;
  }
  .tx-cell-sub {
    font-size: 9px;
    font-weight: 700;
    color: #7f8ba8;
  }
  .tx-cell-site {
    font-size: 11px;
    font-weight: 800;
    color: #fda4af;
    letter-spacing: 0.03em;
  }
  .tx-cell-user {
    font-size: 12px;
    font-weight: 800;
    color: #7dd3fc;
  }
  .tx-cell-account {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 58px;
    padding: 4px 9px;
    border-radius: 999px;
    background: rgba(59, 130, 246, 0.12);
    border: 1px solid rgba(96, 165, 250, 0.16);
    color: #93c5fd;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.04em;
  }
  .tx-cell-merchant {
    font-size: 9px;
    font-weight: 700;
    color: #c9d4ea;
  }
  .tx-cell-created {
    font-size: 11px;
    font-weight: 800;
    color: #f8fafc;
  }
  .tx-cell-expires {
    font-size: 11px;
    font-weight: 800;
    color: #fef3c7;
  }
  .tx-cell-amount {
    font-size: 13px;
    font-weight: 900;
    color: #86efac;
  }
  .tx-cell-amount-sub {
    font-size: 9px;
    font-weight: 700;
    color: #8fa2bd;
  }
  .tx-cell-created2 {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .tx-cell-created2 .d2-date {
    font-size: 12px;
    font-weight: 700;
    color: var(--ink);
  }
  .tx-cell-created2 .d2-time {
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .tx-cell-rrn {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 11px;
    font-weight: 800;
    color: #7dd3fc;
    letter-spacing: 0.02em;
  }
  .tx-cell-note {
    font-size: 10px;
    font-weight: 800;
    color: #f8fafc;
    white-space: nowrap;   /* note 1 baris (issuer di bawah) -> total 2 baris, bukan 3 */
  }
  .tx-cell-issuer {
    font-size: 11px;
    font-weight: 700;
    color: #f59e0b;
  }
  .tx-cell-sender {
    font-weight: 600;
    color: #94a3b8;
  }
  .tx-actions-wrap {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    gap: 3px;
  }
  /* -- Kolom ringkas 1-baris (History Generate QR): detail sekunder pindah ke tooltip hover -- */
  .tx-cell-1line {
    display: flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap !important;   /* kalahkan .tabulator-cell{white-space:normal} agar tetap 1 baris */
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    cursor: default;
    word-break: normal !important;
  }
  .tx-cell-1line > * { flex: 0 0 auto; min-width: 0; }
  .tx-cell-1line .tx-cell-user,
  .tx-cell-1line .tx-cell-account { overflow: hidden; text-overflow: ellipsis; }
  .tx-cell-site-tag {
    font-size: 9px;
    font-weight: 800;
    color: #fda4af;
    letter-spacing: 0.03em;
    padding: 1px 5px;
    border-radius: 6px;
    background: rgba(253, 164, 175, 0.12);
  }
  .tx-cell-time-sub {
    font-size: 10px;
    font-weight: 600;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .tx-exp-inline {
    font-size: 9px;
    font-weight: 800;
    color: #fbbf24;
    background: rgba(251, 191, 36, 0.12);
    padding: 1px 5px;
    border-radius: 6px;
    font-variant-numeric: tabular-nums;
  }
  .tx-cell-status1 { justify-content: center; }
  /* Status 1-baris padat: [PAID] jam · [BOT] jam */
  .tx-status-time {
    font-size: 10px;
    font-weight: 800;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-variant-numeric: tabular-nums;
  }
  .tx-status-time-paid { color: #86efac; }
  .tx-status-time-bot  { color: #86efac; }
  .tx-status-sep { color: var(--muted); font-weight: 700; opacity: 0.6; }
  .tx-bot-icon { font-size: 14px; line-height: 1; flex: 0 0 auto; cursor: help; }
  /* Ref/Issuer: bank & pengirim boleh menyusut, ref tetap utuh */
  .tx-cell-1line .tx-cell-issuer,
  .tx-cell-1line .tx-cell-sender { overflow: hidden; text-overflow: ellipsis; min-width: 0; flex: 0 1 auto; }
  .tx-cell-1line .tx-cell-rrn { flex: 0 0 auto; }
  /* Tag site jangan terlalu kecil; user tetap prioritas tampil */
  .tx-cell-1line .tx-cell-site-tag { flex: 0 0 auto; }
  .tx-cell-1line .tx-cell-user { font-weight: 800; }
  .tx-bot-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: currentColor;
    flex: 0 0 auto;
  }
  /* Titik bot memakai warna pill bot (ambil color dari kelas qris-pill-*) */
  .tx-bot-dot.qris-pill-paid    { color: #22c55e; }
  .tx-bot-dot.qris-pill-warn    { color: #f59e0b; }
  .tx-bot-dot.qris-pill-danger  { color: #ef4444; }
  .tx-bot-dot.qris-pill-review  { color: #f97316; }
  .tx-bot-dot.qris-pill-muted   { color: #94a3b8; }

  @media (max-width: 768px) {
    .tx-toolbar { padding: 10px 14px; }
    .tx-filter-bar { padding: 10px 14px; }
    .tx-stats-row { padding: 10px 14px; }
    .tx-stat { padding: 8px 12px; flex: none; min-width: calc(50% - 4px); }
    .tx-stat-value { font-size: 15px; }
    .tx-cell-main,
    .tx-cell-created,
    .tx-cell-expires { font-size: 10px; }
    .tx-cell-amount { font-size: 12px; }
  }
  @keyframes txBookedBlink { 0%,100%{ box-shadow:inset 0 0 0 2000px rgba(59,130,246,.05); } 50%{ box-shadow:inset 0 0 0 2000px rgba(59,130,246,.45); } }
  #transactions-table .tabulator-row.tx-row-booked .tabulator-cell { animation:txBookedBlink 1.25s ease-in-out infinite; }
  #transactions-table .tabulator-row.tx-row-booked { cursor:help; }
  #transactions-table .tabulator-row.tx-row-booked:hover .tabulator-cell { animation:none; box-shadow:inset 0 0 0 2000px rgba(59,130,246,.42); }
</style>

<section class="space-y-5">
  <div class="qris-page-header">
    <h1 class="qris-page-title">Transaksi <span>QR</span></h1>
    <p class="qris-section-sub mt-1">Setiap QR yang dibuat akan langsung masuk ke sini, dari status menunggu bayar sampai berhasil terproses.</p>
  </div>

  <section class="qris-card overflow-hidden">
    <!-- ── Toolbar ──────────────────────────────── -->
    <div class="tx-toolbar">
      <a href="<%= url((typeof paidOnly !== 'undefined' && paidOnly) ? '/dashboard/transactions' : '/dashboard/history') %>" class="qris-ghost-btn"><span>Reload</span></a>
      <button type="button" onclick="exportTransactions()" class="qris-ghost-btn"><span>Export</span></button>
      <div class="tx-toolbar-sep"></div>
      <button type="button" onclick="checkStatusAll()" class="qris-accent-btn">Check Status All</button>
      <button type="button" id="btnAppAllTx" title="App Sinkron ALL — tarik dari app OrderKuota (cepat). Akun yang kena 469 dilewati otomatis." style="display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,rgba(99,179,237,0.18),rgba(99,179,237,0.06));border:1px solid rgba(99,179,237,0.3);color:#bfdbfe;padding:9px 15px;border-radius:999px;font-size:12px;font-weight:800;letter-spacing:.03em;cursor:pointer;transition:opacity .2s;white-space:nowrap"><i class="fa-solid fa-bolt"></i><span id="btnAppAllTxLabel">App Sinkron ALL</span></button>
      <button type="button" id="btnRepAllTx" title="Report Sinkron ALL — tarik dari web report (bebas limit 469, agak lambat)." style="display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,rgba(52,211,153,0.18),rgba(52,211,153,0.06));border:1px solid rgba(52,211,153,0.32);color:#a7f3d0;padding:9px 15px;border-radius:999px;font-size:12px;font-weight:800;letter-spacing:.03em;cursor:pointer;transition:opacity .2s;white-space:nowrap"><i class="fa-solid fa-globe"></i><span id="btnRepAllTxLabel">Report Sinkron ALL</span></button>
