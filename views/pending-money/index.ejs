<%
  function fmtWib(d) {
    try {
      var t = new Date(new Date(d).getTime() + 7 * 3600000);
      var p = function (n) { return String(n).padStart(2, '0'); };
      return p(t.getUTCDate()) + '/' + p(t.getUTCMonth() + 1) + ' ' + p(t.getUTCHours()) + ':' + p(t.getUTCMinutes()) + ':' + p(t.getUTCSeconds());
    } catch (e) { return '-'; }
  }
  function rp(n) { return 'Rp ' + Number(n || 0).toLocaleString('id-ID'); }
  function ago(mins) {
    mins = Number(mins) || 0;
    if (mins < 1) return 'baru saja';
    var d = Math.floor(mins / 1440), h = Math.floor((mins % 1440) / 60), m = mins % 60;
    if (d > 0) return d + ' hari' + (h > 0 ? (' ' + h + ' jam') : '') + ' lalu';
    if (h > 0) return h + ' jam' + (m > 0 ? (' ' + m + ' mnt') : '') + ' lalu';
    return m + ' mnt lalu';
  }
  var siteList = typeof websites !== 'undefined' ? websites : [];
%>
<style>
  .pm-table th { font-size:10px; text-transform:uppercase; letter-spacing:.06em; color:var(--muted,#8b8b8b); text-align:left; padding:8px 10px; border-bottom:1px solid rgba(255,255,255,.08); }
  .pm-table td { padding:10px; border-bottom:1px solid rgba(255,255,255,.05); vertical-align:top; }
  .pm-table tbody tr { transition:background .15s; }
  .pm-table tbody tr:hover { background:rgba(255,255,255,.03); }
  .pm-amt { font-weight:800; color:#fbbf24; font-size:15px; font-family:ui-monospace,monospace; white-space:nowrap; }
  .pm-req { font-size:11px; color:var(--muted-2,#9a9a9a); margin-top:2px; }
  .pm-badge { display:inline-block; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:600; }
  .pm-btn { border:none; cursor:pointer; border-radius:8px; font-size:12px; font-weight:700; padding:7px 12px; transition:transform .12s, box-shadow .2s, filter .2s; display:inline-flex; align-items:center; gap:6px; }
  .pm-btn:hover { transform:translateY(-1px); filter:brightness(1.08); }
  .pm-btn:active { transform:translateY(0); }
  .pm-btn-ghost { background:rgba(148,163,184,.14); color:#cbd5e1; }
  .pm-btn-push { background:linear-gradient(135deg,#3b82f6,#2563eb); color:#fff; box-shadow:0 4px 14px rgba(37,99,235,.35); }
  .pm-btn-red { background:linear-gradient(135deg,#ef4444,#dc2626); color:#fff; box-shadow:0 4px 14px rgba(220,38,38,.32); }
  .pm-btn-green { background:linear-gradient(135deg,#22c55e,#16a34a); color:#fff; box-shadow:0 4px 14px rgba(22,163,74,.32); }
  .pm-locked-row { background:rgba(134,239,172,.04); cursor:help; }
  .pm-locked-row:hover { background:rgba(134,239,172,.09) !important; }

  /* ── Modal premium ── */
  .pm-modal-backdrop { position:fixed; inset:0; background:rgba(2,6,23,.62); backdrop-filter:blur(6px); z-index:1000; display:none; align-items:center; justify-content:center; padding:16px; overflow-y:auto; opacity:0; transition:opacity .22s ease; }
  .pm-modal-backdrop.show { display:flex; opacity:1; }
  .pm-modal { width:100%; max-width:430px; border-radius:20px; background:linear-gradient(180deg,#ffffff,#f7f8fb); color:#0f172a; box-shadow:0 30px 70px rgba(0,0,0,.5); transform:translateY(18px) scale(.96); opacity:0; transition:transform .28s cubic-bezier(.2,.9,.3,1.2), opacity .28s; max-height:92vh; overflow-y:auto; overflow-x:hidden; }
  .pm-modal-backdrop.show .pm-modal { transform:translateY(0) scale(1); opacity:1; }
  @media (prefers-color-scheme: dark) { .pm-modal { background:linear-gradient(180deg,#1e293b,#0f172a); color:#e2e8f0; } }
  .pm-modal-head { text-align:center; padding:20px 22px 6px; }
  .pm-modal-title { font-size:20px; font-weight:800; letter-spacing:-.01em; }
  .pm-info { margin:14px 22px 4px; background:rgba(148,163,184,.12); border:1px solid rgba(148,163,184,.18); border-radius:12px; padding:12px 14px; }
  .pm-info-row { display:flex; justify-content:space-between; align-items:center; font-size:13px; padding:3px 0; }
  .pm-info-row .k { color:#94a3b8; }
  .pm-info-amt { color:#16a34a; font-weight:800; font-size:16px; }
  @media (prefers-color-scheme: dark) { .pm-info-amt { color:#4ade80; } }
  .pm-tabs { display:flex; margin:16px 22px 0; border-bottom:1px solid rgba(148,163,184,.25); position:relative; }
  .pm-tab { flex:1; text-align:center; padding:10px; font-size:13px; font-weight:700; cursor:pointer; color:#94a3b8; background:none; border:none; transition:color .2s; }
  .pm-tab.active { color:#3b82f6; }
  .pm-tab-underline { position:absolute; bottom:-1px; height:2px; width:50%; background:#3b82f6; border-radius:2px; transition:transform .28s cubic-bezier(.2,.9,.3,1.2); }
  .pm-panel { padding:16px 22px 6px; animation:pmFade .3s ease; }
  @keyframes pmFade { from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:none;} }
  .pm-label { font-size:12px; font-weight:600; color:#64748b; margin:10px 0 5px; display:block; }
  @media (prefers-color-scheme: dark){ .pm-label{color:#94a3b8;} }
  .pm-field { width:100%; padding:10px 12px; border-radius:10px; border:1px solid rgba(148,163,184,.35); background:rgba(255,255,255,.6); color:inherit; font-size:14px; outline:none; transition:border .2s, box-shadow .2s; }
  @media (prefers-color-scheme: dark){ .pm-field{ background:rgba(15,23,42,.6);} }
  .pm-field:focus { border-color:#3b82f6; box-shadow:0 0 0 3px rgba(59,130,246,.18); }
  .pm-note { font-size:11.5px; color:#94a3b8; margin-top:10px; display:flex; gap:6px; align-items:flex-start; }
  .pm-actions { display:flex; gap:10px; justify-content:center; padding:16px 22px 22px; }
  .pm-modal-btn { border:none; cursor:pointer; border-radius:10px; font-size:14px; font-weight:800; padding:11px 22px; transition:transform .12s, filter .2s; }
  .pm-modal-btn:hover { filter:brightness(1.08); transform:translateY(-1px); }
  .pm-ok { background:linear-gradient(135deg,#3b82f6,#2563eb); color:#fff; box-shadow:0 6px 18px rgba(37,99,235,.4); }
  .pm-cancel { background:#64748b; color:#fff; }
  .pm-soon { text-align:center; padding:22px 10px; }
  .pm-soon i { font-size:30px; color:#a78bfa; }
</style>

<!-- Header -->
<div class="qris-page-header flex flex-wrap items-start justify-between gap-4">
  <div>
    <h1 class="qris-page-title">Uang <span>Pending</span></h1>
    <p class="qris-section-sub mt-1">Uang MASUK QRIS yang belum ter-match ke order (bayar 2× / QR kadaluarsa). Uang keluar / pencairan tidak ditampilkan.</p>
  </div>
</div>

<!-- Ringkasan -->
<div class="grid grid-cols-2 lg:grid-cols-3 gap-4 mb-5 qris-card-enter">
  <div class="qris-stat-card" style="border-color:rgba(251,191,36,0.25)">
    <div class="qris-stat-icon" style="background:rgba(251,191,36,0.12);color:#fbbf24">
      <i class="fa-solid fa-hourglass-half"></i>
    </div>
    <div>
      <p class="text-[11px] font-semibold uppercase tracking-wider text-muted mb-1">Total Uang Pending</p>
      <p class="text-base font-bold leading-tight" style="color:#fbbf24">Rp <%= totalPending.toLocaleString('id-ID') %></p>
      <p class="text-xs text-muted-2 mt-0.5"><%= (typeof total!=='undefined'?total:rows.length) %> uang masuk belum ter-match</p>
    </div>
  </div>
</div>

<%
  function pmUrl(ov) {
    var p = Object.assign({ period: (typeof period!=='undefined'?period:'today'), from: (typeof fromValue!=='undefined'?fromValue:''), to: (typeof toValue!=='undefined'?toValue:''), pageSize: (typeof pageSize!=='undefined'?pageSize:25), page: (typeof page!=='undefined'?page:1), dPageSize: (typeof dPageSize!=='undefined'?dPageSize:10), dPage: (typeof dPage!=='undefined'?dPage:1) }, ov || {});
    var parts = []; Object.keys(p).forEach(function (k) { if (p[k] !== '' && p[k] != null) parts.push(k + '=' + encodeURIComponent(p[k])); });
    return '/dashboard/pending-money?' + parts.join('&');
  }
  var _pd = (typeof period !== 'undefined') ? period : 'today';
%>
<style>
  .pmf { display:flex;flex-wrap:wrap;align-items:flex-end;gap:10px;padding:13px 15px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.09);border-radius:14px;margin-bottom:14px; }
  .pmf-l { font-size:10px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--muted,#8b8b8b);display:block;margin-bottom:5px; }
  .pmf-in { height:36px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:var(--ink);border-radius:9px;padding:0 11px;font-size:13px;outline:none; }
  .pmf-in option { background:#141a26;color:#e6ebf5; }
  .pmf-pill { padding:7px 14px;border-radius:999px;font-size:12px;font-weight:700;cursor:pointer;border:1px solid rgba(255,255,255,.1);background:transparent;color:var(--muted,#8b8b8b);text-decoration:none;transition:all .18s; }
  .pmf-pill:hover { border-color:rgba(255,255,255,.25);color:var(--ink); }
  .pmf-pill.on { border-color:rgba(251,191,36,.5);background:rgba(251,191,36,.15);color:#fbbf24;font-weight:800; }
  .pmf-btn { height:36px;display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:0 13px;min-width:34px;border-radius:9px;font-size:13px;font-weight:800;cursor:pointer;border:1px solid transparent;text-decoration:none; }
</style>
<div class="pmf">
  <div>
    <span class="pmf-l">Periode</span>
    <div style="display:flex;gap:6px;flex-wrap:wrap">
      <a href="<%= pmUrl({period:'today',from:'',to:'',page:1}) %>" class="pmf-pill <%= _pd==='today'?'on':'' %>">Hari Ini</a>
      <a href="<%= pmUrl({period:'yesterday',from:'',to:'',page:1}) %>" class="pmf-pill <%= _pd==='yesterday'?'on':'' %>">Kemarin</a>
      <a href="<%= pmUrl({period:'all',from:'',to:'',page:1}) %>" class="pmf-pill <%= _pd==='all'?'on':'' %>">Semua</a>
      <a href="<%= pmUrl({period:'custom',page:1}) %>" class="pmf-pill <%= _pd==='custom'?'on':'' %>">Custom</a>
    </div>
  </div>
  <form method="get" action="/dashboard/pending-money" style="display:flex;align-items:flex-end;gap:10px;flex-wrap:wrap">
    <input type="hidden" name="period" id="pmPeriod" value="<%= _pd %>" />
    <div><span class="pmf-l">Dari</span><input type="date" name="from" value="<%= typeof fromValue!=='undefined'?fromValue:'' %>" onchange="document.getElementById('pmPeriod').value='custom'" class="pmf-in" style="width:145px"></div>
    <div><span class="pmf-l">Sampai</span><input type="date" name="to" value="<%= typeof toValue!=='undefined'?toValue:'' %>" onchange="document.getElementById('pmPeriod').value='custom'" class="pmf-in" style="width:145px"></div>
    <div><span class="pmf-l">Baris/Hal</span>
      <select name="pageSize" class="pmf-in" style="width:80px" onchange="this.form.submit()">
        <% [25,50,100].forEach(function(ps){ %><option value="<%= ps %>" <%= (typeof pageSize!=='undefined'?Number(pageSize):25)===ps?'selected':'' %>><%= ps %></option><% }); %>
      </select>
    </div>
    <button type="submit" class="pmf-btn" style="background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#3a2500"><i class="fa-solid fa-magnifying-glass" style="font-size:11px"></i> Terapkan</button>
  </form>
</div>
<div class="qris-card p-4">
  <% if (!rows || rows.length === 0) { %>
    <div class="text-center py-10 text-muted-2">
      <i class="fa-solid fa-circle-check text-3xl mb-2" style="color:#86efac"></i>
      <p>Tidak ada uang pending. Semua uang masuk sudah ter-match. 🎉</p>
    </div>
  <% } else { %>
  <div class="overflow-x-auto">
    <table class="w-full pm-table">
      <thead>
        <tr>
          <th>Waktu</th>
          <th>Akun / Site</th>
          <th>Nominal</th>
          <th>Pengirim / RRN</th>
          <th>Dugaan Member</th>
          <th style="text-align:center">Action</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function (r) {
             var guessId = (r.guesses && r.guesses[0]) ? r.guesses[0].userIdExt : '';
        %>
          <tr>
            <td class="whitespace-nowrap text-muted-2">
              <%= fmtWib(r.transactionTime) %>
              <span class="block text-[10px] text-muted"><%= ago(r.ageMinutes) %></span>
            </td>
            <td class="whitespace-nowrap">
              <span class="text-ink font-semibold"><%= r.merchantName || r.accountCode %></span>
              <span class="block text-[10px] text-muted"><%= r.siteName || 'Tanpa site' %></span>
            </td>
            <td>
              <div class="pm-amt"><%= rp(r.amount) %></div>
              <% if (r.reqAmount) { %><div class="pm-req">Req: <%= rp(r.reqAmount) %></div><% } %>
            </td>
            <td>
              <span class="text-ink text-sm"><%= r.pengirim || '-' %></span>
              <% if (r.rrn) { %><span class="block text-[10px] text-muted font-mono"><%= r.rrn %></span><% } %>
            </td>
            <td>
              <% if (r.guesses && r.guesses.length) { %>
                <% r.guesses.slice(0,3).forEach(function (g) { %>
                  <span class="pm-badge" style="background:rgba(96,165,250,.15);color:#93c5fd;margin-bottom:3px"><%= g.userIdExt %> <span style="opacity:.7">(<%= g.statusPay %>)</span></span><br>
                <% }); %>
              <% } else { %>
                <span class="text-[11px] text-muted">— tak ada dugaan —</span>
              <% } %>
            </td>
            <td style="text-align:center">
              <div style="display:flex; gap:6px; justify-content:center; flex-wrap:wrap">
                <% if (r.claimedByReport) { %>
                  <span class="pm-badge" style="background:rgba(139,92,246,.16);color:#c4b5fd" title="Ada laporan OrderKuota aktif (RRN+nominal+akun cocok) — bot akan ambil alih & kredit otomatis. Booking manual dikunci agar tak dobel."><i class="fa-solid fa-flag"></i> Diklaim Laporan OrderKuota</span>
                <% } else if (r.tag && r.tag.status === 'claimed') { %>
                  <span class="pm-badge" style="background:rgba(134,239,172,.15);color:#86efac"><i class="fa-solid fa-circle-check"></i> Diklaim<%= r.tag.website ? (' → ' + r.tag.website) : '' %></span>
                  <button class="pm-btn pm-btn-ghost" data-url="<%= url('/dashboard/api/pending-money/' + r.id + '/untag') %>" onclick="pmUntag(this)">Reset</button>
                <% } else { %>
                  <% if (r.tag && r.tag.status === 'pending') { %>
                    <button class="pm-btn pm-btn-green" data-url="<%= url('/dashboard/api/pending-money/' + r.id + '/untag') %>" onclick="pmUntag(this)"><i class="fa-solid fa-circle-check"></i> Dicatat</button>
                  <% } else { %>
                    <button class="pm-btn pm-btn-red" data-url="<%= url('/dashboard/api/pending-money/' + r.id + '/tag') %>" onclick="pmCatat(this)"><i class="fa-solid fa-bookmark"></i> Catat Pending</button>
                  <% } %>
                  <button class="pm-btn pm-btn-push"
                    data-book-url="<%= url('/dashboard/api/pending-money/' + r.id + '/book') %>"
                    data-issuer="<%= r.pengirim || '-' %>"
                    data-amount="<%= rp(r.amount) %>"
                    data-rrn="<%= r.rrn || '-' %>"
                    data-member="<%= guessId %>"
                    onclick="pmOpenPush(this)"><i class="fa-solid fa-arrow-up-right-from-square"></i> Push ke Website</button>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
<div class="qris-card p-3 mt-3" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px">
  <span class="text-[11px] text-muted-2">Halaman <b class="text-ink"><%= page %></b> dari <%= totalPages %> · <%= total %> uang pending</span>
  <div style="display:flex;gap:6px;flex-wrap:wrap">
    <% var _lo=Math.max(1,page-2),_hi=Math.min(totalPages,page+2); var _pl=[]; if(_lo>1){_pl.push(1); if(_lo>2)_pl.push('...');} for(var _i=_lo;_i<=_hi;_i++)_pl.push(_i); if(_hi<totalPages){if(_hi<totalPages-1)_pl.push('...');_pl.push(totalPages);} %>
    <a href="<%= pmUrl({page:Math.max(1,page-1)}) %>" class="pmf-btn" style="background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.12);color:var(--muted);<%= page<=1?'opacity:.4;pointer-events:none':'' %>"><i class="fa-solid fa-chevron-left" style="font-size:10px"></i></a>
    <% _pl.forEach(function(pn){ %>
      <% if(pn==='...'){ %><span style="padding:0 6px;color:var(--muted);align-self:center">…</span><% } else { %>
      <a href="<%= pmUrl({page:pn}) %>" class="pmf-btn" style="<%= pn===page?'background:linear-gradient(135deg,#fbbf24,#f59e0b);color:#3a2500':'background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.12);color:var(--ink)' %>"><%= pn %></a>
      <% } %>
    <% }); %>
    <a href="<%= pmUrl({page:Math.min(totalPages,page+1)}) %>" class="pmf-btn" style="background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.12);color:var(--muted);<%= page>=totalPages?'opacity:.4;pointer-events:none':'' %>"><i class="fa-solid fa-chevron-right" style="font-size:10px"></i></a>
  </div>
</div>
<% } %>

<!-- ── Sudah Diproses (terkunci) ── -->
<% var _locked = (typeof lockedRows !== 'undefined' && lockedRows) ? lockedRows : []; %>
<% var _dTotal = (typeof dTotal !== 'undefined') ? dTotal : _locked.length; %>
<% if (_dTotal > 0) { %>
<div class="qris-card p-4 mt-5">
  <div class="flex items-center justify-between flex-wrap gap-2 mb-3">
    <div class="flex items-center gap-2">
      <i class="fa-solid fa-lock" style="color:#86efac"></i>
      <h2 class="text-sm font-bold text-ink">Sudah Diproses <span class="text-muted-2 font-normal">(<%= _dTotal %> — manual + auto deposit, terkunci)</span></h2>
    </div>
    <div style="display:flex;align-items:center;gap:6px">
      <span class="pmf-l" style="margin:0">Baris/Hal</span>
      <select class="pmf-in" style="width:78px" onchange="var u=new URL(location.href);u.searchParams.set('dPageSize',this.value);u.searchParams.set('dPage','1');location.href=u.toString()">
        <% [10,50,100].forEach(function(ps){ %><option value="<%= ps %>" <%= (typeof dPageSize!=='undefined'?Number(dPageSize):10)===ps?'selected':'' %>><%= ps %></option><% }); %>
      </select>
    </div>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full pm-table">
      <thead>
        <tr>
          <th>Uang Masuk</th>
          <th>User ID</th>
          <th>Akun / Site</th>
          <th>Nominal</th>
          <th>Pengirim / RRN</th>
          <th>Diproses</th>
          <th style="text-align:center">Status</th>
        </tr>
      </thead>
      <tbody>
        <% _locked.forEach(function (r) {
             var _isOk = (r.source === 'orderkuota');
             var tip = (_isOk ? 'Diambil alih oleh Laporkan ke OrderKuota' : 'Dari Uang Pending') + ' · masuk ' + fmtWib(r.transactionTime) + (r.processedAt ? (' · diproses ' + fmtWib(r.processedAt)) : '') + (r.processedBy ? (' oleh ' + r.processedBy) : '');
        %>
          <tr class="pm-locked-row" title="<%= tip %>">
            <td class="whitespace-nowrap text-muted-2"><%= fmtWib(r.transactionTime) %></td>
            <td class="whitespace-nowrap"><span class="pm-badge" style="background:rgba(96,165,250,.15);color:#93c5fd"><%= r.userIdExt || '-' %></span></td>
            <td class="whitespace-nowrap">
              <span class="text-ink font-semibold"><%= r.merchantName || r.accountCode %></span>
              <span class="block text-[10px] text-muted"><%= r.siteName || 'Tanpa site' %></span>
            </td>
            <td><div class="pm-amt" style="color:#86efac"><%= rp(r.amount) %></div></td>
            <td>
              <span class="text-ink text-sm"><%= r.pengirim || '-' %></span>
              <% if (r.rrn) { %><span class="block text-[10px] text-muted font-mono"><%= r.rrn %></span><% } %>
            </td>
            <td class="whitespace-nowrap text-muted-2">
              <%= r.processedAt ? fmtWib(r.processedAt) : '-' %>
              <span class="block text-[10px] text-muted"><%= (r.website ? ('→ ' + r.website) : '') %><%= r.processedBy ? (' · ' + r.processedBy) : '' %></span>
            </td>
            <td style="text-align:center">
              <% if (_isOk) { %>
                <span class="pm-badge" style="background:rgba(139,92,246,.16);color:#c4b5fd" title="Diambil alih oleh Laporkan ke OrderKuota"><i class="fa-solid fa-flag"></i> Diambil alih (OrderKuota)</span>
              <% } else { %>
                <span class="pm-badge" style="background:rgba(134,239,172,.15);color:#86efac"><i class="fa-solid fa-lock"></i> Terkunci</span>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% if (typeof dTotalPages !== 'undefined' && dTotalPages > 1) { %>
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.08)">
    <span class="text-[11px] text-muted-2">Halaman <b class="text-ink"><%= dPage %></b> dari <%= dTotalPages %></span>
    <div style="display:flex;gap:6px;flex-wrap:wrap">
      <% var _dlo=Math.max(1,dPage-2),_dhi=Math.min(dTotalPages,dPage+2); var _dpl=[]; if(_dlo>1){_dpl.push(1); if(_dlo>2)_dpl.push('...');} for(var _di=_dlo;_di<=_dhi;_di++)_dpl.push(_di); if(_dhi<dTotalPages){if(_dhi<dTotalPages-1)_dpl.push('...');_dpl.push(dTotalPages);} %>
      <a href="<%= pmUrl({dPage:Math.max(1,dPage-1)}) %>" class="pmf-btn" style="background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.12);color:var(--muted);<%= dPage<=1?'opacity:.4;pointer-events:none':'' %>"><i class="fa-solid fa-chevron-left" style="font-size:10px"></i></a>
      <% _dpl.forEach(function(pn){ %>
        <% if(pn==='...'){ %><span style="padding:0 6px;color:var(--muted);align-self:center">…</span><% } else { %>
        <a href="<%= pmUrl({dPage:pn}) %>" class="pmf-btn" style="<%= pn===dPage?'background:linear-gradient(135deg,#86efac,#22c55e);color:#052e16':'background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.12);color:var(--ink)' %>"><%= pn %></a>
        <% } %>
      <% }); %>
      <a href="<%= pmUrl({dPage:Math.min(dTotalPages,dPage+1)}) %>" class="pmf-btn" style="background:rgba(255,255,255,.05);border-color:rgba(255,255,255,.12);color:var(--muted);<%= dPage>=dTotalPages?'opacity:.4;pointer-events:none':'' %>"><i class="fa-solid fa-chevron-right" style="font-size:10px"></i></a>
    </div>
  </div>
  <% } %>
</div>
<% } %>

<!-- ── Modal Push ke Website (Klaim Transaksi) ── -->
<div class="pm-modal-backdrop" id="pmModal" onclick="if(event.target===this)pmClose()">
  <div class="pm-modal" role="dialog" aria-modal="true">
    <div class="pm-modal-head"><div class="pm-modal-title">Klaim Transaksi</div></div>
    <div class="pm-info">
      <div class="pm-info-row"><span class="k">Pengirim</span><span id="pmiIssuer" style="font-weight:700"></span></div>
      <div class="pm-info-row"><span class="k">Amount</span><span class="pm-info-amt" id="pmiAmount"></span></div>
      <div class="pm-info-row"><span class="k">RRN</span><span id="pmiRrn" class="font-mono" style="font-size:12px;color:#94a3b8"></span></div>
    </div>
    <div class="pm-tabs">
      <button class="pm-tab active" id="pmTabManual" onclick="pmSwitch('manual')"><i class="fa-solid fa-pen-to-square"></i> Manual</button>
      <button class="pm-tab" id="pmTabAuto" onclick="pmSwitch('auto')"><i class="fa-solid fa-robot"></i> Auto Deposit</button>
      <span class="pm-tab-underline" id="pmUnderline" style="transform:translateX(0)"></span>
    </div>

    <div class="pm-panel">
      <label class="pm-label">Website <span style="color:#ef4444">*</span></label>
      <select class="pm-field" id="pmWebsite">
        <option value="">— Pilih Website —</option>
        <% siteList.forEach(function(w){ %><option value="<%= w.name %>"><%= w.name %><%= w.code ? (' (' + w.code + ')') : '' %></option><% }); %>
      </select>
      <label class="pm-label">User ID / Member <span id="pmMemberReq" style="color:#ef4444;display:none">*</span></label>
      <input class="pm-field" id="pmMember" type="text" placeholder="Username member">
      <label class="pm-label">Catatan</label>
      <input class="pm-field" id="pmNote" type="text" placeholder="Catatan (opsional)">
      <div class="pm-note" id="pmHintManual"><i class="fa-solid fa-circle-info" style="margin-top:2px"></i><span><b>Manual:</b> CS isi saldo member di panel sendiri. Sistem mencatat jadi <b>Transaksi</b> (masuk omzet) &amp; mutasi jadi <b>match</b>. Tidak mengirim deposit otomatis.</span></div>
      <div class="pm-note" id="pmHintAuto" style="display:none"><i class="fa-solid fa-robot" style="margin-top:2px;color:#a78bfa"></i><span><b>Auto Deposit:</b> bot langsung <b>kredit saldo member</b> di website + catat jadi Transaksi. <b>Member wajib diisi.</b> Hanya website ber-API deposit (mis. Sulebet).</span></div>
    </div>

    <div class="pm-actions">
      <button class="pm-modal-btn pm-ok" id="pmSubmit" onclick="pmSubmit()"><i class="fa-solid fa-check"></i> Proses &amp; Catat</button>
      <button class="pm-modal-btn pm-cancel" onclick="pmClose()">Batal</button>
    </div>
  </div>
</div>

<script>
  var pmCur = { bookUrl: '', mode: 'auto' };
  function pmOpenPush(btn) {
    pmCur.bookUrl = btn.dataset.bookUrl;
    document.getElementById('pmiIssuer').textContent = btn.dataset.issuer;
    document.getElementById('pmiAmount').textContent = btn.dataset.amount;
    document.getElementById('pmiRrn').textContent = btn.dataset.rrn;
    document.getElementById('pmMember').value = btn.dataset.member || '';
    var _ws = document.getElementById('pmWebsite'); var _def = '';
    for (var _i=0;_i<_ws.options.length;_i++){ if((_ws.options[_i].value||'').toLowerCase()==='sulebet'){_def=_ws.options[_i].value;break;} }
    if(!_def){ for (var _j=0;_j<_ws.options.length;_j++){ if(_ws.options[_j].value){_def=_ws.options[_j].value;break;} } }
    _ws.value = _def;
    document.getElementById('pmNote').value = '';
    pmSwitch('auto');
    document.getElementById('pmModal').classList.add('show');
  }
  function pmClose() { document.getElementById('pmModal').classList.remove('show'); }
  function pmSwitch(mode) {
    pmCur.mode = mode;
    var man = mode === 'manual';
    document.getElementById('pmTabManual').classList.toggle('active', man);
    document.getElementById('pmTabAuto').classList.toggle('active', !man);
    document.getElementById('pmUnderline').style.transform = 'translateX(' + (man ? '0' : '100%') + ')';
    document.getElementById('pmHintManual').style.display = man ? 'block' : 'none';
    document.getElementById('pmHintAuto').style.display = man ? 'none' : 'block';
    document.getElementById('pmMemberReq').style.display = man ? 'none' : 'inline';
    var submit = document.getElementById('pmSubmit');
    submit.style.opacity = '1';
    submit.style.pointerEvents = 'auto';
    submit.innerHTML = man
      ? '<i class="fa-solid fa-check"></i> Proses &amp; Catat'
      : '<i class="fa-solid fa-robot"></i> Kredit Otomatis';
  }
  async function pmSubmit() {
    var website = document.getElementById('pmWebsite').value;
    if (!website) { alert('Pilih Website dulu ya.'); return; }
    var member = document.getElementById('pmMember').value.trim();
    if (pmCur.mode === 'auto') {
      if (!member) { alert('Auto Deposit wajib isi Member (username yang dikredit).'); return; }
      var amt = document.getElementById('pmiAmount').textContent || '';
      if (!confirm('Kredit otomatis ' + amt + ' ke member "' + member + '" di ' + website + '?\nPastikan member benar — saldo akan langsung masuk.')) return;
    }
    var btn = document.getElementById('pmSubmit');
    btn.style.pointerEvents = 'none'; btn.style.opacity = '.6';
    var payload = { mode: pmCur.mode, website: website, userIdExt: member, note: document.getElementById('pmNote').value.trim() };
    try {
      var r = await fetch(pmCur.bookUrl, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      var d = {}; try { d = await r.json(); } catch (e2) {}
      if (r.ok && d.ok) { location.reload(); }
      else { alert(d.message || 'Gagal memproses.'); btn.style.pointerEvents = 'auto'; btn.style.opacity = '1'; }
    } catch (e) { alert('Gagal: ' + e.message); btn.style.pointerEvents = 'auto'; btn.style.opacity = '1'; }
  }
  async function pmCatat(btn) {
    try {
      var r = await fetch(btn.dataset.url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status: 'pending' }) });
      if (r.ok) { location.reload(); } else { alert('Gagal'); }
    } catch (e) { alert('Gagal: ' + e.message); }
  }
  async function pmUntag(btn) {
    if (!confirm('Reset status uang pending ini?')) return;
    try {
      var r = await fetch(btn.dataset.url, { method: 'POST' });
      if (r.ok) { location.reload(); } else { alert('Gagal'); }
    } catch (e) { alert('Gagal: ' + e.message); }
  }
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') pmClose(); });
  // Pindahkan modal ke <body> supaya position:fixed lepas dari ancestor ber-transform
  // (fix: breakdown tak muncul pas / harus zoom-out+scroll karena kejebak container beranimasi).
  (function () { var m = document.getElementById('pmModal'); if (m && m.parentElement !== document.body) document.body.appendChild(m); })();
</script>
