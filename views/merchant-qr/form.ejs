<%
  const isEdit = account !== null;
  const formAction = isEdit ? url(`/merchant-qr/${account.id}`) : url('/merchant-qr');
  function val(field, fallback) {
    return isEdit && account[field] != null ? account[field] : (fallback ?? '');
  }
  function hasErr(field) {
    return errors && errors[field] && errors[field].length > 0;
  }
%>

<style>
  .mq-back {
    display:inline-flex;align-items:center;gap:6px;
    font-size:12px;color:var(--color-muted);text-decoration:none;
    padding:5px 0;transition:color .15s;
  }
  .mq-back:hover { color:var(--color-ink); }

  /* Section card */
  .mq-section {
    border-radius:16px;
    border:1px solid rgba(255,255,255,0.07);
    background:var(--color-card);
    overflow:hidden;
    margin-bottom:16px;
  }
  .mq-section-hdr {
    display:flex;align-items:center;gap:12px;
    padding:14px 20px;
    border-bottom:1px solid rgba(255,255,255,0.06);
  }
  .mq-section-icon {
    width:34px;height:34px;border-radius:10px;
    display:flex;align-items:center;justify-content:center;
    flex-shrink:0;font-size:14px;
  }
  .mq-section-body { padding:20px; }

  /* Field */
  .mq-field { margin-bottom:0; }
  .mq-label {
    display:flex;align-items:center;gap:6px;
    font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;
    color:var(--color-muted);margin-bottom:6px;
  }
  .mq-label .req { color:#f87171;margin-left:2px; }
  .mq-label .badge {
    font-size:9px;font-weight:600;letter-spacing:.03em;text-transform:none;
    padding:1px 7px;border-radius:999px;
    background:rgba(99,179,237,0.12);color:#93c5fd;border:1px solid rgba(99,179,237,0.2);
    margin-left:auto;
  }
  .mq-label .badge.must {
    background:rgba(34,197,94,0.12);
    color:#86efac;
    border-color:rgba(34,197,94,0.24);
  }
  .mq-label .badge.opt {
    background:rgba(100,116,139,0.12);color:#94a3b8;border-color:rgba(100,116,139,0.2);
  }
  .mq-label .badge.tip {
    background:rgba(245,158,11,0.12);color:#fcd34d;border-color:rgba(245,158,11,0.24);
  }
  .mq-input {
    width:100%;background:rgba(255,255,255,0.04);
    border:1px solid rgba(255,255,255,0.1);
    border-radius:10px;padding:10px 14px;
    color:var(--color-ink);font-size:13px;outline:none;
    transition:border-color .2s,background .2s;
    box-sizing:border-box;
  }
  .mq-input:focus { border-color:rgba(99,179,237,0.45);background:rgba(99,179,237,0.04); }
  .mq-input::placeholder { color:var(--color-muted); }
  .mq-input.is-error { border-color:rgba(239,68,68,0.5); }
  .mq-input.mono { font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:12px; }
  .mq-input[readonly] { opacity:.55;cursor:not-allowed; }
  .mq-hint {
    margin-top:5px;font-size:11px;color:var(--color-muted);
    display:flex;align-items:flex-start;gap:5px;line-height:1.5;
  }
  .mq-hint i { margin-top:1px;flex-shrink:0;font-size:10px; }
  .mq-err { margin-top:4px;font-size:11px;color:#fca5a5; }

  /* Input with suffix */
  .mq-input-wrap { position:relative; }
  .mq-input-wrap .mq-input { padding-right:48px; }
  .mq-input-wrap .mq-suffix {
    position:absolute;right:12px;top:50%;transform:translateY(-50%);
    font-size:11px;font-weight:700;color:var(--color-muted);
  }

  /* Password toggle */
  .mq-pwd-wrap { position:relative; }
  .mq-pwd-wrap .mq-input { padding-right:42px; }
  .mq-pwd-toggle {
    position:absolute;right:12px;top:50%;transform:translateY(-50%);
    background:none;border:none;cursor:pointer;color:var(--color-muted);
    font-size:13px;padding:2px;transition:color .15s;
  }
  .mq-pwd-toggle:hover { color:var(--color-ink); }

  /* Poll row */
  .mq-poll-card {
    padding:14px 16px;
    background:rgba(255,255,255,0.02);
    border:1px solid rgba(255,255,255,0.06);
    border-radius:12px;
  }
  .mq-poll-title { font-size:12px;font-weight:700;color:var(--color-ink);margin-bottom:2px; }
  .mq-poll-sub { font-size:11px;color:var(--color-muted);margin-bottom:10px;line-height:1.45; }

  /* Balance mini cards */
  .mq-bal-card {
    padding:12px 14px;border-radius:12px;
    border:1px solid rgba(255,255,255,0.07);
    background:rgba(255,255,255,0.03);
    text-align:center;
  }
  .mq-bal-label { font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--color-muted);margin-bottom:4px; }
  .mq-bal-val { font-size:16px;font-weight:800;color:var(--color-ink); }

  /* Sticky page top bar */
  .mq-topbar {
    display:flex;align-items:center;justify-content:space-between;
    flex-wrap:wrap;gap:12px;margin-bottom:20px;
  }
  .mq-topbar-actions { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
  .mq-toolbar-btn {
    display:inline-flex; align-items:center; gap:8px;
    padding:10px 14px; border-radius:12px; text-decoration:none;
    border:1px solid rgba(255,255,255,0.1); background:rgba(255,255,255,0.04);
    color:var(--color-ink); font-size:12px; font-weight:700; cursor:pointer;
    transition:all .15s;
  }
  .mq-toolbar-btn:hover { background:rgba(255,255,255,0.08); }
  .mq-toolbar-btn.blue { border-color:rgba(59,130,246,0.22); color:#93c5fd; }
  .mq-toolbar-btn.green { border-color:rgba(34,197,94,0.22); color:#86efac; }
  .mq-page-grid { display:grid; grid-template-columns:minmax(0,1.7fr) minmax(300px,.85fr); gap:20px; align-items:start; }
  .mq-main { min-width:0; }
  .mq-side { min-width:0; position:sticky; top:18px; }
  @media(max-width:1100px){ .mq-page-grid { grid-template-columns:1fr; } .mq-side { position:static; } }
  .mq-side-card {
    border-radius:18px; padding:18px; margin-bottom:16px;
    border:1px solid rgba(255,255,255,0.08);
    background:linear-gradient(180deg,rgba(255,255,255,0.035),rgba(255,255,255,0.02));
  }
  .mq-side-title { font-size:12px; font-weight:800; color:var(--color-ink); letter-spacing:.04em; text-transform:uppercase; margin-bottom:12px; }
  .mq-stat-list { display:flex; flex-direction:column; gap:10px; }
  .mq-stat {
    display:flex; align-items:center; justify-content:space-between; gap:12px;
    padding:10px 12px; border-radius:12px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06);
  }
  .mq-stat-label { font-size:12px; color:var(--color-muted); }
  .mq-stat-val { font-size:12px; font-weight:800; color:var(--color-ink); }
  .mq-quick-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
  .mq-preset-row { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:14px; }
  .mq-preset-btn {
    display:inline-flex; align-items:center; gap:7px; padding:8px 12px; border-radius:999px;
    border:1px solid rgba(255,255,255,0.08); background:rgba(255,255,255,0.04);
    color:var(--color-ink); font-size:11px; font-weight:700; cursor:pointer;
  }
  .mq-preset-btn:hover { background:rgba(255,255,255,0.08); }
  .mq-note-list { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:10px; }
  .mq-note-list li { display:flex; gap:10px; font-size:12px; color:var(--color-muted); line-height:1.55; }
  .mq-note-list i { margin-top:2px; color:#93c5fd; flex-shrink:0; }
  .mq-steps { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin:0 0 18px; }
  @media(max-width:900px){ .mq-steps { grid-template-columns:repeat(2,1fr); } }
  @media(max-width:520px){ .mq-steps { grid-template-columns:1fr; } }
  .mq-step {
    padding:14px 15px; border-radius:16px;
    border:1px solid rgba(255,255,255,0.07);
    background:rgba(255,255,255,0.03);
  }
  .mq-step-no {
    width:28px;height:28px;border-radius:10px;
    display:flex;align-items:center;justify-content:center;
    background:rgba(34,197,94,0.12);color:#86efac;
    font-size:12px;font-weight:800;margin-bottom:10px;
  }
  .mq-step-title { font-size:12px;font-weight:800;color:var(--color-ink);margin-bottom:4px; }
  .mq-step-sub { font-size:11px;color:var(--color-muted);line-height:1.5; }
  .mq-subpanel {
    margin-top:14px;padding:14px 16px;border-radius:14px;
    background:rgba(255,255,255,0.02);border:1px dashed rgba(255,255,255,0.12);
  }
  .mq-subpanel-title {
    font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;
    color:var(--color-muted);margin-bottom:12px;
  }
  .mq-toggle-wrap { border-top:1px dashed rgba(255,255,255,0.09); margin-top:16px; padding-top:16px; }
  .mq-toggle-btn {
    display:inline-flex;align-items:center;gap:8px;
    padding:9px 12px;border-radius:12px;cursor:pointer;user-select:none;
    border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.04);
    color:var(--color-ink);font-size:12px;font-weight:700;
  }
  .mq-toggle-btn:hover { background:rgba(255,255,255,0.07); }
  .mq-toggle-box { display:none; }
  .mq-toggle-box.open { display:block; }
  .mq-action-modal {
    position:fixed; inset:0; z-index:80; display:none; align-items:center; justify-content:center; padding:20px;
    background:rgba(4,7,17,0.72); backdrop-filter:blur(8px);
  }
  .mq-action-modal.open { display:flex; }
  .mq-action-card {
    width:min(760px,100%); max-height:88vh; overflow:auto;
    border-radius:24px; border:1px solid rgba(255,255,255,0.08);
    background:linear-gradient(180deg,rgba(20,24,38,0.98),rgba(12,15,26,0.98));
    box-shadow:0 26px 70px rgba(0,0,0,0.46);
  }
  .mq-action-head {
    display:flex; align-items:flex-start; justify-content:space-between; gap:12px;
    padding:20px 22px; border-bottom:1px solid rgba(255,255,255,0.06);
  }
  .mq-action-title { margin:0 0 4px; font-size:18px; font-weight:800; color:var(--color-ink); }
  .mq-action-sub { margin:0; font-size:12px; color:var(--color-muted); }
  .mq-action-body { padding:22px; }
  .mq-close-btn {
    width:34px; height:34px; border-radius:11px; border:1px solid rgba(255,255,255,0.08);
    background:rgba(255,255,255,0.04); color:var(--color-muted); cursor:pointer;
  }
  .mq-result-hero {
    margin-bottom:16px; padding:14px 16px; border-radius:16px;
    background:linear-gradient(135deg,rgba(255,124,108,0.08),rgba(59,130,246,0.08));
    border:1px solid rgba(255,255,255,0.08); color:var(--color-ink); font-size:13px; line-height:1.65;
  }
  .mq-result-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:16px; }
  @media(max-width:760px){ .mq-result-grid { grid-template-columns:repeat(2,1fr); } }
  @media(max-width:480px){ .mq-result-grid { grid-template-columns:1fr; } }
  .mq-result-card { padding:13px 14px; border-radius:14px; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07); }
  .mq-result-k { font-size:10px; text-transform:uppercase; letter-spacing:.08em; color:var(--color-muted); margin-bottom:5px; }
  .mq-result-v { font-size:17px; font-weight:800; color:var(--color-ink); }
  .mq-result-checks { display:flex; flex-direction:column; gap:10px; }
  .mq-result-check { display:flex; gap:12px; align-items:flex-start; padding:12px 14px; border-radius:14px; border:1px solid rgba(255,255,255,0.07); background:rgba(255,255,255,0.025); }
  .mq-result-check.ok { background:rgba(34,197,94,0.06); border-color:rgba(34,197,94,0.18); }
  .mq-result-check.bad { background:rgba(239,68,68,0.06); border-color:rgba(239,68,68,0.18); }
  .mq-result-icon { width:28px; height:28px; border-radius:9px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .mq-result-check.ok .mq-result-icon { background:rgba(34,197,94,0.14); color:#86efac; }
  .mq-result-check.bad .mq-result-icon { background:rgba(239,68,68,0.14); color:#fca5a5; }
  .mq-result-check-title { font-size:13px; font-weight:700; color:var(--color-ink); margin-bottom:2px; }
  .mq-result-check-detail { font-size:12px; color:var(--color-muted); line-height:1.55; }
  .mq-inline-actions { display:flex; flex-wrap:wrap; gap:8px; margin-top:10px; }
  .mq-mini-btn {
    display:inline-flex; align-items:center; gap:8px;
    padding:9px 12px; border-radius:10px; cursor:pointer;
    border:1px solid rgba(255,255,255,0.08); background:rgba(255,255,255,0.04);
    color:var(--color-ink); font-size:12px; font-weight:700;
  }
  .mq-mini-btn:hover { background:rgba(255,255,255,0.08); }
  .mq-mini-btn.blue { border-color:rgba(59,130,246,0.22); color:#93c5fd; }
  .mq-mini-btn.green { border-color:rgba(34,197,94,0.22); color:#86efac; }
  .mq-mini-btn.orange { border-color:rgba(245,158,11,0.22); color:#fcd34d; }
  .mq-report-test {
    margin-top:12px; padding:14px 16px; border-radius:14px;
    background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.07);
    display:none;
  }
  .mq-report-test.open { display:block; }
  .mq-badge-row { display:flex; flex-wrap:wrap; gap:8px; margin:10px 0 12px; }
  .mq-test-badge {
    display:inline-flex; align-items:center; gap:6px; padding:6px 10px; border-radius:999px;
    font-size:11px; font-weight:700; border:1px solid rgba(255,255,255,0.08);
    background:rgba(255,255,255,0.04); color:var(--color-muted);
  }
  .mq-test-badge.ok { color:#86efac; border-color:rgba(34,197,94,0.24); background:rgba(34,197,94,0.08); }
  .mq-test-badge.bad { color:#fca5a5; border-color:rgba(239,68,68,0.24); background:rgba(239,68,68,0.08); }
  .mq-test-grid { display:grid; grid-template-columns:repeat(2, minmax(0,1fr)); gap:10px; margin-top:10px; }
  @media(max-width:720px){ .mq-test-grid { grid-template-columns:1fr; } }
  .mq-test-card {
    padding:12px 13px; border-radius:12px; background:rgba(255,255,255,0.025); border:1px solid rgba(255,255,255,0.06);
  }
  .mq-test-k { font-size:10px; text-transform:uppercase; letter-spacing:.08em; color:var(--color-muted); margin-bottom:5px; }
  .mq-test-v { font-size:14px; font-weight:800; color:var(--color-ink); }
  .mq-source-preset {
    margin-top:14px; padding:14px 16px; border-radius:14px;
    background:rgba(255,255,255,0.025); border:1px solid rgba(255,255,255,0.07);
  }
  .mq-source-preset-title { font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--color-muted); margin-bottom:10px; }
  .mq-source-preset-sub { font-size:12px; color:var(--color-muted); line-height:1.55; margin-top:10px; }
  .mq-lock-note { margin-top:6px; font-size:11px; color:#fcd34d; display:none; }
  .mq-lock-note.show { display:flex; align-items:flex-start; gap:6px; }
  .mq-reco-box {
    margin-top:10px; padding:12px 13px; border-radius:12px;
    border:1px solid rgba(255,255,255,0.08); background:rgba(255,255,255,0.03);
  }
  .mq-reco-title { font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; color:var(--color-muted); margin-bottom:4px; }
  .mq-reco-value { font-size:14px; font-weight:800; color:var(--color-ink); }
  .mq-reco-note { font-size:12px; color:var(--color-muted); line-height:1.55; margin-top:6px; }
  .mq-warning-box {
    margin-top:12px; padding:12px 13px; border-radius:12px;
    border:1px solid rgba(245,158,11,0.24); background:rgba(245,158,11,0.08); color:#fcd34d;
    font-size:12px; line-height:1.6;
  }
</style>

<!-- Back + Title -->
<div class="mq-topbar">
  <div>
    <a href="<%= url('/merchant-qr') %>" class="mq-back">
      <i class="fa-solid fa-arrow-left" style="font-size:11px"></i>
      Kembali ke Merchant QR
    </a>
    <h1 style="font-size:20px;font-weight:800;color:var(--color-ink);margin:6px 0 2px">
      <% if (isEdit) { %>
        Edit <span style="color:#ff7c6c"><%= account.merchantName %></span>
      <% } else { %>
        Tambah <span style="color:#ff7c6c">Merchant QR</span>
      <% } %>
    </h1>
    <p style="font-size:12px;color:var(--color-muted)">
      Merchant aktif otomatis dipakai di Generate QR, Mutasi QRIS, Utama, dan Madera
    </p>
  </div>

  <% if (isEdit) { %>
    <div class="mq-topbar-actions">
      <button type="button" class="mq-toolbar-btn blue" onclick="runMerchantAction('<%= account.id %>', 'test')">
        <i class="fa-solid fa-plug-circle-check"></i>
        Test Koneksi
      </button>
      <button type="button" class="mq-toolbar-btn green" onclick="runMerchantAction('<%= account.id %>', 'sync')">
        <i class="fa-solid fa-arrows-rotate"></i>
        Sinkronkan Sekarang
      </button>
      <div style="display:flex;align-items:center;gap:10px">
        <div style="text-align:right">
          <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--color-muted);margin-bottom:1px">Kode</p>
          <p style="font-size:18px;font-weight:900;color:var(--color-ink);font-family:monospace"><%= account.code %></p>
        </div>
        <div style="
        width:42px;height:42px;border-radius:12px;
        background:linear-gradient(135deg,rgba(255,124,108,0.2),rgba(255,124,108,0.06));
        border:1px solid rgba(255,124,108,0.25);
        display:flex;align-items:center;justify-content:center;
        ">
          <i class="fa-solid fa-store" style="color:#ffb4a8;font-size:17px"></i>
        </div>
      </div>
    </div>
  <% } %>
</div>

<% if (errors && errors._form) { %>
  <div style="padding:12px 16px;border-radius:12px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);color:#fca5a5;font-size:13px;margin-bottom:16px;display:flex;align-items:center;gap:10px">
    <i class="fa-solid fa-circle-xmark"></i>
    <span><%= errors._form[0] %></span>
  </div>
<% } %>

<% if (!isEdit) { %>
  <div class="mq-steps">
    <div class="mq-step">
      <div class="mq-step-no">1</div>
      <div class="mq-step-title">Isi Identitas</div>
      <div class="mq-step-sub">Masukkan kode, nama merchant, dan nomor akun lebih dulu.</div>
    </div>
    <div class="mq-step">
      <div class="mq-step-no">2</div>
      <div class="mq-step-title">Isi Yang Wajib</div>
      <div class="mq-step-sub">Fokus dulu ke field berlabel hijau <strong>WAJIB</strong>.</div>
    </div>
    <div class="mq-step">
      <div class="mq-step-no">3</div>
      <div class="mq-step-title">Opsional Belakangan</div>
      <div class="mq-step-sub">Field tambahan saya pindahkan belakangan supaya tidak bikin pusing.</div>
    </div>
    <div class="mq-step">
      <div class="mq-step-no">4</div>
      <div class="mq-step-title">Simpan Lalu Tes</div>
      <div class="mq-step-sub">Setelah simpan, lanjut <strong>Test Koneksi</strong> dan <strong>Sinkronkan Sekarang</strong>.</div>
    </div>
  </div>
<% } %>

<div class="mq-page-grid">
<div class="mq-main">
<form action="<%= formAction %>" method="POST">

  <!-- ══ 1. IDENTITAS MERCHANT ══════════════════════════════════════════════ -->
  <div class="mq-section">
    <div class="mq-section-hdr">
      <div class="mq-section-icon" style="background:rgba(255,124,108,0.12);color:#ffb4a8">
        <i class="fa-solid fa-store"></i>
      </div>
      <div>
        <p style="font-size:13px;font-weight:800;color:var(--color-ink);margin:0">Identitas Merchant</p>
        <p style="font-size:11px;color:var(--color-muted);margin:1px 0 0">Informasi dasar yang wajib diisi</p>
      </div>
    </div>
    <div class="mq-section-body">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <!-- Kode Merchant -->
        <div class="mq-field">
          <label class="mq-label">
            <i class="fa-solid fa-hashtag" style="font-size:10px"></i>
            Kode Merchant <span class="req">*</span>
            <span class="badge must">WAJIB</span>
          </label>
          <input type="text" name="code"
                 value="<%= isEdit ? account.code : '' %>"
                 <%= isEdit ? 'readonly' : '' %>
                 required maxlength="10" pattern="[A-Za-z0-9]+"
                 class="mq-input mono <%= isEdit ? '' : '' %> <%= hasErr('code') ? 'is-error' : '' %>"
                 placeholder="Contoh: 01WR" />
          <% if (isEdit) { %>
            <p class="mq-hint"><i class="fa-solid fa-lock"></i> Kode tidak bisa diubah setelah disimpan</p>
          <% } else { %>
            <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> Huruf & angka saja, unik per merchant</p>
          <% } %>
          <% if (hasErr('code')) { %><p class="mq-err"><%= errors.code[0] %></p><% } %>
        </div>

        <!-- Nama Merchant -->
        <div class="mq-field">
          <label class="mq-label">
            <i class="fa-solid fa-tag" style="font-size:10px"></i>
            Nama Merchant <span class="req">*</span>
            <span class="badge must">WAJIB</span>
          </label>
          <input type="text" name="merchantName"
                 value="<%= val('merchantName') %>"
                 required maxlength="100"
                 class="mq-input <%= hasErr('merchantName') ? 'is-error' : '' %>"
                 placeholder="Contoh: SOSIS BAKAR DEWI" />
          <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> Tampil di halaman mutasi dan Generate QR</p>
          <% if (hasErr('merchantName')) { %><p class="mq-err"><%= errors.merchantName[0] %></p><% } %>
        </div>

        <!-- Nomor Akun -->
        <div class="mq-field">
          <label class="mq-label">
            <i class="fa-solid fa-mobile-screen" style="font-size:10px"></i>
            Nomor HP / ID Merchant <span class="req">*</span>
            <span class="badge must">WAJIB</span>
          </label>
          <input type="text" name="accountNumber"
                 value="<%= val('accountNumber') %>"
                 required maxlength="50"
                 class="mq-input <%= hasErr('accountNumber') ? 'is-error' : '' %>"
                 placeholder="Contoh: 081779015187" />
          <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> Nomor HP atau ID akun OrderKuota</p>
          <% if (hasErr('accountNumber')) { %><p class="mq-err"><%= errors.accountNumber[0] %></p><% } %>
        </div>

      </div>
      <div class="mq-subpanel">
        <div class="mq-subpanel-title">Tambahan Opsional</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="mq-field">
            <label class="mq-label">
              <i class="fa-solid fa-gauge" style="font-size:10px"></i>
              Limit Harian (Rp)
              <span class="badge opt">opsional</span>
            </label>
            <div class="mq-input-wrap">
              <input type="number" name="dailyLimit"
                     value="<%= val('dailyLimit', 30000000) %>"
                     min="0" step="1000"
                     class="mq-input <%= hasErr('dailyLimit') ? 'is-error' : '' %>"
                     placeholder="30000000" />
              <span class="mq-suffix">Rp</span>
            </div>
            <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> Batas total transaksi per hari untuk akun ini.</p>
            <% if (hasErr('dailyLimit')) { %><p class="mq-err"><%= errors.dailyLimit[0] %></p><% } %>
          </div>

          <div class="mq-field">
            <label class="mq-label">
              <i class="fa-solid fa-arrow-down-1-9" style="font-size:10px"></i>
              Index Settlement Orkut
              <span class="badge opt">opsional</span>
            </label>
            <input type="number" name="orkutAccountIndex"
                   value="<%= isEdit && account.orkutAccountIndex ? account.orkutAccountIndex : '' %>"
                   min="1" max="999"
                   class="mq-input"
                   placeholder="Contoh: 2" />
            <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> Isi hanya jika merchant punya urutan khusus di settlement Orkut.</p>
            <% if (hasErr('orkutAccountIndex')) { %><p class="mq-err"><%= errors.orkutAccountIndex[0] %></p><% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ 2. KREDENSIAL API ══════════════════════════════════════════════════ -->
  <div class="mq-section">
    <div class="mq-section-hdr">
      <div class="mq-section-icon" style="background:rgba(245,158,11,0.12);color:#fcd34d">
        <i class="fa-solid fa-shield-halved"></i>
      </div>
      <div>
        <p style="font-size:13px;font-weight:800;color:var(--color-ink);margin:0">Kredensial API</p>
        <p style="font-size:11px;color:var(--color-muted);margin:1px 0 0">Token & device untuk koneksi ke OrderKuota</p>
      </div>
      <div style="margin-left:auto">
        <span style="font-size:10px;padding:3px 10px;border-radius:999px;background:rgba(245,158,11,0.1);color:#fcd34d;border:1px solid rgba(245,158,11,0.25);font-weight:700">
          <i class="fa-solid fa-lock" style="font-size:9px;margin-right:3px"></i>Terenkripsi
        </span>
      </div>
    </div>
    <div class="mq-section-body space-y-4">
      <div class="mq-source-preset">
        <div class="mq-source-preset-title">Preset Sumber</div>
        <div class="mq-preset-row" style="margin-bottom:0">
          <button type="button" class="mq-preset-btn" id="preset-app-btn" onclick="applySourcePreset('app')">
            <i class="fa-solid fa-mobile-screen-button"></i>
            App Only
          </button>
          <button type="button" class="mq-preset-btn" id="preset-web-btn" onclick="applySourcePreset('web')">
            <i class="fa-solid fa-globe"></i>
            Web Report Only
          </button>
          <button type="button" class="mq-preset-btn" id="preset-hybrid-btn" onclick="applySourcePreset('hybrid')">
            <i class="fa-solid fa-layer-group"></i>
            Hybrid
          </button>
        </div>
        <div id="source-recommend-box" class="mq-reco-box">
          <div class="mq-reco-title">Auto Recommend</div>
          <div id="source-recommend-value" class="mq-reco-value">Hybrid</div>
          <div id="source-recommend-note" class="mq-reco-note">Mode hybrid direkomendasikan jika field report web dan app live sama-sama tersedia.</div>
        </div>
        <p id="source-preset-sub" class="mq-source-preset-sub">Mode hybrid menyalakan report scraper dan live app API sekaligus supaya bisa dibandingkan.</p>
      </div>

      <!-- Session Token -->
      <div class="mq-field">
        <label class="mq-label">
          <i class="fa-solid fa-key" style="font-size:10px"></i>
          Session Token
          <span class="badge tip">opsional untuk app</span>
        </label>
        <div class="mq-pwd-wrap">
          <input type="password" name="sessionToken" id="fld-session" maxlength="1000"
                 class="mq-input mono"
                 placeholder="<%= isEdit ? '(kosongkan jika tidak diubah)' : 'username:accountId:tokenSecret' %>" />
          <button type="button" class="mq-pwd-toggle" onclick="togglePwd('fld-session',this)" title="Tampilkan">
            <i class="fa-solid fa-eye"></i>
          </button>
        </div>
        <div style="margin-top:6px;padding:8px 12px;border-radius:8px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06)">
          <p style="font-size:11px;color:var(--color-muted);margin:0 0 3px">
            <i class="fa-solid fa-circle-info" style="color:#93c5fd;margin-right:4px"></i>
            Format: <code style="background:rgba(255,255,255,0.08);padding:1px 6px;border-radius:4px;font-size:11px">username:accountId:tokenSecret</code>
          </p>
          <p style="font-size:11px;color:var(--color-muted);margin:0">
            Diperlukan untuk jalur app seperti generate QR live dan sebagian fitur app OrderKuota.
          </p>
        </div>
        <p id="session-lock-note" class="mq-lock-note"><i class="fa-solid fa-lock"></i><span>Field ini dikunci karena mode sekarang tidak memakai live app API.</span></p>
      </div>

      <div class="mq-subpanel" style="margin-top:16px">
        <div class="mq-subpanel-title">Field Disarankan</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <!-- Device ID -->
        <div class="mq-field">
          <label class="mq-label">
            <i class="fa-solid fa-mobile" style="font-size:10px"></i>
            Device ID
            <span class="badge tip">disarankan</span>
          </label>
          <input type="text" name="deviceId"
                 value="<%= val('deviceId') %>"
                 maxlength="100"
                 class="mq-input mono"
                 placeholder="dgxxwBi9SaSl4LrCzNbNLu" />
          <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> UUID perangkat dari header request app OrderKuota</p>
          <p id="device-lock-note" class="mq-lock-note"><i class="fa-solid fa-lock"></i><span>Field ini dikunci karena mode sekarang tidak memakai live app API.</span></p>
        </div>

        <!-- App Reg ID -->
        <div class="mq-field">
          <label class="mq-label">
            <i class="fa-solid fa-cookie-bite" style="font-size:10px"></i>
            App Reg ID
            <span class="badge tip">disarankan</span>
          </label>
          <div class="mq-pwd-wrap">
            <input type="password" name="cookies" id="fld-cookies" maxlength="5000"
                   class="mq-input mono"
                   placeholder="<%= isEdit ? '(kosongkan jika tidak diubah)' : 'app_reg_id dari app OrderKuota' %>" />
            <button type="button" class="mq-pwd-toggle" onclick="togglePwd('fld-cookies',this)" title="Tampilkan">
              <i class="fa-solid fa-eye"></i>
            </button>
          </div>
          <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> Dipakai khusus untuk app API. Jangan campur dengan cookie login web.</p>
          <p id="app-cookie-lock-note" class="mq-lock-note"><i class="fa-solid fa-lock"></i><span>Field ini dikunci karena mode sekarang tidak memakai live app API.</span></p>
        </div>

        <div class="mq-field">
          <label class="mq-label">
            <i class="fa-solid fa-lock" style="font-size:10px"></i>
            PIN Merchant
            <span class="badge must">WAJIB utk Kirim Uang</span>
          </label>
          <div class="mq-pwd-wrap">
            <input type="password" name="transferPin" id="fld-pin" maxlength="20"
                   class="mq-input mono"
                   value="<%= isEdit ? (val('transferPin') || '') : '' %>"
                   placeholder="<%= isEdit ? '(kosongkan jika tidak diubah)' : 'PIN Nobu / Madera merchant' %>" />
            <button type="button" class="mq-pwd-toggle" onclick="togglePwd('fld-pin',this)" title="Tampilkan">
              <i class="fa-solid fa-eye"></i>
            </button>
          </div>
          <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> Dipakai otomatis saat Kirim Uang dari saldo Madera, jadi kamu tidak perlu mengetik PIN lagi di halaman settlement.</p>
        </div>
        </div>
      </div>

      <div class="mq-toggle-wrap">
        <button type="button" class="mq-toggle-btn" onclick="toggleOptionalBox('hybrid-box', this)">
          <i class="fa-solid fa-layer-group"></i>
          Opsi Hybrid Web dan Lanjutan
        </button>
        <div id="hybrid-box" class="mq-toggle-box">
          <div class="mq-subpanel">
            <div class="mq-subpanel-title">Opsional Hybrid Web</div>
            <div class="grid grid-cols-1 gap-4">
              <div class="mq-field sm:col-span-2">
                <label class="mq-label">
                  <i class="fa-solid fa-paste" style="font-size:10px"></i>
                  Paste Header Mentah
                  <span class="badge tip">tempel sekali</span>
                </label>
                <textarea id="fld-raw-report-headers" rows="6" class="mq-input mono" style="resize:vertical;line-height:1.55"
                          placeholder="Paste blok mentah dari browser / HTTP Toolkit, misalnya:
Cookie: csrf_cookie_name=...; ci_session=...
Set-Cookie: csrf_cookie_name=...
User-Agent: Mozilla/5.0 ..."></textarea>
                <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> Tombol di bawah akan memecah header mentah ke <code>Web Session Cookie</code> dan <code>Web User-Agent</code>, lalu bisa langsung dites sebelum simpan.</p>
                <div class="mq-inline-actions">
                  <button type="button" class="mq-mini-btn blue" onclick="applyRawReportHeaders()">
                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                    Pecah ke Field
                  </button>
                  <button type="button" class="mq-mini-btn green" onclick="runReportLoginTest()">
                    <i class="fa-solid fa-plug-circle-check"></i>
                    Test Report Login
                  </button>
                  <button type="button" class="mq-mini-btn orange" onclick="compareSourceInputs()">
                    <i class="fa-solid fa-scale-balanced"></i>
                    Bandingkan Sumber
                  </button>
                </div>
                <p id="raw-header-lock-note" class="mq-lock-note"><i class="fa-solid fa-lock"></i><span>Field ini dikunci karena mode sekarang tidak memakai report web.</span></p>
                <div id="report-login-test-box" class="mq-report-test" aria-live="polite"></div>
                <div id="source-compare-box" class="mq-report-test" aria-live="polite"></div>
              </div>

              <div class="mq-field sm:col-span-2">
                <label class="mq-label">
                  <i class="fa-solid fa-globe" style="font-size:10px"></i>
                  Web Session Cookie
                  <span class="badge must">utama untuk report</span>
                </label>
                <div class="mq-pwd-wrap">
                  <input type="password" name="webCookies" id="fld-web-cookies" maxlength="12000"
                         class="mq-input mono <%= hasErr('webCookies') ? 'is-error' : '' %>"
                         placeholder="<%= isEdit ? '(kosongkan jika tidak diubah)' : 'boleh paste raw Cookie: / Set-Cookie: dari report.orderkuota.com' %>" />
                  <button type="button" class="mq-pwd-toggle" onclick="togglePwd('fld-web-cookies',this)" title="Tampilkan">
                    <i class="fa-solid fa-eye"></i>
                  </button>
                </div>
                <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> Dipakai Python scraper untuk <strong>https://report.orderkuota.com/mutasi_qris</strong> dan <strong>https://report.orderkuota.com/mutasi</strong>. Boleh paste header mentah <code>Cookie:</code> dan <code>Set-Cookie:</code> dari browser / HTTP Toolkit; sistem akan rapikan otomatis.</p>
                <p id="web-cookie-lock-note" class="mq-lock-note"><i class="fa-solid fa-lock"></i><span>Field ini dikunci karena mode sekarang tidak memakai report web.</span></p>
                <% if (hasErr('webCookies')) { %><p class="mq-err"><%= errors.webCookies[0] %></p><% } %>
              </div>

              <div class="mq-field sm:col-span-2">
                <label class="mq-label">
                  <i class="fa-solid fa-desktop" style="font-size:10px"></i>
                  Web User-Agent
                  <span class="badge opt">opsional hybrid</span>
                </label>
                <input type="text" name="webUserAgent"
                       value="<%= val('webUserAgent') %>"
                       maxlength="500"
                       class="mq-input mono <%= hasErr('webUserAgent') ? 'is-error' : '' %>"
                       placeholder="Mozilla/5.0 ... atau User-Agent: harywang8" />
                <p class="mq-hint"><i class="fa-solid fa-circle-info"></i> Bisa isi nilai langsung atau format <code>User-Agent: ...</code>. Jika kosong, sistem pakai User-Agent Chrome Windows default.</p>
                <p id="web-ua-lock-note" class="mq-lock-note"><i class="fa-solid fa-lock"></i><span>Field ini dikunci karena mode sekarang tidak memakai report web.</span></p>
                <% if (hasErr('webUserAgent')) { %><p class="mq-err"><%= errors.webUserAgent[0] %></p><% } %>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ══ 3. QRIS PAYLOAD ════════════════════════════════════════════════════ -->
  <div class="mq-section">
    <div class="mq-section-hdr">
      <div class="mq-section-icon" style="background:rgba(34,197,94,0.12);color:#86efac">
        <i class="fa-solid fa-qrcode"></i>
      </div>
      <div>
        <p style="font-size:13px;font-weight:800;color:var(--color-ink);margin:0">QRIS Payload</p>
        <p style="font-size:11px;color:var(--color-muted);margin:1px 0 0">String QRIS statis NOBU bank dari OrderKuota</p>
      </div>
      <span style="margin-left:auto;font-size:10px;padding:3px 10px;border-radius:999px;background:rgba(100,116,139,0.12);color:#94a3b8;border:1px solid rgba(100,116,139,0.2);font-weight:700">
        Opsional
      </span>
    </div>
    <div class="mq-section-body">
      <textarea name="qrisPayload" rows="4" maxlength="2000"
                class="mq-input mono"
                style="resize:vertical;line-height:1.6"
                placeholder="00020101021226670016COM.NOBUBANK.WWW..."><%= isEdit && account.qrisPayload ? account.qrisPayload : '' %></textarea>
      <p class="mq-hint" style="margin-top:6px">
        <i class="fa-solid fa-circle-info"></i>
        Diisi otomatis saat Generate QR berhasil. Isi manual hanya jika perlu override fallback — format harus berupa string QR NOBU (<code style="font-size:10px">COM.NOBUBANK.WWW</code>).
      </p>
    </div>
  </div>

  <!-- ══ 4. SCHEDULER SINKRONISASI ════════════════════════════════════════ -->
  <div class="mq-section">
    <div class="mq-section-hdr" style="cursor:pointer" onclick="toggleScheduler()">
      <div class="mq-section-icon" style="background:rgba(99,179,237,0.12);color:#93c5fd">
        <i class="fa-solid fa-clock"></i>
      </div>
      <div>
        <p style="font-size:13px;font-weight:800;color:var(--color-ink);margin:0">Scheduler Sinkronisasi</p>
        <p style="font-size:11px;color:var(--color-muted);margin:1px 0 0"><%= isEdit ? 'Interval polling data per tipe — klik untuk buka/tutup' : 'Opsional lanjutan — kalau belum paham, biarkan default saja' %></p>
      </div>
      <i class="fa-solid fa-chevron-down" id="sched-chev" style="margin-left:auto;font-size:11px;color:var(--color-muted);transition:transform .25s"></i>
    </div>

    <div id="sched-body" style="display:none">
      <div style="padding:12px 20px 0;font-size:11px;color:var(--color-muted);display:flex;align-items:flex-start;gap:6px;border-bottom:1px solid rgba(255,255,255,0.05)">
        <i class="fa-solid fa-circle-info" style="color:#93c5fd;margin-top:1px;flex-shrink:0"></i>
        <span>Interval dalam <strong>detik</strong>. Yang aktif sekarang hanya watcher saldo QRIS, fallback sinkron mutasi, dan RRN detail. Polling mutasi penuh/idle lama sudah dimatikan.</span>
      </div>
      <div class="mq-section-body">
        <div class="mq-preset-row">
          <button type="button" class="mq-preset-btn" onclick="applySchedulerPreset('standby-safe')">
            <i class="fa-solid fa-robot"></i>
            Standby Aman
          </button>
          <button type="button" class="mq-preset-btn" onclick="applySchedulerPreset('standby-normal')">
            <i class="fa-solid fa-sliders"></i>
            Standby Normal
          </button>
          <button type="button" class="mq-preset-btn" onclick="applySchedulerPreset('standby-relaxed')">
            <i class="fa-solid fa-bolt"></i>
            Standby Santai
          </button>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4" style="margin-bottom:16px">
          <div class="mq-poll-card" style="grid-column:1 / -1">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
              <span style="width:30px;height:30px;border-radius:10px;background:rgba(16,185,129,0.14);color:#86efac;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0">
                <i class="fa-solid fa-robot"></i>
              </span>
              <div>
                <p class="mq-poll-title">Python Balance Standby</p>
                <p class="mq-poll-sub" style="margin-bottom:0">Mode ini aktif otomatis untuk semua merchant. Sistem cek saldo QRIS ringan, lalu hanya menarik mutasi baru setelah mutasi terakhir yang sudah tersimpan.</p>
              </div>
            </div>
            <p class="mq-hint">
              <i class="fa-solid fa-circle-info"></i>
              Refresh saldo sekarang dipisah per menu: QRIS saat buka <strong>Mutasi QRIS</strong>, saldo utama saat buka <strong>Mutasi Utama</strong>, dan saldo Madera saat buka <strong>Mutasi Madera</strong> atau klik akun di <strong>Settlement</strong>. Tidak ada lagi fallback sync mutasi berkala.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

          <div class="mq-poll-card">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
              <span style="width:28px;height:28px;border-radius:8px;background:rgba(16,185,129,0.12);color:#6ee7b7;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0">
                <i class="fa-solid fa-heart-pulse"></i>
              </span>
              <div>
                <p class="mq-poll-title">Watcher Saldo Aktif</p>
                <p class="mq-poll-sub" style="margin-bottom:0">Cek saldo QRIS ringan setiap 1-2 detik</p>
              </div>
            </div>
            <div class="mq-input-wrap">
              <input type="number" name="balanceWatchActiveSeconds"
                     value="<%= val('balanceWatchActiveSeconds', 2) %>"
                     min="1" max="10"
                     class="mq-input" placeholder="2" />
              <span class="mq-suffix">dtk</span>
            </div>
            <p class="mq-hint"><i class="fa-solid fa-satellite-dish"></i> Begitu saldo berubah, Python mengejar mutasi baru saja dari mutasi terakhir, bukan menarik sejarah penuh.</p>
            <% if (hasErr('balanceWatchActiveSeconds')) { %><p class="mq-err"><%= errors.balanceWatchActiveSeconds[0] %></p><% } %>
          </div>

          <div class="mq-poll-card">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
              <span style="width:28px;height:28px;border-radius:8px;background:rgba(168,85,247,0.12);color:#d8b4fe;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0">
                <i class="fa-solid fa-fingerprint"></i>
              </span>
              <div>
                <p class="mq-poll-title">RRN Detail</p>
                <p class="mq-poll-sub" style="margin-bottom:0">Enrichment detail QRIS di background</p>
              </div>
            </div>
            <div class="mq-input-wrap">
              <input type="number" name="detailPollSeconds"
                     value="<%= val('detailPollSeconds', 20) %>"
                     min="15" max="120"
                     class="mq-input" placeholder="20" />
              <span class="mq-suffix">dtk</span>
            </div>
            <% if (hasErr('detailPollSeconds')) { %><p class="mq-err"><%= errors.detailPollSeconds[0] %></p><% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ 5. SALDO TERAKHIR (edit only) ══════════════════════════════════════ -->
  <% if (isEdit && (account.lastBalanceSyncAt || account.lastMainBalance != null || account.lastQrisBalance != null || account.lastMaderaBalance != null)) { %>
  <div class="mq-section">
    <div class="mq-section-hdr">
      <div class="mq-section-icon" style="background:rgba(16,185,129,0.1);color:#6ee7b7">
        <i class="fa-solid fa-wave-square"></i>
      </div>
      <div>
        <p style="font-size:13px;font-weight:800;color:var(--color-ink);margin:0">Saldo Terakhir</p>
        <p style="font-size:11px;color:var(--color-muted);margin:1px 0 0">
          Sync:
          <%= account.lastBalanceSyncAt ? new Date(account.lastBalanceSyncAt).toLocaleString('id-ID', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit', second:'2-digit', timeZone:'Asia/Jakarta' }) : '—' %>
          <% if (account.lastBalanceSyncStatus) { %>
            · <span style="color:<%= account.lastBalanceSyncStatus === 'synced' ? '#86efac' : '#fcd34d' %>">
              <%= account.lastBalanceSyncStatus %>
            </span>
          <% } %>
        </p>
      </div>
    </div>
    <div class="mq-section-body">
      <div class="grid grid-cols-3 gap-3">
        <div class="mq-bal-card">
          <p class="mq-bal-label">Saldo Utama</p>
          <p class="mq-bal-val" style="color:#60a5fa">Rp <%= (account.lastMainBalance ?? 0).toLocaleString('id-ID') %></p>
        </div>
        <div class="mq-bal-card">
          <p class="mq-bal-label">Saldo QRIS</p>
          <p class="mq-bal-val" style="color:#4ade80">Rp <%= (account.lastQrisBalance ?? 0).toLocaleString('id-ID') %></p>
        </div>
        <div class="mq-bal-card">
          <p class="mq-bal-label">Saldo Madera</p>
          <p class="mq-bal-val" style="color:#fb923c">Rp <%= (account.lastMaderaBalance ?? 0).toLocaleString('id-ID') %></p>
        </div>
      </div>
      <% if (account.lastBalanceSyncError) { %>
        <p style="margin-top:8px;font-size:11px;color:#fca5a5;display:flex;align-items:center;gap:5px">
          <i class="fa-solid fa-triangle-exclamation"></i> <%= account.lastBalanceSyncError %>
        </p>
      <% } %>
    </div>
  </div>
  <% } %>

  <!-- ══ Submit Bar ════════════════════════════════════════════════════════ -->
  <div style="
    position:sticky;bottom:16px;z-index:10;
    padding:14px 20px;border-radius:14px;
    background:rgba(15,17,25,0.9);
    border:1px solid rgba(255,255,255,0.1);
