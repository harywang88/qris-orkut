<div id="merchant-action-modal" class="mq-action-modal" aria-hidden="true">
  <div class="mq-action-card">
    <div class="mq-action-head">
      <div>
        <h3 id="merchant-action-title" class="mq-action-title">Merchant QR</h3>
        <p id="merchant-action-sub" class="mq-action-sub">Memproses permintaan...</p>
      </div>
      <button type="button" class="mq-close-btn" onclick="closeMerchantActionModal()">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <div id="merchant-action-body" class="mq-action-body">
      <div class="mq-result-hero">Menyiapkan hasil...</div>
    </div>
  </div>
</div>

<script>
  // Show/hide password
  window.togglePwd = function(id, btn) {
    const inp = document.getElementById(id);
    if (!inp) return;
    const isHidden = inp.type === 'password';
    inp.type = isHidden ? 'text' : 'password';
    btn.innerHTML = isHidden
      ? '<i class="fa-solid fa-eye-slash"></i>'
      : '<i class="fa-solid fa-eye"></i>';
  };

  // Toggle scheduler section
  window.toggleScheduler = function() {
    const body = document.getElementById('sched-body');
    const chev = document.getElementById('sched-chev');
    const open = body.style.display === 'none';
    body.style.display = open ? '' : 'none';
    chev.style.transform = open ? 'rotate(180deg)' : '';
  };

  window.applySchedulerPreset = function(type) {
    const presets = {
      'standby-safe': {
        balanceWatchActiveSeconds: 2,
        detailPollSeconds: 20,
      },
      'standby-normal': {
        balanceWatchActiveSeconds: 3,
        detailPollSeconds: 20,
      },
      'standby-relaxed': {
        balanceWatchActiveSeconds: 4,
        detailPollSeconds: 20,
      },
    };
    const preset = presets[type];
    if (!preset) return;
    Object.entries(preset).forEach(([name, value]) => {
      const field = document.querySelector(`[name="${name}"]`);
      if (field) field.value = value;
    });
    const body = document.getElementById('sched-body');
    const chev = document.getElementById('sched-chev');
    if (body && body.style.display === 'none') {
      body.style.display = '';
      chev.style.transform = 'rotate(180deg)';
    }
  };

  window.toggleOptionalBox = function(id, btn) {
    const box = document.getElementById(id);
    if (!box) return;
    box.classList.toggle('open');
    const icon = btn ? btn.querySelector('i') : null;
    if (icon) {
      icon.className = box.classList.contains('open')
        ? 'fa-solid fa-chevron-up'
        : 'fa-solid fa-layer-group';
    }
  };

  function openMerchantActionModal(title, subtitle, bodyHtml) {
    document.getElementById('merchant-action-title').textContent = title;
    document.getElementById('merchant-action-sub').textContent = subtitle;
    document.getElementById('merchant-action-body').innerHTML = bodyHtml;
    document.getElementById('merchant-action-modal').classList.add('open');
  }

  function closeMerchantActionModal() {
    document.getElementById('merchant-action-modal').classList.remove('open');
  }

  function renderMerchantReport(report, modeLabel) {
    const readiness = report.readiness || {};
    const stats = report.stats || {};
    const checks = Array.isArray(report.checks) ? report.checks : [];
    const cards = [
      { key: 'Generate', value: readiness.generateReady ? 'Siap' : 'Belum', color: readiness.generateReady ? '#86efac' : '#fcd34d' },
      { key: 'Mutasi', value: readiness.mutationReady ? 'Siap' : 'Belum', color: readiness.mutationReady ? '#86efac' : '#fcd34d' },
      { key: 'Mode', value: modeLabel, color: '#93c5fd' },
      { key: 'Mutasi Baru', value: String((stats.newQrisMutations ?? 0) + (stats.newUtamaMutations ?? 0)), color: '#ffb4a8' },
    ];

    return `
      <div class="mq-result-hero">
        <strong>${report.account.code} · ${report.account.merchantName}</strong><br>
        ${report.message || 'Tidak ada pesan tambahan.'}
      </div>
      <div class="mq-result-grid">
        ${cards.map((card) => `
          <div class="mq-result-card">
            <div class="mq-result-k">${card.key}</div>
            <div class="mq-result-v" style="color:${card.color}">${card.value}</div>
          </div>
        `).join('')}
      </div>
      ${stats.mainBalance != null || stats.qrisBalance != null || stats.maderaBalance != null ? `
        <div class="mq-result-grid" style="margin-top:-2px">
          <div class="mq-result-card"><div class="mq-result-k">Saldo Utama</div><div class="mq-result-v">Rp ${(stats.mainBalance ?? 0).toLocaleString('id-ID')}</div></div>
          <div class="mq-result-card"><div class="mq-result-k">Saldo QRIS</div><div class="mq-result-v">Rp ${(stats.qrisBalance ?? 0).toLocaleString('id-ID')}</div></div>
          <div class="mq-result-card"><div class="mq-result-k">Saldo Madera</div><div class="mq-result-v">Rp ${(stats.maderaBalance ?? 0).toLocaleString('id-ID')}</div></div>
          <div class="mq-result-card"><div class="mq-result-k">Match</div><div class="mq-result-v">${stats.matchedTransactions ?? 0}</div></div>
        </div>
      ` : ''}
      <div class="mq-result-checks">
        ${checks.map((check) => `
          <div class="mq-result-check ${check.ok ? 'ok' : 'bad'}">
            <div class="mq-result-icon"><i class="fa-solid ${check.ok ? 'fa-check' : 'fa-triangle-exclamation'}"></i></div>
            <div>
              <div class="mq-result-check-title">${check.label}</div>
              <div class="mq-result-check-detail">${check.detail}</div>
            </div>
          </div>
        `).join('')}
      </div>
    `;
  }

  window.runMerchantAction = async function(id, action) {
    const isSync = action === 'sync';
    openMerchantActionModal(
      isSync ? 'Sinkronkan Merchant' : 'Test Koneksi Merchant',
      isSync ? 'Menarik data terbaru dari OrderKuota...' : 'Mengecek token, payload, dan jalur mutasi...',
      '<div class="mq-result-hero">Sedang memproses. Mohon tunggu sebentar...</div>'
    );

    try {
      const res = await fetch(`<%= url('/merchant-qr') %>/${id}/${isSync ? 'sync-now' : 'test-connection'}`, {
        method: 'POST',
        headers: { 'Accept': 'application/json' }
      });
      const data = await res.json();
      if (!res.ok || !data.success) {
        openMerchantActionModal(
          isSync ? 'Sinkron Gagal' : 'Test Gagal',
          'Permintaan belum berhasil dijalankan',
          `<div class="mq-result-hero">${data.error || 'Terjadi kesalahan yang tidak diketahui.'}</div>`
        );
        return;
      }

      const report = data.report;
      const modeMap = {
        app: 'App API',
        web: 'Cookie/Web',
        'payload-only': 'Payload Only',
        unconfigured: 'Belum Lengkap',
      };

      openMerchantActionModal(
        isSync ? 'Sinkron Selesai' : 'Test Koneksi Selesai',
        'Hasil pemeriksaan merchant terbaru',
        renderMerchantReport(report, modeMap[report.mode] || report.mode)
      );
    } catch (err) {
      openMerchantActionModal(
        isSync ? 'Sinkron Gagal' : 'Test Gagal',
        'Permintaan belum berhasil dijalankan',
        `<div class="mq-result-hero">${err?.message || 'Terjadi kesalahan jaringan.'}</div>`
      );
    }
  };

  function parseRawReportHeaders(raw) {
    const text = String(raw || '').replace(/\r/g, '').trim();
    if (!text) return { cookie: '', userAgent: '' };

    const cookieLines = [];
    let userAgent = '';
    let mode = '';
    text.split('\n').forEach((sourceLine) => {
      const line = sourceLine.trim();
      if (!line) return;
      const cookieMatch = line.match(/^cookie\s*:\s*(.*)$/i);
      if (cookieMatch) {
        mode = 'cookie';
        if (cookieMatch[1]) cookieLines.push(cookieMatch[1].trim());
        return;
      }
      const setCookieMatch = line.match(/^set-cookie\s*:\s*(.*)$/i);
      if (setCookieMatch) {
        mode = 'set-cookie';
        if (setCookieMatch[1]) cookieLines.push(setCookieMatch[1].trim());
        return;
      }
      const userAgentMatch = line.match(/^user-agent\s*:\s*(.*)$/i);
      if (userAgentMatch) {
        userAgent = userAgentMatch[1].trim();
        mode = '';
        return;
      }
      if (/^[a-z-]+\s*:/i.test(line)) {
        mode = '';
        return;
      }
      if (mode === 'cookie' || mode === 'set-cookie') {
        cookieLines.push(line);
      }
    });

    return {
      cookie: cookieLines.join('\n').trim(),
      userAgent,
    };
  }

  function renderReportLoginResult(payload) {
    const report = payload?.report || payload;
    const badges = Array.isArray(report?.badges) ? report.badges : [];
    const preview = report?.preview || {};
    const detectedPattern = report?.detectedPattern || {};
    const box = document.getElementById('report-login-test-box');
    if (!box) return;

    box.classList.add('open');
    box.innerHTML = `
      <div style="font-size:13px;font-weight:800;color:var(--color-ink)">${report?.success ? 'Report login valid' : 'Report login belum valid'}</div>
      <div style="font-size:12px;color:var(--color-muted);margin-top:4px;line-height:1.6">${report?.message || 'Tidak ada pesan.'}</div>
      <div class="mq-badge-row">
        ${badges.map((badge) => `
          <div class="mq-test-badge ${badge.ok ? 'ok' : 'bad'}" title="${badge.detail || ''}">
            <i class="fa-solid ${badge.ok ? 'fa-circle-check' : 'fa-circle-xmark'}"></i>
            <span>${badge.label}</span>
          </div>
        `).join('')}
      </div>
      <div class="mq-test-grid">
        <div class="mq-test-card"><div class="mq-test-k">Nama Akun Report</div><div class="mq-test-v">${preview.accountName || '-'}</div></div>
        <div class="mq-test-card"><div class="mq-test-k">Saldo Utama</div><div class="mq-test-v">${preview.mainBalance != null ? `Rp ${Number(preview.mainBalance).toLocaleString('id-ID')}` : '-'}</div></div>
        <div class="mq-test-card"><div class="mq-test-k">Saldo QRIS</div><div class="mq-test-v">${preview.qrisBalance != null ? `Rp ${Number(preview.qrisBalance).toLocaleString('id-ID')}` : '-'}</div></div>
        <div class="mq-test-card"><div class="mq-test-k">Baris Terbaca</div><div class="mq-test-v">QRIS ${preview.qrisCount ?? 0} · Utama ${preview.utamaCount ?? 0}</div></div>
        <div class="mq-test-card"><div class="mq-test-k">Halaman Report</div><div class="mq-test-v">QRIS ${preview.qrisPagesRead ?? '-'} · Utama ${preview.utamaPagesRead ?? '-'}</div></div>
        <div class="mq-test-card"><div class="mq-test-k">Detected Pattern</div><div class="mq-test-v">QRIS: ${detectedPattern.qris || '-'}<br>Utama: ${detectedPattern.utama || '-'}</div></div>
      </div>
    `;
  }

  function renderSourceComparisonResult(payload) {
    const report = payload?.report || {};
    const sourceReport = report.report || {};
    const live = report.live || {};
    const delta = report.delta || {};
    const box = document.getElementById('source-compare-box');
    if (!box) return;
    const warnings = [];
    const absMainDiff = delta.mainBalanceDiff != null ? Math.abs(Number(delta.mainBalanceDiff)) : null;
    const absQrisDiff = delta.qrisBalanceDiff != null ? Math.abs(Number(delta.qrisBalanceDiff)) : null;
    const absQrisCountDiff = delta.qrisCountDiff != null ? Math.abs(Number(delta.qrisCountDiff)) : null;
    const absUtamaCountDiff = delta.utamaCountDiff != null ? Math.abs(Number(delta.utamaCountDiff)) : null;
    if (absMainDiff != null && absMainDiff >= 1000) {
      warnings.push(`Saldo utama berbeda cukup besar: Rp ${absMainDiff.toLocaleString('id-ID')}.`);
    }
    if (absQrisDiff != null && absQrisDiff >= 1000) {
      warnings.push(`Saldo QRIS berbeda cukup besar: Rp ${absQrisDiff.toLocaleString('id-ID')}.`);
    }
    if (absQrisCountDiff != null && absQrisCountDiff >= 2) {
      warnings.push(`Jumlah baris mutasi QRIS berbeda ${absQrisCountDiff} data.`);
    }
    if (absUtamaCountDiff != null && absUtamaCountDiff >= 2) {
      warnings.push(`Jumlah baris mutasi utama berbeda ${absUtamaCountDiff} data.`);
    }

    box.classList.add('open');
    box.innerHTML = `
      <div style="font-size:13px;font-weight:800;color:var(--color-ink)">Perbandingan Source: ${report.mode || '-'}</div>
      <div style="font-size:12px;color:var(--color-muted);margin-top:4px;line-height:1.6">${report.message || 'Tidak ada pesan.'}</div>
      ${warnings.length ? `
        <div class="mq-warning-box">
          <strong>Warning selisih besar</strong><br>
          ${warnings.join('<br>')}
        </div>
      ` : ''}
      <div class="mq-test-grid" style="margin-top:12px">
        <div class="mq-test-card">
          <div class="mq-test-k">Report Scraper</div>
          <div class="mq-test-v">${sourceReport.ok ? 'Siap' : 'Belum siap'}</div>
          <div style="font-size:12px;color:var(--color-muted);margin-top:8px;line-height:1.55">
            Akun: ${sourceReport.accountName || '-'}<br>
            QRIS: ${sourceReport.qrisCount ?? 0} baris<br>
            Utama: ${sourceReport.utamaCount ?? 0} baris
          </div>
        </div>
        <div class="mq-test-card">
          <div class="mq-test-k">Live App API</div>
          <div class="mq-test-v">${live.ok ? 'Siap' : 'Belum siap'}</div>
          <div style="font-size:12px;color:var(--color-muted);margin-top:8px;line-height:1.55">
            QRIS: ${live.qrisCount ?? 0} baris<br>
            Utama: ${live.utamaCount ?? 0} baris<br>
            Session: ${document.getElementById('fld-session')?.value ? 'Terisi' : 'Kosong'}
          </div>
        </div>
        <div class="mq-test-card">
          <div class="mq-test-k">Saldo</div>
          <div style="font-size:12px;color:var(--color-muted);line-height:1.7">
            Report utama: ${sourceReport.mainBalance != null ? `Rp ${Number(sourceReport.mainBalance).toLocaleString('id-ID')}` : '-'}<br>
            Live utama: ${live.mainBalance != null ? `Rp ${Number(live.mainBalance).toLocaleString('id-ID')}` : '-'}<br>
            Report QRIS: ${sourceReport.qrisBalance != null ? `Rp ${Number(sourceReport.qrisBalance).toLocaleString('id-ID')}` : '-'}<br>
            Live QRIS: ${live.qrisBalance != null ? `Rp ${Number(live.qrisBalance).toLocaleString('id-ID')}` : '-'}
          </div>
        </div>
        <div class="mq-test-card">
          <div class="mq-test-k">Delta</div>
          <div style="font-size:12px;color:var(--color-muted);line-height:1.7">
            Selisih utama: ${delta.mainBalanceDiff != null ? `Rp ${Number(delta.mainBalanceDiff).toLocaleString('id-ID')}` : '-'}<br>
            Selisih QRIS: ${delta.qrisBalanceDiff != null ? `Rp ${Number(delta.qrisBalanceDiff).toLocaleString('id-ID')}` : '-'}<br>
            Selisih count QRIS: ${delta.qrisCountDiff ?? '-'}<br>
            Selisih count utama: ${delta.utamaCountDiff ?? '-'}
          </div>
        </div>
      </div>
    `;
  }

  function setFieldLocked(selector, locked, noteId) {
    const field = typeof selector === 'string' ? document.querySelector(selector) : selector;
    if (!field) return;
    field.disabled = locked;
    field.readOnly = locked;
    field.style.opacity = locked ? '.6' : '';
    const note = noteId ? document.getElementById(noteId) : null;
    if (note) note.classList.toggle('show', locked);
  }

  function refreshSourcePresetVisual(mode) {
    const labels = {
      app: 'Mode app only mengunci field report web dan fokus ke session token, app_reg_id, dan device ID.',
      web: 'Mode web report only mengunci field app live dan fokus ke cookie report serta User-Agent.',
      hybrid: 'Mode hybrid menyalakan report scraper dan live app API sekaligus supaya bisa dibandingkan.',
    };
    const sub = document.getElementById('source-preset-sub');
    if (sub) sub.textContent = labels[mode] || labels.hybrid;
    ['app', 'web', 'hybrid'].forEach((key) => {
      const btn = document.getElementById(`preset-${key}-btn`);
      if (!btn) return;
      btn.style.background = key === mode ? 'rgba(255,255,255,0.1)' : 'rgba(255,255,255,0.04)';
      btn.style.borderColor = key === mode ? 'rgba(255,255,255,0.18)' : 'rgba(255,255,255,0.08)';
    });
  }

  function getFieldState() {
    return {
      hasSession: Boolean(document.getElementById('fld-session')?.value.trim()),
      hasAppCookie: Boolean(document.getElementById('fld-cookies')?.value.trim()),
      hasDevice: Boolean(document.querySelector('[name="deviceId"]')?.value.trim()),
      hasWebCookie: Boolean(document.getElementById('fld-web-cookies')?.value.trim()),
      hasRawHeader: Boolean(document.getElementById('fld-raw-report-headers')?.value.trim()),
      hasWebUA: Boolean(document.querySelector('[name="webUserAgent"]')?.value.trim()),
    };
  }

  function getRecommendedSourceMode() {
    const state = getFieldState();
    const hasAppCore = state.hasSession;
    const hasAppSupport = state.hasAppCookie || state.hasDevice;
    const hasWebCore = state.hasWebCookie || state.hasRawHeader;
    const hasWebSupport = state.hasWebUA;

    if (hasAppCore && hasWebCore) {
      return {
        mode: 'hybrid',
        note: 'Session token dan cookie report sama-sama tersedia. Hybrid paling bernilai karena bisa membandingkan scraping dengan live app API.',
      };
    }
    if (hasWebCore && !hasAppCore) {
      return {
        mode: 'web',
        note: hasWebSupport
          ? 'Cookie report siap dipakai. Web Report Only paling aman untuk sinkron mutasi dari report.'
          : 'Cookie report sudah ada. Tambahkan User-Agent jika perlu, tetapi mode Web Report Only sudah paling cocok.',
      };
    }
    if (hasAppCore && !hasWebCore) {
      return {
        mode: 'app',
        note: hasAppSupport
          ? 'Kredensial app live sudah cukup. App Only direkomendasikan sampai cookie report ditambahkan.'
          : 'Session token sudah ada, tetapi App Reg ID atau Device ID masih layak dilengkapi supaya jalur live lebih stabil.',
      };
    }
    return {
      mode: 'hybrid',
      note: 'Belum ada kredensial yang cukup dominan. Mulai dari mode yang Anda butuhkan, lalu form akan menyesuaikan otomatis.',
    };
  }

  function updateSourceRecommendation(activeMode) {
    const recommended = getRecommendedSourceMode();
    const valueEl = document.getElementById('source-recommend-value');
    const noteEl = document.getElementById('source-recommend-note');
    if (valueEl) {
      const labelMap = { app: 'App Only', web: 'Web Report Only', hybrid: 'Hybrid' };
      valueEl.textContent = `${labelMap[recommended.mode] || recommended.mode}${activeMode && activeMode !== recommended.mode ? ` · aktif: ${labelMap[activeMode] || activeMode}` : ''}`;
      valueEl.style.color = recommended.mode === activeMode ? 'var(--color-ink)' : '#fcd34d';
    }
    if (noteEl) {
      noteEl.textContent = recommended.note;
    }
  }

  window.applySourcePreset = function(type) {
    const mode = type === 'app' || type === 'web' ? type : 'hybrid';
    const rawField = document.getElementById('fld-raw-report-headers');
    const sessionField = document.getElementById('fld-session');
    const appCookieField = document.getElementById('fld-cookies');
    const deviceField = document.querySelector('[name="deviceId"]');
    const webCookieField = document.getElementById('fld-web-cookies');
    const userAgentField = document.querySelector('[name="webUserAgent"]');

    const lockApp = mode === 'web';
    const lockWeb = mode === 'app';

    setFieldLocked(sessionField, lockApp, 'session-lock-note');
    setFieldLocked(appCookieField, lockApp, 'app-cookie-lock-note');
    setFieldLocked(deviceField, lockApp, 'device-lock-note');
    setFieldLocked(rawField, lockWeb, 'raw-header-lock-note');
    setFieldLocked(webCookieField, lockWeb, 'web-cookie-lock-note');
    setFieldLocked(userAgentField, lockWeb, 'web-ua-lock-note');

    if (lockApp) {
      if (sessionField && !sessionField.value) sessionField.placeholder = 'dikunci karena mode web report only';
      if (appCookieField && !appCookieField.value) appCookieField.placeholder = 'dikunci karena mode web report only';
    }
    if (lockWeb) {
      if (webCookieField && !webCookieField.value) webCookieField.placeholder = 'dikunci karena mode app only';
    }

    refreshSourcePresetVisual(mode);
    updateSourceRecommendation(mode);
    if (mode !== 'app') document.getElementById('hybrid-box')?.classList.add('open');
    if (mode === 'web' && webCookieField) webCookieField.focus();
    if (mode === 'app' && sessionField) sessionField.focus();
    window.__merchantSourcePreset = mode;
  };

  window.applyRawReportHeaders = function() {
    const rawField = document.getElementById('fld-raw-report-headers');
    const webCookieField = document.getElementById('fld-web-cookies');
    const userAgentField = document.querySelector('[name="webUserAgent"]');
    if (!rawField || !webCookieField || !userAgentField) return;
    const parsed = parseRawReportHeaders(rawField.value);
    if (parsed.cookie) webCookieField.value = parsed.cookie;
    if (parsed.userAgent && !userAgentField.value) userAgentField.value = parsed.userAgent;
    document.getElementById('hybrid-box')?.classList.add('open');
    updateSourceRecommendation(window.__merchantSourcePreset || 'hybrid');
  };

  window.runReportLoginTest = async function() {
    const rawField = document.getElementById('fld-raw-report-headers');
    const webCookieField = document.getElementById('fld-web-cookies');
    const userAgentField = document.querySelector('[name="webUserAgent"]');
    const box = document.getElementById('report-login-test-box');
    if (!rawField || !webCookieField || !userAgentField || !box) return;

    const parsed = parseRawReportHeaders(rawField.value);
    if (parsed.cookie && !webCookieField.value) webCookieField.value = parsed.cookie;
    if (parsed.userAgent && !userAgentField.value) userAgentField.value = parsed.userAgent;

    box.classList.add('open');
    box.innerHTML = '<div style="font-size:12px;color:var(--color-muted)">Sedang mengetes login report dan membaca preview mutasi...</div>';

    try {
      const res = await fetch('<%= url('/merchant-qr/test-report-login') %>', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
        body: JSON.stringify({
          rawHeaders: rawField.value,
          webCookies: webCookieField.value,
          webUserAgent: userAgentField.value,
        }),
      });
      const data = await res.json();
      if (!data?.report) {
        box.innerHTML = `<div style="font-size:12px;color:#fca5a5">${data?.error || 'Test report gagal.'}</div>`;
        return;
      }
      if (data.report.normalized?.cookie && !webCookieField.value) webCookieField.value = data.report.normalized.cookie;
      if (data.report.normalized?.userAgent && !userAgentField.value) userAgentField.value = data.report.normalized.userAgent;
      renderReportLoginResult(data);
    } catch (err) {
      box.innerHTML = `<div style="font-size:12px;color:#fca5a5">${err?.message || 'Gagal menghubungi server untuk test report.'}</div>`;
    }
  };

  window.compareSourceInputs = async function() {
    const rawField = document.getElementById('fld-raw-report-headers');
    const webCookieField = document.getElementById('fld-web-cookies');
    const userAgentField = document.querySelector('[name="webUserAgent"]');
    const sessionField = document.getElementById('fld-session');
    const appCookieField = document.getElementById('fld-cookies');
    const deviceField = document.querySelector('[name="deviceId"]');
    const box = document.getElementById('source-compare-box');
    if (!rawField || !webCookieField || !userAgentField || !sessionField || !appCookieField || !deviceField || !box) return;

    const parsed = parseRawReportHeaders(rawField.value);
    if (parsed.cookie && !webCookieField.value) webCookieField.value = parsed.cookie;
    if (parsed.userAgent && !userAgentField.value) userAgentField.value = parsed.userAgent;

    box.classList.add('open');
    box.innerHTML = '<div style="font-size:12px;color:var(--color-muted)">Sedang membandingkan report scraper dengan live app API...</div>';

    try {
      const res = await fetch('<%= url('/merchant-qr/compare-sources') %>', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
        body: JSON.stringify({
          rawHeaders: rawField.value,
          webCookies: webCookieField.value,
          webUserAgent: userAgentField.value,
          sessionToken: sessionField.value,
          cookies: appCookieField.value,
          deviceId: deviceField.value,
        }),
      });
      const data = await res.json();
      if (!data?.report) {
        box.innerHTML = `<div style="font-size:12px;color:#fca5a5">${data?.error || 'Perbandingan source gagal.'}</div>`;
        return;
      }
      renderSourceComparisonResult(data);
    } catch (err) {
      box.innerHTML = `<div style="font-size:12px;color:#fca5a5">${err?.message || 'Gagal menghubungi server untuk perbandingan source.'}</div>`;
    }
  };

  (function initSourcePreset() {
    [
      '#fld-session',
      '#fld-cookies',
      '[name="deviceId"]',
      '#fld-web-cookies',
      '#fld-raw-report-headers',
      '[name="webUserAgent"]',
    ].forEach((selector) => {
      const field = document.querySelector(selector);
      if (field) {
        field.addEventListener('input', () => {
          updateSourceRecommendation(window.__merchantSourcePreset || 'hybrid');
        });
      }
    });
    const hasApp = Boolean(document.getElementById('fld-session')?.value || document.getElementById('fld-cookies')?.value || document.querySelector('[name="deviceId"]')?.value);
    const hasWeb = Boolean(document.getElementById('fld-web-cookies')?.value || document.querySelector('[name="webUserAgent"]')?.value);
    const initialMode = hasApp && hasWeb ? 'hybrid' : hasWeb ? 'web' : hasApp ? 'app' : 'hybrid';
    window.applySourcePreset(initialMode);
  })();
</script>
