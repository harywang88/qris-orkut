  // Siarkan perubahan status ke tab/halaman lain (via localStorage storage event)
  function broadcastAcctStatus(id, status) {
    try { localStorage.setItem(ACCT_SYNC_KEY, JSON.stringify({ id: id, status: status, ts: Date.now() })); } catch (e) {}
  }

  async function toggleSettlementAccount(id, checked) {
    applySettlementToggle(id, checked); // optimistic
    try {
      const resp = await fetch(MQR_BASE + '/' + id + '/toggle-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await resp.json().catch(() => null);
      if (!resp.ok || !data || !data.success) throw new Error((data && data.error) || 'Gagal');
      const active = data.status === 'active';
      applySettlementToggle(id, active); // reconcile with server truth
      broadcastAcctStatus(id, active ? 'active' : 'inactive');
    } catch (e) {
      applySettlementToggle(id, !checked); // revert
      if (window.Swal) {
        Swal.fire({ icon: 'error', title: 'Gagal', text: 'Gagal mengubah status akun.', background: 'var(--card)', color: 'var(--ink)' });
      } else {
        alert('Gagal mengubah status akun.');
      }
    }
  }
  window.toggleSettlementAccount = toggleSettlementAccount;

  // Sinkron lintas-tab: dengar perubahan status dari tab/halaman lain
