  // Baca saldo LIVE dari node alur estafet (data-field), bukan snapshot lama
  function readLiveBal(field, id) {
    const el = document.querySelector('[data-field="' + field + '"][data-id="' + id + '"]');
    return el ? (parseMoney(el.textContent) || 0) : 0;
  }

  function setlBulkProgress(title, jobs) {
    const ov = document.createElement('div');
    ov.className = 'setl-progress-overlay';
    const rowsHtml = jobs.map((j) =>
      '<div class="setl-bulkp-row" data-id="' + j.id + '">' +
        '<span class="setl-bulkp-dot"></span>' +
        '<span class="setl-bulkp-name">' + escP(j.name) + '</span>' +
        '<span class="setl-bulkp-amt">' + rp(j.amount) + '</span>' +
        '<span class="setl-bulkp-msg"></span>' +
      '</div>'
    ).join('');
    ov.innerHTML =
      '<div class="setl-progress-card setl-bulkp-card" role="dialog" aria-modal="true">' +
        '<div class="setl-progress-spinner" id="bp-ico"><i class="fa-solid fa-layer-group"></i></div>' +
        '<div class="setl-progress-title">' + escP(title) + '</div>' +
        '<div class="setl-progress-sub" id="bp-sub">Memproses ' + jobs.length + ' akun…</div>' +
        '<div class="setl-bulkp-list">' + rowsHtml + '</div>' +
        '<div class="setl-progress-result" id="bp-result" style="display:none"></div>' +
        '<button class="setl-progress-close" id="bp-close" style="display:none">Tutup</button>' +
      '</div>';
    document.body.appendChild(ov);
    requestAnimationFrame(() => ov.classList.add('open'));
    const rowEl = (id) => ov.querySelector('.setl-bulkp-row[data-id="' + id + '"]');
    return {
      setRow(id, state, msg) {
        const el = rowEl(id); if (!el) return;
        el.classList.remove('run', 'ok', 'fail'); el.classList.add(state);
        const m = el.querySelector('.setl-bulkp-msg'); if (m && msg != null) m.textContent = msg;
      },
      finish(okCount, failCount, okAmt, skipped) {
        const ico = ov.querySelector('#bp-ico');
        const allOk = failCount === 0;
        ico.className = 'setl-progress-spinner ' + (okCount > 0 ? 'ok' : 'fail');
        ico.innerHTML = allOk ? '<i class="fa-solid fa-check"></i>' : '<i class="fa-solid fa-triangle-exclamation"></i>';
        ov.querySelector('#bp-sub').textContent = 'Selesai.';
        const res = ov.querySelector('#bp-result');
        res.className = 'setl-progress-result ' + (allOk && okCount > 0 ? 'ok' : 'fail');
        res.style.display = '';
        res.innerHTML = '<div class="setl-progress-msg"><b>' + okCount + ' berhasil</b> (' + rp(okAmt) + ')' +
          (failCount ? ' &middot; <b>' + failCount + ' gagal</b>' : '') +
          (skipped && skipped.length ? ' &middot; ' + skipped.length + ' dilewati (saldo &lt; 10rb)' : '') + '</div>';
        const close = ov.querySelector('#bp-close');
        close.style.display = '';
        close.onclick = () => { ov.remove(); if (okCount > 0) location.reload(); };
      },
    };
  }

  let bulkRunning = false;
  function getAcctName(id) {
    const cb = document.querySelector('.setl-bulk-acc[data-id="' + id + '"]');
    return (cb && cb.getAttribute('data-name')) || 'Akun';
  }
  // Satu job transfer (dipakai bersama: single & bulk)
  async function doOneTransfer(panel, job, fromWallet, toWallet) {
    panel.setRow(job.id, 'run', 'Memproses…');
    try {
      const resp = await fetch(transferUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ fromWallet, toWallet, amount: job.amount, qrisAccountId: job.id }),
      });
      const data = await resp.json().catch(() => null);
      if (data && data.ok) {
        panel.setRow(job.id, 'ok', 'Berhasil' + (data.referenceNo ? ' · Ref ' + data.referenceNo : ''));
        return { ok: true, amount: job.amount };
      }
      panel.setRow(job.id, 'fail', cleanMsg(data && data.error) || 'Gagal memproses');
      return { ok: false, amount: 0 };
    } catch (e) {
      panel.setRow(job.id, 'fail', 'Koneksi ke server gagal');
      return { ok: false, amount: 0 };
    }
  }
  window.getAcctName = getAcctName;

  async function runBulk(fromWallet, toWallet, opts) {
    opts = opts || {};
    const auto = !!opts.auto;
    if (bulkRunning) return;
    const isTopup = fromWallet === 'utama' && toWallet === 'madera';
    const checked = [...document.querySelectorAll('.setl-bulk-acc:checked')];
    if (checked.length === 0) {
      if (!auto) await setlConfirm({ icon: 'fa-triangle-exclamation', title: 'Belum ada akun dipilih', subtitle: 'Buka daftar akun di bawah tombol lalu centang minimal satu akun.', confirmText: 'Mengerti' });
      return;
    }
    const jobs = [];
    const skipped = [];
    checked.forEach((cb) => {
      const id = cb.getAttribute('data-id');
      const name = cb.getAttribute('data-name') || id;
      const bal = readLiveBal(fromWallet, id);
      let amt = Math.floor(bal / 1000) * 1000;
      const wMax = Number(cb.getAttribute('data-wmax') || '0');
      if (!isTopup && wMax > 0) amt = Math.min(amt, Math.floor(wMax / 1000) * 1000);
      if (amt >= 10000) jobs.push({ id, name, amount: amt });
      else skipped.push({ id, name });
    });
    if (jobs.length === 0) {
      if (!auto) await setlConfirm({ icon: 'fa-circle-info', title: 'Tidak ada saldo yang bisa diproses', subtitle: 'Semua akun terpilih saldonya di bawah Rp 10.000 setelah dibulatkan ke 1.000.', confirmText: 'Mengerti' });
      return;
    }
    const totalAmt = jobs.reduce((s, j) => s + j.amount, 0);
    if (!auto) {
      const ok = await setlConfirm({
        icon: isTopup ? 'fa-circle-arrow-up' : 'fa-download',
        title: isTopup ? 'Top Up SEMUA ke Madera?' : 'Tarik SEMUA QRIS ke Utama?',
        subtitle: jobs.length + ' akun akan diproses' + (skipped.length ? ' · ' + skipped.length + ' dilewati (saldo < 10rb)' : '') + '.',
        rows: [
          { label: 'Jumlah akun', value: jobs.length + ' akun' },
          { label: 'Alur', value: isTopup ? 'Saldo Utama → Madera' : 'Saldo QRIS → Utama' },
          { label: 'Total nominal', value: rp(totalAmt), hl: true },
        ],
        confirmText: isTopup ? 'Top Up Semua' : 'Tarik Semua',
        confirmClass: isTopup ? 'orange' : 'green',
      });
      if (!ok) return;
    }

    bulkRunning = true;
    const btnTarik = document.getElementById('bulkBtnTarik');
    const btnTopup = document.getElementById('bulkBtnTopup');
    if (btnTarik) btnTarik.disabled = true;
    if (btnTopup) btnTopup.disabled = true;

    const baseTitle = isTopup ? 'Top Up Semua ke Madera' : 'Tarik Semua QRIS ke Utama';
    const panel = setlBulkProgress((auto ? '⏱ ' : '') + baseTitle, jobs);
    let okCount = 0, failCount = 0, okAmt = 0;
    for (const job of jobs) {
      const r = await doOneTransfer(panel, job, fromWallet, toWallet);
      if (r.ok) { okCount++; okAmt += r.amount; } else failCount++;
    }
    panel.finish(okCount, failCount, okAmt, skipped);
    if (btnTarik) btnTarik.disabled = false;
    if (btnTopup) btnTopup.disabled = false;
    bulkRunning = false;
  }
  window.runBulk = runBulk;

  // ── Scheduler Otomatis (client-side, jalan selama halaman terbuka) ─────────
  const SCHED_KEY = 'qris:sched';
  const schedState = { tarik: { on: false, min: 30 }, topup: { on: false, min: 30 } };
  const schedTimer = { tarik: null, topup: null };
  const schedNextAt = { tarik: 0, topup: 0 };
  function schedEls(kind) {
    return {
      box: document.getElementById(kind === 'tarik' ? 'schedTarik' : 'schedTopup'),
      min: document.getElementById(kind === 'tarik' ? 'schedTarikMin' : 'schedTopupMin'),
      next: document.getElementById(kind === 'tarik' ? 'schedTarikNext' : 'schedTopupNext'),
    };
  }
  function schedMinOf(kind) {
    const el = schedEls(kind).min;
    let v = parseInt((el && el.value) || '30', 10);
    if (!Number.isFinite(v) || v < 1) v = 1;
    if (v > 1440) v = 1440;
    return v;
  }
  function saveSched() { try { localStorage.setItem(SCHED_KEY, JSON.stringify(schedState)); } catch (e) {} }
  function loadSched() {
    try {
      const j = JSON.parse(localStorage.getItem(SCHED_KEY) || 'null');
      if (j) ['tarik', 'topup'].forEach((k) => { if (j[k]) { schedState[k].on = !!j[k].on; schedState[k].min = j[k].min || 30; } });
    } catch (e) {}
  }
  function fireSched(kind) {
    if (kind === 'tarik') runBulk('qris', 'utama', { auto: true });
    else runBulk('utama', 'madera', { auto: true });
  }
  function startSched(kind) {
    stopSched(kind);
    const ms = schedMinOf(kind) * 60000;
    schedNextAt[kind] = Date.now() + ms;
    schedTimer[kind] = setInterval(() => { schedNextAt[kind] = Date.now() + ms; fireSched(kind); }, ms);
    renderSchedNext();
  }
  function stopSched(kind) {
    if (schedTimer[kind]) { clearInterval(schedTimer[kind]); schedTimer[kind] = null; }
    schedNextAt[kind] = 0;
    renderSchedNext();
  }
  function onSchedToggle(kind, on) { schedState[kind].on = on; schedState[kind].min = schedMinOf(kind); saveSched(); if (on) startSched(kind); else stopSched(kind); }
  function onSchedIntChange(kind) { schedState[kind].min = schedMinOf(kind); saveSched(); if (schedTimer[kind]) startSched(kind); }
  window.onSchedToggle = onSchedToggle;
  window.onSchedIntChange = onSchedIntChange;
  function renderSchedNext() {
    ['tarik', 'topup'].forEach((kind) => {
      const el = schedEls(kind).next;
      if (!el) return;
      if (!schedTimer[kind]) { el.textContent = 'nonaktif'; el.classList.remove('on'); return; }
      const left = Math.max(0, schedNextAt[kind] - Date.now());
      const m = Math.floor(left / 60000), s = Math.floor((left % 60000) / 1000);
      el.textContent = 'berikutnya ' + m + ':' + String(s).padStart(2, '0');
      el.classList.add('on');
    });
  }
  setInterval(renderSchedNext, 1000);
  function initSched() {
    loadSched();
    ['tarik', 'topup'].forEach((kind) => {
      const els = schedEls(kind);
      if (els.min) els.min.value = schedState[kind].min;
      if (els.box) els.box.checked = schedState[kind].on;
      if (schedState[kind].on) startSched(kind);
    });
    renderSchedNext();
  }

  // Inisialisasi hitungan checklist + scheduler saat halaman siap
  updateBulkCount();
  initSched();

  // ── Madera → Bank ─────────────────────────────────────────────────────────
  async function requestBankInquiry(acctId, options = {}) {
    const bankInput = getInput('bank-code', acctId);
    const accountInput = getInput('bank-account', acctId);
    const sourceInput = getInput('bank-source', acctId);
    const amountInput = getInput('madera2bank', acctId);
    if (!bankInput || !accountInput || !sourceInput) return null;
    if (bankInput.disabled || accountInput.disabled || amountInput?.disabled) return null;

    const swiftInput = getInput('bank-swift', acctId);
    const bankDisplayName = normalizeBankValue(bankInput.value);
    // Resolve SWIFT code: prefer hidden input → resolveSwiftCode fallback → display name
    const resolvedSwift = (swiftInput?.value) || resolveSwiftCode(bankDisplayName);
    const bankCode = resolvedSwift || bankDisplayName;
    const bankAccount = String(accountInput.value || '').replace(/[^\d]/g, '');
    const amount = Math.max(parseMoney(amountInput?.value) || 0, 10000);
    const fromWallet = 'madera';

    bankInput.value = bankDisplayName || bankInput.value.trim();
    // Sync SWIFT hidden input if we resolved a code
    if (swiftInput && !swiftInput.value && resolvedSwift && resolvedSwift !== bankDisplayName) {
      swiftInput.value = resolvedSwift;
    }
    accountInput.value = bankAccount;

    if ((!bankDisplayName && !swiftInput?.value) || !bankAccount) {
      resetOwnerState(acctId);
      if (!options.silent) {
        showMsg('madera2bank', acctId, 'Pilih bank dan isi nomor rekening terlebih dahulu.', false);
      }
      return null;
    }

    renderOwnerState(acctId, 'loading');

    const requestKey = `${fromWallet}|${bankCode}|${bankAccount}|${amount}`;
    const inflight = inquiryInflight.get(acctId);
    if (inflight && inflight.key === requestKey) {
      return inflight.promise;
    }

    const requestPromise = fetch(inquiryUrl, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        fromWallet,
        qrisAccountId: acctId,
        bankCode,
        bankAccount,
        amount,
      }),
    })
      .then(async (response) => {
        const payload = await response.json().catch(() => ({ ok: false, error: 'Respon inquiry tidak valid.' }));
        if (!response.ok || !payload.ok) {
          throw new Error(payload.error || 'Inquiry rekening gagal.');
        }
        const current = inquiryInflight.get(acctId);
        if (!current || current.key !== requestKey) {
          return null;
        }

        const result = payload.data || {};
        const accountName = String(result.accountName || '').trim();
        if (!accountName) {
          throw new Error('Nama pemilik rekening belum ditemukan.');
        }
        const resolvedBankName = String(result.bankName || bankCode).trim() || bankCode;
        const feeValue = Number.parseInt(String(result.fee ?? ''), 10);
        const feeMeta = Number.isFinite(feeValue)
          ? (feeValue === 0 ? 'Biaya GRATIS' : `Biaya ${rp(feeValue)}`)
          : '';
        const meta = [resolvedBankName, bankAccount, feeMeta].filter(Boolean).join(' | ');
        renderOwnerState(acctId, 'success', {
          bankName: resolvedBankName,
          accountName,
          meta,
        });
        if (!options.silent) {
          showMsg('madera2bank', acctId, `Rekening ${resolvedBankName} berhasil diverifikasi.`, true);
        }
        return result;
      })
      .catch((error) => {
        renderOwnerState(acctId, 'error', {
          title: 'Rekening belum valid',
          meta: error instanceof Error ? error.message : 'Inquiry rekening gagal.',
        });
        if (!options.silent) {
          showMsg('madera2bank', acctId, error instanceof Error ? error.message : 'Inquiry rekening gagal.', false);
        }
        return null;
      })
      .finally(() => {
        const current = inquiryInflight.get(acctId);
        if (current && current.key === requestKey) {
          inquiryInflight.delete(acctId);
        }
      });

    inquiryInflight.set(acctId, { key: requestKey, promise: requestPromise });
    return requestPromise;
  }

  function scheduleBankInquiry(acctId) {
    // Auto-cek dimatikan: inquiry rekening HANYA dijalankan saat klik tombol "Cek".
    clearTimeout(inquiryTimers.get(acctId));
  }

  function bindInquiryInputs() {
    document.querySelectorAll('[data-input^="bank-account-"]').forEach((input) => {
      if (input.dataset.inquiryBound === '1') return;
      input.dataset.inquiryBound = '1';
      input.addEventListener('input', () => {
        input.value = String(input.value || '').replace(/[^\d]/g, '');
        const acctId = (input.dataset.input || '').replace('bank-account-', '');
        resetOwnerState(acctId);
        scheduleBankInquiry(acctId);
      });
      input.addEventListener('blur', () => {
        const acctId = (input.dataset.input || '').replace('bank-account-', '');
        scheduleBankInquiry(acctId);
      });
    });

    document.querySelectorAll('[data-input^="bank-source-"]').forEach((input) => {
      if (input.dataset.inquiryBound === '1') return;
      input.dataset.inquiryBound = '1';
      input.addEventListener('change', () => {
        const acctId = (input.dataset.input || '').replace('bank-source-', '');
        resetOwnerState(acctId);
        scheduleBankInquiry(acctId);
      });
    });
  }

  function bindBankPickers() {
    document.querySelectorAll('[data-bank-search]').forEach((input) => {
      if (input.dataset.bankPickerBound === '1') return;
      input.dataset.bankPickerBound = '1';
      const acctId = input.getAttribute('data-bank-search') || '';

      input.addEventListener('focus', () => {
        if (input.disabled) return;
        renderBankOptions(acctId, input.value);
        closeAllBankDropdowns(acctId);
        setBankDropdownOpen(acctId, true);
      });

      input.addEventListener('input', () => {
        if (input.disabled) return;
        // Clear SWIFT code when user types (will be re-set on selection)
        const swiftInput = getInput('bank-swift', acctId);
        if (swiftInput) swiftInput.value = '';
        resetOwnerState(acctId);
        renderBankOptions(acctId, input.value);
        closeAllBankDropdowns(acctId);
        setBankDropdownOpen(acctId, true);
        scheduleBankInquiry(acctId);
      });

      input.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setBankDropdownOpen(acctId, false);
          return;
        }
        if (event.key === 'Enter') {
          const normalized = normalizeBankValue(input.value);
          if (normalized) {
            event.preventDefault();
            input.value = normalized;
            const swiftInput = getInput('bank-swift', acctId);
            if (swiftInput) swiftInput.value = resolveSwiftCode(normalized);
            renderBankOptions(acctId, normalized);
            setBankDropdownOpen(acctId, false);
            scheduleBankInquiry(acctId);
          }
        }
        if (event.key === 'ArrowDown') {
          event.preventDefault();
          renderBankOptions(acctId, input.value);
          closeAllBankDropdowns(acctId);
          setBankDropdownOpen(acctId, true);
        }
      });

      input.addEventListener('blur', () => {
        setTimeout(() => {
          const normalized = normalizeBankValue(input.value);
          if (normalized) {
            input.value = normalized;
            const swiftInput = getInput('bank-swift', acctId);
            if (swiftInput) swiftInput.value = resolveSwiftCode(normalized);
          }
          setBankDropdownOpen(acctId, false);
          scheduleBankInquiry(acctId);
        }, 120);
      });

      renderBankOptions(acctId, input.value);
    });

    document.querySelectorAll('[data-bank-toggle]').forEach((button) => {
      if (button.dataset.bankPickerBound === '1') return;
      button.dataset.bankPickerBound = '1';
      const acctId = button.getAttribute('data-bank-toggle') || '';
      button.addEventListener('click', (event) => {
        event.preventDefault();
        const input = getInput('bank-code', acctId);
        if (button.disabled || input?.disabled) return;
        const dropdown = getBankDropdown(acctId);
        const nextOpen = dropdown?.hidden ?? true;
        renderBankOptions(acctId, input?.value || '');
        closeAllBankDropdowns(nextOpen ? acctId : '');
        setBankDropdownOpen(acctId, nextOpen);
        if (nextOpen && input) {
          input.focus();
        }
      });
    });

    document.addEventListener('click', (event) => {
      if (event.target instanceof Element && event.target.closest('.setl-bank-picker')) return;
      closeAllBankDropdowns();
    });
  }

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeTransferFlowModal();
    }
  });

  getTransferFlowModal()?.addEventListener('click', (event) => {
    if (event.target === getTransferFlowModal()) {
      closeTransferFlowModal();
    }
  });

  window.doTransferBank = async function(acctId, btn) {
    const bankInput = getInput('bank-code', acctId);
    const accountInput = getInput('bank-account', acctId);
    const amountInput = getInput('madera2bank', acctId);
    const sourceInput = getInput('bank-source', acctId);
    const bankNameInput = getInput('bank-name', acctId);
    const swiftInput = getInput('bank-swift', acctId);
    const ownerBox = getOwnerBox(acctId);

    const bankDisplayName = normalizeBankValue(bankInput?.value || '');
    // Resolve SWIFT code: prefer hidden input → resolveSwiftCode fallback → display name
    const resolvedSwift = (swiftInput?.value) || resolveSwiftCode(bankDisplayName);
    const bankCode = resolvedSwift || bankDisplayName;
    const bankAccount = String(accountInput?.value || '').replace(/[^\d]/g, '');
    const amount = parseMoney(amountInput?.value);
    const fromWallet = 'madera';

    if (bankInput && bankDisplayName) bankInput.value = bankDisplayName;
    // Sync SWIFT hidden input if we resolved a code
    if (swiftInput && !swiftInput.value && resolvedSwift && resolvedSwift !== bankDisplayName) {
      swiftInput.value = resolvedSwift;
    }
    if (accountInput) accountInput.value = bankAccount;

    if (!bankCode) {
      showMsg('madera2bank', acctId, 'Pilih bank dari daftar terlebih dahulu.', false);
      return;
    }
    if (!bankAccount) {
      showMsg('madera2bank', acctId, 'Masukkan nomor rekening tujuan.', false);
      return;
    }
    if (!amount || amount < 10000) {
      showMsg('madera2bank', acctId, 'Minimal transfer bank dari Saldo Madera Rp 10.000.', false);
      return;
    }
    if (sourceInput && sourceInput.value !== 'madera') {
      sourceInput.value = 'madera';
    }
    if (bankInput?.disabled || accountInput?.disabled || amountInput?.disabled) {
      showMsg('madera2bank', acctId, 'Kirim Uang belum aktif. Pastikan saldo Madera ada dan PIN merchant sudah diisi.', false);
      return;
    }

    if (!ownerBox?.dataset.ownerName) {
      const inquiry = await requestBankInquiry(acctId, { silent: false });
      if (!inquiry) return;
    }

    const bankName = bankNameInput?.value?.trim() || bankDisplayName || bankCode;

    const feeConfirm = 2500;
    const ownerName = ownerBox?.dataset.ownerName || '-';
    const okConfirm = await setlConfirm({
      icon: 'fa-paper-plane',
      title: 'Kirim Uang Sekarang?',
      subtitle: 'Periksa detail transfer sebelum lanjut.',
      rows: [
        { label: 'Bank', value: bankName },
        { label: 'Nama', value: ownerName },
        { label: 'No. Rekening', value: bankAccount },
        { label: 'Nominal', value: rp(amount) },
        { label: 'Biaya', value: rp(feeConfirm) },
        { label: 'Total', value: rp(amount + feeConfirm), hl: true },
      ],
      confirmText: 'Kirim Sekarang',
      confirmClass: 'blue',
    });
    if (!okConfirm) return;

    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
    await performTransfer(
      {
        fromWallet,
        toWallet: 'bank',
        amount,
        qrisAccountId: acctId,
        bankCode,
        bankAccount,
        bankName,
        note: ownerBox?.dataset.ownerName || undefined,
      },
      'madera2bank',
      acctId,
      btn,
      orig,
    );
  };

  // ── Cek rekening (stub) ───────────────────────────────────────────────────
  window.cekRekening = async function(acctId) {
    // Inquiry Nobu kadang gagal sesaat (flaky) -> auto-retry beberapa kali sebelum menyerah.
    const maxTry = 3;
    for (let i = 1; i <= maxTry; i++) {
      renderOwnerState(acctId, 'loading');
      const res = await requestBankInquiry(acctId, { silent: i < maxTry });
      if (res) return; // sukses: nama pemilik ditemukan
      if (i < maxTry) await new Promise((r) => setTimeout(r, 900));
    }
  };

  // ── Bukti Transfer (render ke canvas → download PNG) ──────────────────────
  function prettyBank(nameOrCode) {
    if (!nameOrCode) return '';
    for (const k in BANK_SWIFT_MAP) if (BANK_SWIFT_MAP[k] === nameOrCode) return k;
    if (typeof dynamicBanksByCode !== 'undefined' && dynamicBanksByCode.get) {
      const e = dynamicBanksByCode.get(nameOrCode);
      if (e && e.name) return e.name;
    }
    return nameOrCode;
  }
  function downloadReceipt(d) {
    const rows = [];
    rows.push(['Tanggal', d.time || '-']);
    if (d.merchant) rows.push(['Merchant', d.merchant]);
    rows.push(['Alur', (d.from || '') + '  →  ' + (d.to || '')]);
    if (d.bankName) rows.push(['Bank Tujuan', prettyBank(d.bankName)]);
    if (d.bankAccount) rows.push(['No. Rekening', String(d.bankAccount)]);
    rows.push(['Nominal', rp(d.amount)]);
    if (d.fee !== null && d.fee !== undefined) rows.push(['Biaya', rp(d.fee)]);
    if (d.total !== null && d.total !== undefined) rows.push(['Total', rp(d.total)]);
    if (d.ref) rows.push(['Referensi', String(d.ref)]);
    if (d.note) rows.push(['Keterangan', String(d.note)]);

    const W = 640, padX = 40, headerH = 210, rowH = 44, footerH = 92;
    const H = headerH + rows.length * rowH + footerH;
    const scale = 2;
    const canvas = document.createElement('canvas');
    canvas.width = W * scale; canvas.height = H * scale;
    const ctx = canvas.getContext('2d');
    ctx.scale(scale, scale);

    const bg = ctx.createLinearGradient(0, 0, 0, H);
    bg.addColorStop(0, '#0f172a'); bg.addColorStop(1, '#1e293b');
    ctx.fillStyle = bg; ctx.fillRect(0, 0, W, H);
    const ab = ctx.createLinearGradient(0, 0, W, 0);
    ab.addColorStop(0, '#3b82f6'); ab.addColorStop(.5, '#a78bfa'); ab.addColorStop(1, '#22c55e');
    ctx.fillStyle = ab; ctx.fillRect(0, 0, W, 5);

    const ok = d.status === 'done';
    const proc = d.status === 'processing' || d.status === 'pending';
    const stColor = ok ? '#22c55e' : (proc ? '#f59e0b' : '#ef4444');
    const stText = ok ? 'BERHASIL' : (proc ? 'DIPROSES' : 'GAGAL');

    ctx.fillStyle = '#e2e8f0'; ctx.font = '800 13px system-ui, -apple-system, sans-serif';
    ctx.fillText('BUKTI TRANSFER', padX, 46);
    ctx.fillStyle = '#64748b'; ctx.font = '600 11px system-ui, sans-serif';
    const brand = 'QRIS ORKUT';
    ctx.fillText(brand, W - padX - ctx.measureText(brand).width, 46);

    ctx.fillStyle = stColor;
    ctx.beginPath(); ctx.arc(padX + 9, 80, 10, 0, 2 * Math.PI); ctx.fill();
    ctx.fillStyle = '#0f172a'; ctx.font = '900 12px system-ui, sans-serif';
    ctx.fillText(ok ? '✓' : (proc ? '…' : '✕'), padX + (ok ? 4.5 : (proc ? 4 : 5)), 84);
    ctx.fillStyle = stColor; ctx.font = '800 21px system-ui, sans-serif';
    ctx.fillText(stText, padX + 28, 88);

    ctx.fillStyle = '#f8fafc'; ctx.font = '800 40px system-ui, sans-serif';
    ctx.fillText(rp(d.amount), padX, 150);
    ctx.fillStyle = '#94a3b8'; ctx.font = '600 12px system-ui, sans-serif';
    ctx.fillText((d.from || '') + '  →  ' + (d.to || ''), padX, 176);

    ctx.strokeStyle = 'rgba(148,163,184,.22)'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(padX, headerH - 14); ctx.lineTo(W - padX, headerH - 14); ctx.stroke();

    let y = headerH + 12;
    rows.forEach(([label, value]) => {
      ctx.textAlign = 'left'; ctx.fillStyle = '#94a3b8'; ctx.font = '600 13px system-ui, sans-serif';
      ctx.fillText(label, padX, y);
      ctx.textAlign = 'right'; ctx.fillStyle = '#f1f5f9'; ctx.font = '700 13px system-ui, sans-serif';
      let v = String(value == null ? '' : value);
      const maxW = W - padX * 2 - 150;
      if (ctx.measureText(v).width > maxW) {
        while (v.length > 4 && ctx.measureText(v + '…').width > maxW) v = v.slice(0, -1);
        v = v + '…';
      }
      ctx.fillText(v, W - padX, y);
      y += rowH;
      ctx.strokeStyle = 'rgba(148,163,184,.08)'; ctx.beginPath(); ctx.moveTo(padX, y - rowH + 14); ctx.lineTo(W - padX, y - rowH + 14); ctx.stroke();
    });
    ctx.textAlign = 'left';

    const fy = H - 46;
    ctx.strokeStyle = 'rgba(148,163,184,.22)'; ctx.beginPath(); ctx.moveTo(padX, fy - 16); ctx.lineTo(W - padX, fy - 16); ctx.stroke();
    ctx.fillStyle = '#64748b'; ctx.font = '500 10.5px system-ui, sans-serif';
    ctx.fillText('Dibuat otomatis • ' + new Date().toLocaleString('id-ID', { timeZone: 'Asia/Jakarta' }), padX, fy);
    ctx.fillText('Bukti ini dibuat dari catatan sistem, bukan dokumen resmi bank.', padX, fy + 16);

    canvas.toBlob(function (blob) {
      if (!blob) return;
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      const stamp = String(d.ref || d.time || 'bukti').replace(/[^\w-]+/g, '_').slice(0, 40);
      a.download = 'bukti-transfer-' + stamp + '.png';
      document.body.appendChild(a); a.click();
      setTimeout(() => { URL.revokeObjectURL(a.href); a.remove(); }, 1200);
    }, 'image/png');
  }
  window.downloadReceipt = downloadReceipt;

  // ── Bukti Resmi Nobu (screenshot bot dari webview Madera) ─────────────────
  const PROOF_BASE = '<%- url('/dashboard/api/settlement') %>';
  const PROOFS_LIST_URL = '<%- url('/dashboard/api/settlement-proofs') %>';
  const proofReady = new Set();
  function setProofBtn(btn, state) {
    if (!btn) return;
    btn.classList.remove('ready', 'busy');
    const ic = btn.querySelector('i');
    if (state === 'ready') { btn.classList.add('ready'); if (ic) ic.className = 'fa-solid fa-file-arrow-down'; btn.title = 'Download bukti resmi Nobu'; }
    else if (state === 'busy') { btn.classList.add('busy'); if (ic) ic.className = 'fa-solid fa-spinner'; btn.title = 'Mengambil bukti…'; }
    else { if (ic) ic.className = 'fa-solid fa-lock'; btn.title = 'Bukti belum diambil — klik untuk ambil (butuh ~30 detik)'; }
  }
  async function loadProofsList() {
    try {
      const resp = await fetch(PROOFS_LIST_URL, { headers: { 'Accept': 'application/json' } });
      const data = await resp.json().catch(() => null);
      if (data && data.ok && Array.isArray(data.ids)) {
        data.ids.forEach((id) => proofReady.add(id));
        document.querySelectorAll('.setl-proof-btn').forEach((btn) => {
          if (proofReady.has(btn.getAttribute('data-id'))) setProofBtn(btn, 'ready');
        });
      }
    } catch (e) {}
  }
  function pollProof(id, btn) {
    let tries = 0;
    const timer = setInterval(async () => {
      tries++;
      try {
        const resp = await fetch(PROOFS_LIST_URL, { headers: { 'Accept': 'application/json' } });
        const data = await resp.json().catch(() => null);
        const ids = (data && data.ids) || [];
        const processing = (data && data.processing) || [];
        if (ids.indexOf(id) !== -1) {
          clearInterval(timer); proofReady.add(id); setProofBtn(btn, 'ready');
          if (window.Swal) Swal.fire({ icon: 'success', title: 'Bukti siap', text: 'Bukti resmi Nobu berhasil diambil. Klik lagi untuk download.', background: 'var(--card)', color: 'var(--ink)', timer: 2400, showConfirmButton: false });
          return;
        }
        if (processing.indexOf(id) === -1) {
          clearInterval(timer); setProofBtn(btn, 'idle');
          alert('Bukti gagal diambil (Nobu sedang sibuk / "Data Gagal Dimuat"). Tunggu beberapa menit, lalu coba lagi.');
          return;
        }
      } catch (e) {}
      if (tries >= 45) { clearInterval(timer); setProofBtn(btn, 'idle'); alert('Pengambilan bukti terlalu lama. Coba lagi nanti.'); }
    }, 5000);
  }
  async function onProofClick(id, btn) {
    if (proofReady.has(id)) {
      window.location.href = PROOF_BASE + '/' + encodeURIComponent(id) + '/proof';
      return;
    }
    if (btn && btn.classList.contains('busy')) return;
    setProofBtn(btn, 'busy');
    try {
      const resp = await fetch(PROOF_BASE + '/' + encodeURIComponent(id) + '/capture-proof', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
      const data = await resp.json().catch(() => null);
      if (!data || !data.ok) {
        setProofBtn(btn, 'idle');
        alert((data && data.message) || 'Gagal memulai pengambilan bukti. Coba lagi.');
        return;
      }
      if (data.status === 'ready') { proofReady.add(id); setProofBtn(btn, 'ready'); return; }
      // status 'processing' -> pantau sampai selesai (bot butuh ~30-60 detik)
      pollProof(id, btn);
    } catch (e) {
      setProofBtn(btn, 'idle');
      alert('Koneksi ke server gagal. Coba lagi.');
    }
  }
  window.onProofClick = onProofClick;
  loadProofsList();

  // ── History filter (tanggal + status) + pagination (maks 100/hal) ─────────
  const HIST_PAGE_SIZE = 100;
  let histRange = 'all', histPageNum = 1, histMatched = [];
  function histRows() { return [...document.querySelectorAll('#hist-tbody tr[data-status]')]; }
  function histInRange(ts) {
    const d = new Date();
    const startToday = new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime();
    if (histRange === 'today') return ts >= startToday;
    if (histRange === 'yesterday') return ts >= startToday - 86400000 && ts < startToday;
    if (histRange === 'custom') {
      const f = document.getElementById('hist-from'), t = document.getElementById('hist-to');
      const lo = (f && f.value) ? new Date(f.value + 'T00:00:00').getTime() : -Infinity;
      const hi = (t && t.value) ? new Date(t.value + 'T23:59:59.999').getTime() : Infinity;
      return ts >= lo && ts <= hi;
    }
    return true;
  }
  function applyHistFilter() {
    const sel = document.getElementById('hist-filter');
    const status = (sel && sel.value) || '';
    histMatched = histRows().filter((r) => {
      const ts = Number(r.dataset.ts || '0');
      return histInRange(ts) && (!status || r.dataset.status === status);
    });
    histPageNum = 1;
    renderHistPage();
  }
  function renderHistPage() {
    const total = histMatched.length;
    const pages = Math.max(1, Math.ceil(total / HIST_PAGE_SIZE));
    if (histPageNum > pages) histPageNum = pages;
    if (histPageNum < 1) histPageNum = 1;
    const start = (histPageNum - 1) * HIST_PAGE_SIZE, end = start + HIST_PAGE_SIZE;
    histRows().forEach((r) => { r.style.display = 'none'; });
    histMatched.forEach((r, i) => { r.style.display = (i >= start && i < end) ? '' : 'none'; });
    const countEl = document.getElementById('hist-count'); if (countEl) countEl.textContent = '(' + total + ' request)';
    const emptyEl = document.getElementById('hist-empty-filter'); if (emptyEl) emptyEl.hidden = total !== 0;
    const info = document.getElementById('hist-pageinfo'); if (info) info.textContent = 'Hal ' + histPageNum + ' / ' + pages + ' · ' + total + ' baris';
    const prev = document.getElementById('hist-prev'), next = document.getElementById('hist-next');
    if (prev) prev.disabled = histPageNum <= 1;
    if (next) next.disabled = histPageNum >= pages;
    const pager = document.getElementById('hist-pager'); if (pager) pager.style.display = total > HIST_PAGE_SIZE ? '' : 'none';
  }
  function histPage(dir) { histPageNum += dir; renderHistPage(); }
  function setHistRange(range, btn) {
    histRange = range;
    document.querySelectorAll('.setl-hist-datebtn').forEach((b) => b.classList.remove('active'));
    if (btn) btn.classList.add('active');
    const custom = document.getElementById('hist-custom');
    if (custom) { if (range === 'custom') custom.removeAttribute('hidden'); else custom.setAttribute('hidden', ''); }
    applyHistFilter();
  }
  window.applyHistFilter = applyHistFilter;
  window.histPage = histPage;
  window.setHistRange = setHistRange;
  const histFilterSel = document.getElementById('hist-filter');
  if (histFilterSel) histFilterSel.addEventListener('change', applyHistFilter);
  applyHistFilter();

  // ── Live balance polling ──────────────────────────────────────────────────
  bindMoneyInputs();
  bindBankPickers();
  bindInquiryInputs();
  document.querySelectorAll('[data-owner-box]').forEach((box) => {
    const acctId = String(box.getAttribute('data-owner-box') || '').replace('bank-owner-', '');
    if (acctId) resetOwnerState(acctId);
  });

  // ── Total Saldo (kartu QRIS/Utama/Madera/Grand) — hormati filter Site + ikut live-refresh ──
  function _wtReadBal(card, field) {
    var el = card.querySelector('.fl-val[data-field="' + field + '"]');
    if (!el) return 0;
    if (el.dataset.val !== undefined && el.dataset.val !== '') return Number(el.dataset.val) || 0;
    return Number(String(el.textContent).replace(/[^\d-]/g, '')) || 0;
  }
  function _wtAnimate(id, to) {
    var el = document.getElementById(id);
    if (!el) return;
    to = Math.round(Number(to) || 0);
    var from = (el.dataset.val !== undefined && el.dataset.val !== '') ? (Number(el.dataset.val) || 0) : 0;
    el.dataset.val = String(to);
    if (from === to) { el.textContent = rp(to); return; }
    var dur = 900, t0 = (window.performance && performance.now) ? performance.now() : Date.now();
    function frame(now) {
      var p = Math.min(1, (((window.performance && performance.now) ? now : Date.now()) - t0) / dur);
      var e = 1 - Math.pow(1 - p, 3);
      el.textContent = rp(Math.round(from + (to - from) * e));
      if (p < 1) requestAnimationFrame(frame); else el.textContent = rp(to);
    }
    requestAnimationFrame(frame);
  }
  function recomputeWalletTotals(animate) {
    var cards = document.querySelectorAll('#account-grid .setl-card');
    var tq = 0, tu = 0, tm = 0;
    cards.forEach(function (card) {
      if (card.style.display === 'none') return; // hormati filter Site
      tq += _wtReadBal(card, 'qris');
      tu += _wtReadBal(card, 'utama');
      tm += _wtReadBal(card, 'madera');
    });
    var tg = tq + tu + tm;
    if (animate) {
      _wtAnimate('wt-qris', tq); _wtAnimate('wt-utama', tu); _wtAnimate('wt-madera', tm); _wtAnimate('wt-grand', tg);
    } else {
      [['wt-qris', tq], ['wt-utama', tu], ['wt-madera', tm], ['wt-grand', tg]].forEach(function (pr) {
        var el = document.getElementById(pr[0]); if (el) { el.dataset.val = String(Math.round(pr[1])); el.textContent = rp(Math.round(pr[1])); }
      });
    }
  }
  window.recomputeWalletTotals = recomputeWalletTotals;

  // Live-refresh saldo QRIS/Utama/Madera langsung dari OrderKuota (cek saldo = BEBAS-LIMIT).
  function refreshAllSettlementAccounts() {
    Array.from(document.querySelectorAll('.setl-acc-toggle'))
      .map(function (el) { return el.getAttribute('data-account-id'); })
      .filter(Boolean)
      .forEach(function (id) { refreshSettlementAccount(id); });
  }
  // 1) Saat menu dibuka/reload.
  refreshAllSettlementAccounts();
  recomputeWalletTotals(true);
  // 2) Otomatis tiap 30 detik TANPA reload -> saldo naik/turun sendiri. Guard in-flight per akun
  //    mencegah tumpukan. Pause saat tab tak terlihat (document.hidden) supaya hemat panggilan.
  setInterval(function () {
    if (document.hidden) return;
    refreshAllSettlementAccounts();
  }, 30000);
  // 3) Begitu tab kembali terlihat, segarkan langsung (biar tak nunggu 30 detik).
  document.addEventListener('visibilitychange', function () {
    if (!document.hidden) refreshAllSettlementAccounts();
  });
})();
</script>
