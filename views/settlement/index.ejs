  // ── Progress premium saat bot memasukkan PIN (return controller .done()) ────
  function setlProgress() {
    const ov = document.createElement('div');
    ov.className = 'setl-progress-overlay';
    ov.innerHTML =
      '<div class="setl-progress-card" role="dialog" aria-modal="true">' +
        '<div class="setl-progress-spinner" id="sp-ico"><i class="fa-solid fa-robot"></i></div>' +
        '<div class="setl-progress-title" id="sp-title">Mengirim Uang</div>' +
        '<div class="setl-progress-sub" id="sp-sub">Menyiapkan transfer…</div>' +
        '<div class="setl-progress-steps">' +
          '<div class="setl-progress-step" data-i="0"><span class="dot"></span> Inisiasi transfer BI-FAST</div>' +
          '<div class="setl-progress-step" data-i="1"><span class="dot"></span> Bot memasukkan PIN di Nobu</div>' +
          '<div class="setl-progress-step" data-i="2"><span class="dot"></span> Menunggu status transaksi</div>' +
        '</div>' +
        '<div class="setl-progress-result" id="sp-result" style="display:none"></div>' +
        '<button class="setl-progress-close" id="sp-close" style="display:none">Tutup</button>' +
      '</div>';
    document.body.appendChild(ov);
    requestAnimationFrame(() => ov.classList.add('open'));
    const steps = ov.querySelectorAll('.setl-progress-step');
    const sub = ov.querySelector('#sp-sub');
    const activate = (n) => steps.forEach((s, i) => { s.classList.toggle('active', i === n); s.classList.toggle('done', i < n); });
    activate(0);
    const timers = [];
    timers.push(setTimeout(() => { activate(1); sub.textContent = 'Bot sedang memasukkan PIN…'; }, 2600));
    timers.push(setTimeout(() => { activate(2); sub.textContent = 'Menunggu status berhasil / gagal…'; }, 8500));
    return {
      done(success, message, ref) {
        timers.forEach(clearTimeout);
        steps.forEach((s) => { s.classList.remove('active'); s.classList.add('done'); });
        const ico = ov.querySelector('#sp-ico');
        ico.className = 'setl-progress-spinner ' + (success ? 'ok' : 'fail');
        ico.innerHTML = success ? '<i class="fa-solid fa-check"></i>' : '<i class="fa-solid fa-xmark"></i>';
        ov.querySelector('#sp-title').textContent = success ? 'Transaksi Berhasil' : 'Transaksi Belum Berhasil';
        sub.textContent = success ? 'Uang berhasil dikirim.' : 'Silakan cek dan coba lagi.';
        const result = ov.querySelector('#sp-result');
        result.className = 'setl-progress-result ' + (success ? 'ok' : 'fail');
        result.style.display = '';
        result.innerHTML = (ref ? '<div class="setl-progress-ref">Ref: ' + escP(ref) + '</div>' : '') + (message ? '<div class="setl-progress-msg">' + escP(message) + '</div>' : '');
        const close = ov.querySelector('#sp-close');
        close.style.display = '';
        close.onclick = () => ov.remove();
        if (success) setTimeout(() => location.reload(), 3800);
      },
    };
  }

