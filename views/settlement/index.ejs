  // ── Generic transfer ──────────────────────────────────────────────────────
  async function execTransfer(body, msgKey, msgId, btn, origHtml) {
    try {
      const res  = await fetch(transferUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();
      if (data.ok) {
        showMsg(msgKey, msgId, `✓ Berhasil! Ref: ${data.referenceNo || data.settlementId}`, true);
        // Reset input
        const inp = document.querySelector(`[data-input="${msgKey}-${msgId}"]`);
        if (inp) inp.value = '';
        setTimeout(() => location.reload(), 2200);
      } else {
        showMsg(msgKey, msgId, `✗ ${data.error || 'Gagal memproses'}`, false);
      }
    } catch {
      showMsg(msgKey, msgId, '✗ Koneksi error', false);
    } finally {
      btn.disabled  = false;
      btn.innerHTML = origHtml;
    }
  }

  async function performTransfer(body, msgKey, msgId, btn, origHtml) {
    const isBank = body.toWallet === 'bank';
    const prog = isBank ? setlProgress() : null;
    try {
      const response = await fetch(transferUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await response.json();
      if (data.ok) {
        const isProcessing = data.status === 'processing';
        const ref = data.referenceNo || data.settlementId;
        const input = getInput(msgKey, msgId);
        if (input) input.value = '';
        if (prog) {
          // Transfer ke bank: tampilkan hasil di overlay progress (pesan dibersihkan).
          prog.done(!isProcessing, isProcessing ? (cleanMsg(data.message) || 'Status belum pasti — cek Mutasi untuk memastikan.') : 'Uang berhasil dikirim ke rekening tujuan.', ref);
        } else {
          const message = isProcessing
            ? `Permintaan dikirim. Ref: ${ref}. Lanjutkan PIN untuk menyelesaikan transfer.`
            : `Berhasil. Ref: ${ref}`;
          showMsg(msgKey, msgId, message, true);
          if (isProcessing && data.redirectUrl) {
            openTransferFlowModal({
              settlementId: data.settlementId,
              referenceNo: data.referenceNo || null,
              redirectUrl: data.redirectUrl,
              bankName: body.bankName || null,
              bankAccount: body.bankAccount || null,
              amount: body.amount || null,
              message: data.message || 'Auto PIN pertama sudah dicoba.',
              status: data.status,
            });
          } else {
            setTimeout(() => location.reload(), 1800);
          }
        }
      } else {
        if (prog) prog.done(false, cleanMsg(data.error) || 'Gagal memproses transfer');
        else showMsg(msgKey, msgId, cleanMsg(data.error) || 'Gagal memproses transfer', false);
      }
    } catch {
      if (prog) prog.done(false, 'Koneksi ke server gagal.');
      else showMsg(msgKey, msgId, 'Koneksi ke server gagal.', false);
    } finally {
      btn.disabled = false;
      btn.innerHTML = origHtml;
    }
  }

  // ── QRIS → Utama ─────────────────────────────────────────────────────────
  window.doTransfer = async function(acctId, fromWallet, toWallet, btn) {
    const key = `${fromWallet}2${toWallet}`;
    const input = getInput(key, acctId);
    if (!input) return;

    const amount = parseMoney(input.value);
    if (!amount || amount < 1000) {
      showMsg(key, acctId, 'Minimal transfer Rp 1.000.', false);
      return;
    }

    if (fromWallet === 'qris' && toWallet === 'utama') {
      const min = Number.parseInt(input.dataset.min || '1000', 10) || 1000;
      const max = Number.parseInt(input.dataset.max || '0', 10) || 0;
      if (amount < min) {
        showMsg(key, acctId, `Minimal tarik saldo ${rp(min)}.`, false);
        return;
      }
      if (max > 0 && amount > max) {
        showMsg(key, acctId, `Maksimal tarik saldo ${rp(max)}.`, false);
        return;
      }
    }

    if (fromWallet === 'utama' && toWallet === 'madera' && amount % 1000 !== 0) {
      showMsg(key, acctId, 'Topup Madera harus kelipatan Rp 1.000.', false);
      return;
    }

    const isTopup = fromWallet === 'utama' && toWallet === 'madera';
    const okConfirm = await setlConfirm({
      icon: isTopup ? 'fa-circle-arrow-up' : 'fa-right-to-bracket',
      title: isTopup ? 'Top Up ke Saldo Madera?' : 'Kirim ke Saldo Utama?',
      subtitle: isTopup ? 'Pindahkan dana dari Saldo Utama.' : 'Tarik dana dari Saldo QRIS.',
      rows: [
        { label: 'Dari', value: isTopup ? 'Saldo Utama' : 'Saldo QRIS' },
        { label: 'Ke', value: isTopup ? 'Saldo Madera' : 'Saldo Utama' },
        { label: 'Nominal', value: rp(amount), hl: true },
      ],
      confirmText: isTopup ? 'Top Up' : 'Kirim',
      confirmClass: isTopup ? 'orange' : 'green',
    });
    if (!okConfirm) return;

    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
    const job = { id: acctId, name: getAcctName(acctId), amount };
    const panel = setlBulkProgress(isTopup ? 'Top Up ke Madera' : 'Tarik QRIS ke Utama', [job]);
    const r = await doOneTransfer(panel, job, fromWallet, toWallet);
    panel.finish(r.ok ? 1 : 0, r.ok ? 0 : 1, r.ok ? amount : 0, []);
    if (r.ok) { const inp = getInput(key, acctId); if (inp) inp.value = ''; }
    btn.disabled = false;
    btn.innerHTML = orig;
  };

  // ── AKSI GLOBAL: Tarik Semua / Top Up Semua ───────────────────────────────
  function toggleBulkList() {
    const list = document.getElementById('bulkList');
    const toggle = document.getElementById('bulkToggle');
    if (!list || !toggle) return;
    const open = list.hasAttribute('hidden');
    if (open) list.removeAttribute('hidden'); else list.setAttribute('hidden', '');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
