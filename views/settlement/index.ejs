  // ── Show message ──────────────────────────────────────────────────────────
  function showMsg(key, id, text, ok) {
    const el = document.querySelector(`[data-msg="${key}-${id}"]`);
    if (!el) return;
    el.textContent = text;
    el.style.background = ok ? 'rgba(34,197,94,0.12)' : 'rgba(239,68,68,0.12)';
    el.style.color = ok ? '#86efac' : '#fca5a5';
    el.style.display = '';
    clearTimeout(el._hideTimer);
    el._hideTimer = setTimeout(() => {
      el.style.display = 'none';
    }, 7000);
  }

  function renderOwnerState(id, state, payload) {
    const box = getOwnerBox(id);
    const hiddenBankName = getInput('bank-name', id);
    if (!box) return;

    box.classList.remove('success', 'error', 'loading');
    box.dataset.ownerName = '';
    box.dataset.bankName = '';
    // Tampil hanya saat proses cek / hasil; disembunyikan saat idle.
    box.style.display = (state === 'loading' || state === 'success' || state === 'error') ? '' : 'none';

    const titleEl = box.querySelector('.setl-owner-title');
    const nameEl = box.querySelector('.setl-owner-name');
    const metaEl = box.querySelector('.setl-owner-meta');
    if (!titleEl || !nameEl || !metaEl) return;

    if (state === 'loading') {
      box.classList.add('loading');
      titleEl.textContent = 'Cek rekening';
      nameEl.textContent = 'Memeriksa nama pemilik rekening...';
      metaEl.textContent = 'Mohon tunggu sebentar.';
      if (hiddenBankName) hiddenBankName.value = '';
      return;
    }

    if (state === 'success') {
      const bankName = payload?.bankName || '';
      const accountName = payload?.accountName || '';
      box.classList.add('success');
      box.dataset.ownerName = accountName;
      box.dataset.bankName = bankName;
      titleEl.textContent = 'Nama pemilik rekening';
      nameEl.textContent = accountName;
      metaEl.textContent = payload?.meta || bankName || 'Rekening berhasil diverifikasi.';
      if (hiddenBankName) hiddenBankName.value = bankName;
      return;
    }

    if (state === 'error') {
      box.classList.add('error');
      titleEl.textContent = 'Nama pemilik rekening';
      nameEl.textContent = payload?.title || 'Rekening belum valid';
      metaEl.textContent = payload?.meta || 'Periksa kembali pilihan bank dan nomor rekening.';
      if (hiddenBankName) hiddenBankName.value = '';
      return;
    }

    titleEl.textContent = 'Nama pemilik rekening';
    nameEl.textContent = 'Akan muncul otomatis setelah bank dan nomor rekening valid.';
    metaEl.textContent = 'Kamu cukup pilih bank, isi nomor rekening, lalu sistem akan cek sendiri.';
    if (hiddenBankName) hiddenBankName.value = '';
  }

  function resetOwnerState(id) {
    const box = getOwnerBox(id);
    if (box?.dataset.maderaReady === '0') {
      renderOwnerState(id, 'error', {
        title: 'Saldo Madera belum aktif',
        meta: 'Klik kartu akun untuk refresh saldo Madera setelah aktivasi selesai.',
      });
      return;
    }
    if (box?.dataset.pinReady === '0') {
      renderOwnerState(id, 'error', {
        title: 'PIN merchant belum diisi',
        meta: 'Buka Merchant QR lalu simpan PIN agar Kirim Uang bisa berjalan otomatis.',
      });
      return;
    }
    renderOwnerState(id, 'idle');
  }

  function bindMoneyInputs() {
    document.querySelectorAll('[data-money="1"]').forEach((input) => {
      if (input.dataset.moneyBound === '1') return;
      input.dataset.moneyBound = '1';

      input.addEventListener('input', () => {
        const amount = parseMoney(input.value);
        input.value = formatMoney(amount);
        setCaretToEnd(input);
        const key = input.dataset.input || '';
        if (key.startsWith('madera2bank-')) {
          scheduleBankInquiry(key.replace('madera2bank-', ''));
