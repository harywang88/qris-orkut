  // Animasi premium saat saldo berubah: angka bergulir (count-up) + pop-scale + glow (hijau naik / merah turun).
  function animateBal(sel, newNum) {
    const el = document.querySelector(sel);
    if (!el) return;
    newNum = Math.round(Number(newNum) || 0);
    let prev;
    if (el.dataset.val !== undefined && el.dataset.val !== '') prev = Number(el.dataset.val) || 0;
    else prev = Number(String(el.textContent).replace(/[^\d-]/g, '')) || 0;
    el.dataset.val = String(newNum);
    // Render pertama (saat menu dibuka) -> set instan, JANGAN animasi.
    if (!el.dataset.balInit) { el.dataset.balInit = '1'; el.textContent = rp(newNum); return; }
    if (prev === newNum) { el.textContent = rp(newNum); return; }
    const up = newNum > prev;
    // Kilau + pop
    el.classList.remove('bal-up', 'bal-down');
    void el.offsetWidth; // reflow -> restart animasi
    el.classList.add(up ? 'bal-up' : 'bal-down');
    const _clear = function () { el.classList.remove('bal-up', 'bal-down'); el.removeEventListener('animationend', _clear); };
    el.addEventListener('animationend', _clear);
    // Count-up angka (easeOutCubic)
    const from = prev, to = newNum, dur = 750;
    const t0 = (window.performance && performance.now) ? performance.now() : Date.now();
    function frame(now) {
      const p = Math.min(1, (((window.performance && performance.now) ? now : Date.now()) - t0) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = rp(Math.round(from + (to - from) * eased));
      if (p < 1) requestAnimationFrame(frame); else el.textContent = rp(to);
    }
    requestAnimationFrame(frame);
  }

  function updateCardBalanceFields(accountId, account) {
    if (!account) return;
    const setEl = (sel, val) => {
      const el = document.querySelector(sel);
      if (el) el.textContent = val;
    };
    animateBal(`[data-field="qris"][data-id="${accountId}"]`, account.lastQrisBalance ?? 0);
    animateBal(`[data-field="utama"][data-id="${accountId}"]`, account.lastMainBalance ?? 0);
    animateBal(`[data-field="madera"][data-id="${accountId}"]`, account.lastMaderaBalance ?? 0);

    // Tombol KIRIM hanya muncul jika saldo madera > 15.000 (ikut update live).
    const _kirimHdr = document.getElementById('kirim-hdr-' + accountId);
    if (_kirimHdr) {
      const _show = Number(account.lastMaderaBalance ?? 0) > 15000;
      _kirimHdr.style.display = _show ? '' : 'none';
      if (!_show) {
        const _body = document.getElementById('kirim-body-' + accountId);
        if (_body) _body.style.display = 'none';
      }
    }

    const syncEl = document.querySelector(`[data-sync-time="${accountId}"]`);
    if (syncEl && account.lastBalanceSyncAt) {
      syncEl.textContent = new Date(account.lastBalanceSyncAt).toLocaleTimeString('id-ID', {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        timeZone: 'Asia/Jakarta',
      });
    }

    const ownerBox = getOwnerBox(accountId);
    const hasMadera = account.lastMaderaBalance !== null && account.lastMaderaBalance !== undefined;
    const hasPin = ownerBox?.dataset.pinReady === '1';
    const transferReady = Boolean(hasMadera && hasPin);
    ['bank-code', 'bank-account', 'madera2bank'].forEach((key) => {
      const input = getInput(key, accountId);
      if (input) input.disabled = !transferReady;
    });
    const bankToggle = getBankToggle(accountId);
    const checkBtn = document.querySelector(`#kirim-body-${accountId} .setl-btn-blue`);
    const sendBtn = document.querySelector(`#kirim-body-${accountId} .setl-btn-orange`);
    if (bankToggle) bankToggle.disabled = !transferReady;
    if (checkBtn) checkBtn.disabled = !transferReady;
    if (sendBtn) sendBtn.disabled = !transferReady;
    if (ownerBox) {
      ownerBox.dataset.maderaReady = hasMadera ? '1' : '0';
      resetOwnerState(accountId);
    }
    if (!transferReady) {
      setBankDropdownOpen(accountId, false);
    }
    recomputeWalletTotals(true);
  }

  async function refreshSettlementAccount(accountId) {
    if (!accountId || refreshInflight.get(accountId)) return;
    refreshInflight.set(accountId, true);
    try {
      const badge = document.getElementById('upd-badge');
      if (badge) badge.textContent = 'Refreshing akun...';

      const qris = await refreshWalletBalance(accountId, 'qris');
      if (qris?.ok) updateCardBalanceFields(accountId, qris.account);

      const utama = await refreshWalletBalance(accountId, 'utama');
      if (utama?.ok) updateCardBalanceFields(accountId, utama.account);

      const madera = await refreshWalletBalance(accountId, 'madera');
      if (madera?.ok) updateCardBalanceFields(accountId, madera.account);

      if (badge) {
        badge.textContent = 'Updated: ' + new Date().toLocaleTimeString('id-ID', {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          timeZone: 'Asia/Jakarta',
        });
      }
    } catch {
      // keep settlement usable even if refresh fails
    } finally {
      refreshInflight.delete(accountId);
    }
  }

