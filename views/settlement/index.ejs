  // Update tampilan toggle 1 akun (tanpa memanggil server)
  function applySettlementToggle(id, active) {
    const track = document.getElementById('setl-tog-track-' + id);
    const thumb = document.getElementById('setl-tog-thumb-' + id);
    const cb = document.querySelector('.setl-acc-toggle[data-account-id="' + id + '"]');
