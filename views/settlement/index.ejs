  function setMoneyInputValue(input, amount) {
    if (!input) return;
    input.value = formatMoney(amount);
  }

  function setCaretToEnd(input) {
    if (!input || typeof input.setSelectionRange !== 'function') return;
    try {
      const length = input.value.length;
      input.setSelectionRange(length, length);
    } catch {
      // ignore unsupported input types
    }
  }

  function getInput(key, id) {
    return document.querySelector(`[data-input="${key}-${id}"]`);
  }

  function getOwnerBox(id) {
    return document.querySelector(`[data-owner-box="bank-owner-${id}"]`);
  }

  function getBankPicker(id) {
    return document.querySelector(`[data-bank-picker="${id}"]`);
  }

  function getBankDropdown(id) {
    return document.querySelector(`[data-bank-dropdown="${id}"]`);
  }

  function getBankOptionsWrap(id) {
    return document.querySelector(`[data-bank-options="${id}"]`);
  }

  function getBankCountEl(id) {
    return document.querySelector(`[data-bank-count="${id}"]`);
  }

  function getBankToggle(id) {
    return document.querySelector(`[data-bank-toggle="${id}"]`);
  }

  function compactBankKey(value) {
    return String(value || '').toUpperCase().replace(/[^A-Z0-9]+/g, '');
  }

  function normalizeBankValue(rawValue) {
    const raw = String(rawValue || '').trim();
    if (!raw) return '';
    const compact = compactBankKey(raw);
    const aliased = bankAliasLookup.get(compact);
    if (aliased) return aliased;
    const exact = bankLookup.get(compact);
    if (exact) return exact;
    const partial = orderedBankOptions.find((item) => compactBankKey(item).includes(compact));
    return partial || '';
  }

  function inferBankMeta(bankName) {
    return walletLikeBanks.has(compactBankKey(bankName))
      ? 'E-wallet / akun digital'
      : 'Transfer bank antar rekening';
  }

  function buildBankBadge(bankName) {
    return String(bankName || '')
      .split(/\s+/)
      .filter(Boolean)
      .slice(0, 2)
      .map((part) => part[0])
      .join('')
      .slice(0, 2)
      .toUpperCase() || 'BK';
  }

  function filterBankOptions(query) {
    const compact = compactBankKey(query);
    if (!compact) return orderedBankOptions.slice(0, 24);

    return orderedBankOptions
      .map((item) => {
        const itemKey = compactBankKey(item);
        const aliasHit = [...bankAliasLookup.entries()].some(([alias, bank]) => bank === item && alias.includes(compact));
        let score = 0;
        if (itemKey === compact) score = 400;
        else if (itemKey.startsWith(compact)) score = 300;
        else if (itemKey.includes(compact)) score = 200;
        else if (aliasHit) score = 150;
        return { item, score };
      })
      .filter((entry) => entry.score > 0)
      .sort((left, right) => right.score - left.score || left.item.localeCompare(right.item))
      .slice(0, 30)
      .map((entry) => entry.item);
  }

  function setBankDropdownOpen(acctId, open) {
    const dropdown = getBankDropdown(acctId);
    const toggle = getBankToggle(acctId);
    if (!dropdown) return;
    dropdown.hidden = !open;
    if (toggle) toggle.classList.toggle('open', open);
  }

  function closeAllBankDropdowns(exceptId = '') {
    document.querySelectorAll('[data-bank-dropdown]').forEach((dropdown) => {
      const acctId = dropdown.getAttribute('data-bank-dropdown') || '';
      if (exceptId && acctId === exceptId) return;
      setBankDropdownOpen(acctId, false);
    });
  }

  function renderBankOptions(acctId, query = '') {
    const wrap = getBankOptionsWrap(acctId);
    const countEl = getBankCountEl(acctId);
    const input = getInput('bank-code', acctId);
    if (!wrap || !input) return;

    const currentValue = normalizeBankValue(input.value);
    const results = filterBankOptions(query);
    wrap.replaceChildren();
    if (countEl) {
      countEl.textContent = `${results.length} hasil`;
    }

    if (results.length === 0) {
      const empty = document.createElement('div');
      empty.className = 'setl-bank-empty';
      empty.textContent = 'Bank tidak ditemukan. Coba kata kunci lain seperti BCA, Mandiri, atau Dana.';
      wrap.appendChild(empty);
      return;
    }

    const noQuery = !compactBankKey(query);
    let lastPinnedEl = null;
    results.forEach((bankName) => {
      const isPinned = noQuery && pinnedNameSet.has(bankName);
      const option = document.createElement('button');
      option.type = 'button';
      option.className = 'setl-bank-option'
        + (bankName === currentValue ? ' active' : '')
        + (isPinned ? ' setl-bank-option-pinned' : '');
      option.setAttribute('data-value', bankName);
      option.textContent = bankName;

      option.addEventListener('mousedown', (event) => {
        event.preventDefault();
      });
      option.addEventListener('click', () => {
        const bankInput = getInput('bank-code', acctId);
        if (!bankInput) return;
        bankInput.value = bankName;
        // Set SWIFT code in hidden input (use resolveSwiftCode for fallback)
        const swiftInput = getInput('bank-swift', acctId);
        if (swiftInput) swiftInput.value = resolveSwiftCode(bankName);
        resetOwnerState(acctId);
        renderBankOptions(acctId, bankName);
        setBankDropdownOpen(acctId, false);
        scheduleBankInquiry(acctId);
      });

      if (isPinned) lastPinnedEl = option;
      wrap.appendChild(option);
    });
    // Garis pemisah halus setelah 6 bank favorit (hanya saat daftar tak difilter)
    if (lastPinnedEl) lastPinnedEl.classList.add('setl-bank-sep');
  }

  // ── Toggle KIRIM UANG ────────────────────────────────────────────────────
  window.toggleKirim = function(id) {
    const body = document.getElementById('kirim-body-' + id);
    const chev = document.getElementById('kirim-chev-' + id);
    if (!body || !chev) return;
    const open = body.style.display === 'none';
    body.style.display = open ? '' : 'none';
    chev.style.transform = open ? 'rotate(180deg)' : '';
    if (open && !dynamicBanks) {
      // Eagerly load dynamic banks so SWIFT codes are available for Cek/Kirim
      fetchDynamicBanks(id).then(() => {
        // After dynamic banks load, update SWIFT code for any already-selected bank
        const swiftInput = getInput('bank-swift', id);
        const bankInput = getInput('bank-code', id);
        if (swiftInput && bankInput && bankInput.value && !swiftInput.value) {
          const resolved = resolveSwiftCode(normalizeBankValue(bankInput.value));
          if (resolved) swiftInput.value = resolved;
        }
      }).catch(() => {});
    }
  };

