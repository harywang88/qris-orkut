  async function fetchDynamicBanks(qrisAccountId) {
    if (dynamicBanks) return dynamicBanks;
    if (dynamicBanksFetchPromise) return dynamicBanksFetchPromise;
    dynamicBanksFetchPromise = (async () => {
      try {
        const res = await fetch(bankListUrl + '?qrisAccountId=' + encodeURIComponent(qrisAccountId));
        const json = await res.json();
        if (json.ok && Array.isArray(json.banks) && json.banks.length > 0) {
          dynamicBanks = json.banks;
          dynamicBanksByCode = new Map(json.banks.map(b => [b.code, b]));
          dynamicBanksByName = new Map(json.banks.map(b => [compactBankKey(b.name), b]));
          rebuildBankOptions(json.banks);
          // Re-render all open bank dropdowns
          document.querySelectorAll('[data-bank-search]').forEach(input => {
            const acctId = input.getAttribute('data-bank-search') || '';
            if (acctId) renderBankOptions(acctId, input.value);
          });
          return json.banks;
        }
      } catch (e) { /* fallback to hardcoded */ }
      return null;
    })();
    return dynamicBanksFetchPromise;
  }

  function rebuildBankOptions(banks) {
    // 6 bank favorit dipin di atas (cocokkan lewat SWIFT code = paling akurat), urutan sesuai PINNED_BANK_SWIFT
    const byCode = new Map(banks.map(b => [b.code, b.name]));
    const pinned = [];
    PINNED_BANK_SWIFT.forEach(code => {
      const name = byCode.get(code);
      if (name) pinned.push(name);
    });
    pinnedNameSet = new Set(pinned);
    const rest = banks
      .map(b => b.name)
      .filter(name => !pinnedNameSet.has(name))
      .sort((a, b) => a.localeCompare(b, 'id'));
    orderedBankOptions = [...pinned, ...rest];
    bankLookup = new Map(orderedBankOptions.map(item => [compactBankKey(item), item]));
    // Also add alias from SWIFT code → name
    banks.forEach(b => {
      bankAliasLookup.set(b.code, b.name);
    });
  }

  function getSwiftCodeForBank(bankDisplayName) {
    if (!dynamicBanks) return '';
    const entry = dynamicBanksByName.get(compactBankKey(bankDisplayName));
    return entry ? entry.code : '';
  }

  function getBankFeeText(bankDisplayName) {
    if (!dynamicBanks) return '';
    const entry = dynamicBanksByName.get(compactBankKey(bankDisplayName));
    if (!entry) return '';
    if (entry.fee === 0) return 'GRATIS';
    if (!entry.fee) return '';
    return 'Rp ' + entry.fee.toLocaleString('id-ID');
  }

