  function setlConfirm(opts) {
    return new Promise((resolve) => {
      const ov = document.createElement('div');
      ov.className = 'setl-confirm-overlay';
      const rowsHtml = (opts.rows || []).map((r) =>
        '<div class="setl-confirm-row"><span>' + r.label + '</span><strong class="' + (r.hl ? 'hl' : '') + '">' + r.value + '</strong></div>'
      ).join('');
      ov.innerHTML =
        '<div class="setl-confirm-card" role="dialog" aria-modal="true">' +
          '<div class="setl-confirm-ico"><i class="fa-solid ' + (opts.icon || 'fa-circle-question') + '"></i></div>' +
          '<div class="setl-confirm-title">' + (opts.title || 'Konfirmasi') + '</div>' +
          (opts.subtitle ? '<div class="setl-confirm-sub">' + opts.subtitle + '</div>' : '') +
          (rowsHtml ? '<div class="setl-confirm-rows">' + rowsHtml + '</div>' : '') +
          '<div class="setl-confirm-actions">' +
            '<button type="button" class="setl-confirm-btn cancel">Batal</button>' +
            '<button type="button" class="setl-confirm-btn ok ' + (opts.confirmClass || '') + '">' + (opts.confirmText || 'Ya') + '</button>' +
          '</div>' +
        '</div>';
      document.body.appendChild(ov);
      requestAnimationFrame(() => ov.classList.add('open'));
      const close = (val) => { ov.classList.remove('open'); setTimeout(() => ov.remove(), 220); resolve(val); };
      ov.querySelector('.cancel').addEventListener('click', () => close(false));
      ov.querySelector('.ok').addEventListener('click', () => close(true));
      ov.addEventListener('click', (e) => { if (e.target === ov) close(false); });
      document.addEventListener('keydown', function esc(e) { if (e.key === 'Escape') { document.removeEventListener('keydown', esc); close(false); } });
    });
  }
  window.setlConfirm = setlConfirm;

  const escP = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m]));

  // Bersihkan pesan: buang marker [[FEE/TOTAL/REDIRECT_URL:...]] (base64 panjang) + prefix "Error:".
  const cleanMsg = (s) => String(s == null ? '' : s)
