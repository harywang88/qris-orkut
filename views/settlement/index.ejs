    <% accounts.forEach(acct => { %>
      <label class="setl-bulk-row">
        <input type="checkbox" class="setl-bulk-acc"
               data-id="<%= acct.id %>"
               data-name="<%= acct.merchantName %>"
               data-wmax="<%= acct.withdrawMax ?? 0 %>"
               <%= acct.status === 'active' ? 'checked' : '' %>
               onchange="updateBulkCount()">
        <span class="setl-bulk-row-name"><%= acct.merchantName %><% if (acct.status !== 'active') { %><span class="setl-bulk-off">nonaktif</span><% } %></span>
        <span class="setl-bulk-row-bal">QRIS <%= fmtRp(acct.lastQrisBalance ?? 0) %> &middot; Utama <%= fmtRp(acct.lastMainBalance ?? 0) %></span>
      </label>
    <% }) %>
  </div>
</div>

<!-- Settlement History -->
<div class="qris-table-wrap">
  <div class="setl-hist-header">
    <h3 class="setl-hist-title">
      <i class="fa-solid fa-money-bill-transfer" style="font-size:14px;color:var(--accent)"></i>
      Riwayat Transfer
      <span class="setl-hist-count" id="hist-count">(<%= settlements.length %> request)</span>
    </h3>
    <div class="setl-hist-controls">
      <div class="setl-hist-dates" id="hist-date-tabs">
        <button type="button" class="setl-hist-datebtn active" data-range="all" onclick="setHistRange('all',this)">Semua</button>
        <button type="button" class="setl-hist-datebtn" data-range="today" onclick="setHistRange('today',this)">Hari ini</button>
        <button type="button" class="setl-hist-datebtn" data-range="yesterday" onclick="setHistRange('yesterday',this)">Kemarin</button>
        <button type="button" class="setl-hist-datebtn" data-range="custom" onclick="setHistRange('custom',this)">Custom</button>
      </div>
      <div class="setl-hist-custom" id="hist-custom" hidden>
        <input type="date" id="hist-from" onchange="applyHistFilter()">
        <span>&mdash;</span>
        <input type="date" id="hist-to" onchange="applyHistFilter()">
      </div>
      <select id="hist-filter" class="setl-hist-filter">
        <option value="">Semua status</option>
        <option value="pending">Pending</option>
        <option value="processing">Processing</option>
        <option value="done">Done</option>
        <option value="failed">Failed</option>
      </select>
    </div>
  </div>
  <div class="overflow-x-auto">
    <table class="qris-table" id="hist-table">
      <thead>
        <tr>
          <th>Waktu</th>
          <th>Dari</th>
          <th>Ke</th>
          <th class="text-right">Nominal</th>
          <th class="text-right hidden md:table-cell">Biaya</th>
          <th class="text-right hidden md:table-cell">Total</th>
          <th class="text-center">Status</th>
          <th class="hidden lg:table-cell">Ref</th>
          <th class="hidden lg:table-cell">Keterangan</th>
          <th class="text-center">Aksi</th>
        </tr>
      </thead>
      <tbody id="hist-tbody">
        <% if (settlements.length === 0) { %>
          <tr><td colspan="10">
            <div class="qris-empty py-10">
              <i class="fa-solid fa-money-bill-transfer qris-empty-icon"></i>
              <p class="qris-empty-title">Belum ada transfer</p>
            </div>
          </td></tr>
        <% } %>
        <% settlements.forEach(s => {
          const pillClass = { pending:'qris-pill-warn', processing:'qris-pill-open', done:'qris-pill-paid', failed:'qris-pill-danger' }[s.status] || 'qris-pill-muted';
          const flowFrom = { qris:'QRIS', utama:'Utama', madera:'Madera' }[s.fromWallet] || s.fromWallet;
          const flowTo   = { utama:'Utama', madera:'Madera', bank:'Bank' }[s.toWallet] || s.toWallet;
          const timeStr  = new Date(s.createdAt).toLocaleString('id-ID', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit', timeZone:'Asia/Jakarta' });
          const redirectUrl = extractSettlementRedirectUrl(s.note);
          const cleanNote = cleanSettlementNote(s.note);
          const feeAmount = extractSettlementFee(s.note);
          const totalAmount = extractSettlementTotal(s.note) ?? (s.amount + Math.max(0, feeAmount || 0));
        %>
          <tr data-status="<%= s.status %>" data-ts="<%= new Date(s.createdAt).getTime() %>">
            <td class="text-xs text-muted whitespace-nowrap"><%= timeStr %></td>
            <td><span class="qris-pill qris-pill-open uppercase" style="font-size:10px"><%= flowFrom %></span></td>
            <td><span class="qris-pill qris-pill-violet uppercase" style="font-size:10px"><%= flowTo %></span></td>
            <td class="text-right font-semibold text-ink text-sm">Rp <%= s.amount.toLocaleString('id-ID') %></td>
            <td class="text-right font-semibold text-orange-300 text-sm hidden md:table-cell"><%= feeAmount !== null ? `Rp ${feeAmount.toLocaleString('id-ID')}` : '—' %></td>
            <td class="text-right font-semibold text-emerald-300 text-sm hidden md:table-cell">Rp <%= totalAmount.toLocaleString('id-ID') %></td>
            <td class="text-center"><span class="qris-pill <%= pillClass %>"><%= s.status %></span></td>
            <td class="text-xs text-muted hidden lg:table-cell font-mono" style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
              <%= s.referenceNo || '—' %>
            </td>
            <td class="text-xs text-muted hidden lg:table-cell" style="max-width:280px">
              <div class="setl-hist-note-wrap">
                <div style="max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                  <%= cleanNote || '—' %>
                </div>
                <% if (redirectUrl) { %>
                  <button
                    type="button"
                    class="setl-hist-action"
                    onclick='openTransferFlowModal(<%- JSON.stringify({
                      settlementId: s.id,
                      referenceNo: s.referenceNo || null,
                      redirectUrl,
                      bankName: s.bankName || null,
                      bankAccount: s.bankAccount || null,
                      amount: s.amount,
                      message: cleanNote || null,
                      status: s.status,
                    }) %>)'>
                    <i class="fa-solid fa-link"></i>
                    Lanjutkan PIN
                  </button>
                <% } %>
              </div>
            </td>
            <td class="text-center">
              <button type="button" class="setl-hist-dl" title="Download bukti transfer"
                onclick='downloadReceipt(<%- JSON.stringify({
                  time: timeStr,
                  merchant: (accounts.find(a => a.id === s.qrisAccountId) || {}).merchantName || null,
                  from: flowFrom,
                  to: flowTo,
                  amount: s.amount,
                  fee: feeAmount,
                  total: totalAmount,
                  status: s.status,
                  ref: s.referenceNo || null,
                  bankName: s.bankName || (s.toWallet === "bank" ? (s.bankCode || null) : null),
                  bankAccount: s.bankAccount || null,
                  note: cleanNote || null
                }) %>)'>
                <i class="fa-solid fa-download"></i>
              </button>
              <% if (s.toWallet === 'bank') { %>
                <button type="button" class="setl-hist-dl setl-proof-btn" data-id="<%= s.id %>" title="Bukti resmi Nobu (screenshot bot)" onclick="onProofClick('<%= s.id %>', this)">
                  <i class="fa-solid fa-lock"></i>
                </button>
              <% } %>
            </td>
          </tr>
        <% }); %>
        <tr id="hist-empty-filter" hidden><td colspan="10">
          <div class="qris-empty py-10">
            <i class="fa-solid fa-filter-circle-xmark qris-empty-icon"></i>
            <p class="qris-empty-title">Tidak ada transfer pada filter ini</p>
          </div>
        </td></tr>
      </tbody>
    </table>
  </div>
  <div class="setl-hist-pager" id="hist-pager" style="display:none">
    <button type="button" id="hist-prev" onclick="histPage(-1)"><i class="fa-solid fa-chevron-left" style="font-size:10px"></i> Sebelumnya</button>
    <span class="setl-hist-pageinfo" id="hist-pageinfo">Hal 1</span>
    <button type="button" id="hist-next" onclick="histPage(1)">Berikutnya <i class="fa-solid fa-chevron-right" style="font-size:10px"></i></button>
  </div>
</div>

<script>
(function () {
  const transferUrl = '<%= url('/dashboard/settlement/transfer') %>';
  const inquiryUrl = '<%= url('/dashboard/settlement/inquiry') %>';
  const retryPinUrl = '<%= url('/dashboard/settlement/retry-pin') %>';
  const bankListUrl = '<%= url('/dashboard/settlement/banks') %>';
  const apiRefreshBalanceUrlTemplate = '<%= url('/dashboard/api/qris-accounts/__ACCOUNT_ID__/refresh-balance') %>';
  const bankOptions = <%- JSON.stringify(BANKS) %>;
  // 6 bank teratas (sering dipakai) — sisanya alfabet
  const PINNED_BANK_NAMES = ['BCA', 'Mandiri', 'BNI', 'BRI', 'SeaBank', 'Permata']; // utk daftar statis (fallback)
  const PINNED_BANK_SWIFT = ['CENAIDJA', 'BMRIIDJA', 'BNINIDJA', 'BRINIDJA', 'SSPIIDJA', 'BBBAIDJA']; // = BCA, Mandiri, BNI, BRI, SeaBank, Permata (daftar dinamis Nobu)
  let pinnedNameSet = new Set(PINNED_BANK_NAMES.filter((item) => bankOptions.includes(item)));
  let orderedBankOptions = [
    ...PINNED_BANK_NAMES.filter((item) => bankOptions.includes(item)),
    ...bankOptions.filter((item) => !pinnedNameSet.has(item)).sort((a, b) => a.localeCompare(b, 'id')),
  ];
  // ── Client-side SWIFT code fallback map (used when dynamic banks not yet loaded) ──
  const BANK_SWIFT_MAP = {
    'BCA': 'CENAIDJA', 'BRI': 'BRINIDJA', 'BNI': 'BNINIDJA', 'Mandiri': 'BMRIIDJA',
    'CIMB Niaga': 'BNIAIDJA', 'Danamon': 'BDINIDJA', 'Permata': 'BBBAIDJA', 'BTN': 'BTANIDJA',
    'Panin': 'PINBIDJA', 'Maybank': 'IBBKIDJA', 'OCBC NISP': 'NISPIDJA', 'BTPN': 'PUBAIDJ1',
    'Mega': 'MEGAIDJA', 'Bukopin': 'BBUKIDJA', 'Sinarmas': 'SBJKIDJA', 'Bank Sinarmas': 'SBJKIDJA',
    'MNC Bank': 'BUMIIDJA', 'Artha Graha': 'MCORIDJA', 'Jago': 'JAGBIDJA', 'Allo Bank': 'ALOBIDJA',
    'SeaBank': 'SSPIIDJA', 'Bank Neo Commerce': 'YUDBIDJ1', 'Bank Raya': 'AGTBIDJA',
    'Bank Amar': 'LOMAIDJ1', 'Bank Sahabat Sampoerna': 'SAHMIDJA', 'Bank Index': 'BIDXIDJA',
    'Bank Ganesha': 'GNESIDJA', 'Bank Ina Perdana': 'IAPTIDJA', 'Bank Maspion': 'MASDIDJ1',
