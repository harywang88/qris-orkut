  window.fillAll = function(id, key, amount) {
    // Bulatkan ke bawah kelipatan 1.000 (mis. 38.827 -> 38.000)
    var rounded = Math.floor((Number(amount) || 0) / 1000) * 1000;
    setMoneyInputValue(getInput(key, id), rounded);
