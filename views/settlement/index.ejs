  /**
   * Resolve a bank display name to its SWIFT/BIC code.
   * Priority: dynamic bank list (from API) → hardcoded BANK_SWIFT_MAP → original name.
   */
  function resolveSwiftCode(bankDisplayName) {
    if (!bankDisplayName) return '';
    // If already looks like a SWIFT code (all uppercase alphanumeric, 6-15 chars), return as-is
    if (/^[A-Z0-9]{6,15}$/.test(bankDisplayName)) return bankDisplayName;
    // 1. Try dynamic banks (from API)
    const dynamicCode = getSwiftCodeForBank(bankDisplayName);
    if (dynamicCode) return dynamicCode;
    // 2. Try hardcoded SWIFT map (exact match)
    if (BANK_SWIFT_MAP[bankDisplayName]) return BANK_SWIFT_MAP[bankDisplayName];
    // 3. Try case-insensitive match
    const lower = bankDisplayName.toLowerCase();
    for (const [name, code] of Object.entries(BANK_SWIFT_MAP)) {
      if (name.toLowerCase() === lower) return code;
    }
    // 4. Fallback: return display name (backend will try to resolve)
    return bankDisplayName;
  }

