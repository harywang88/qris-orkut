  async function retryAutoPin() {
    if (!activeTransferFlow?.settlementId) return;
    const btn = document.getElementById('auto-pin-btn');
    const statusEl = document.getElementById('auto-pin-status');
    const descEl = document.getElementById('auto-pin-desc');
    const panel = document.getElementById('auto-pin-panel');
    if (!btn) return;

    const origHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Memproses PIN...';
    if (statusEl) { statusEl.style.display = 'block'; statusEl.textContent = 'Menghubungi server...'; }

    try {
      const response = await fetch(retryPinUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ settlementId: activeTransferFlow.settlementId }),
      });
      const data = await response.json();

      if (data.ok) {
        if (panel) panel.className = 'setl-flow-panel primary';
        if (descEl) descEl.textContent = 'Auto PIN berhasil! Transfer telah selesai.';
        if (statusEl) {
          statusEl.style.display = 'block';
