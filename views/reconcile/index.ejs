<%
  function fmtWib(d) {
    if (!d) return '-';
    try {
      var t = new Date(new Date(d).getTime() + 7 * 3600000);
      var p = function (n) { return String(n).padStart(2, '0'); };
      return p(t.getUTCDate()) + '/' + p(t.getUTCMonth() + 1) + ' ' + p(t.getUTCHours()) + ':' + p(t.getUTCMinutes()) + ':' + p(t.getUTCSeconds());
    } catch (e) { return '-'; }
  }
  function rp(n) { return 'Rp ' + Number(n || 0).toLocaleString('id-ID'); }
  function badge(s) {
    if (s === 'match') return '<span class="rk-badge" style="background:rgba(34,197,94,.16);color:#4ade80"><i class="fa-solid fa-circle-check"></i> MATCH</span>';
    if (s === 'pending') return '<span class="rk-badge" style="background:rgba(251,191,36,.16);color:#fbbf24"><i class="fa-solid fa-clock"></i> PENDING</span>';
    return '<span class="rk-badge" style="background:rgba(239,68,68,.16);color:#f87171"><i class="fa-solid fa-triangle-exclamation"></i> UNMATCH</span>';
  }
  var sections = [
    { h: 1, rows: hop1, sum: summary.hop1, title: 'QRIS → Utama', sub: 'Pencairan Saldo QRIS → Saldo Utama · cocok by nominal + akun + waktu (±3 mnt)' },
    { h: 2, rows: hop2, sum: summary.hop2, title: 'Utama → Madera', sub: 'Pindah Saldo ke Madera → TOPUP Madera · cocok by kode P# (gratis, tanpa biaya)' }
  ];
%>
<style>
  .rk-badge { display:inline-block; padding:2px 9px; border-radius:999px; font-size:11px; font-weight:700; white-space:nowrap; }
  .rk-table th { font-size:10px; text-transform:uppercase; letter-spacing:.06em; color:var(--muted,#8b8b8b); text-align:left; padding:8px 10px; border-bottom:1px solid rgba(255,255,255,.08); }
  .rk-table td { padding:9px 10px; border-bottom:1px solid rgba(255,255,255,.05); vertical-align:top; }
  .rk-table tbody tr:hover { background:rgba(255,255,255,.03); }
  .rk-stat { border:1px solid rgba(255,255,255,.08); border-radius:12px; padding:10px 12px; }
  .rk-stat .n { font-size:18px; font-weight:800; line-height:1; }
  .rk-stat .l { font-size:10px; text-transform:uppercase; letter-spacing:.05em; color:var(--muted,#8b8b8b); margin-top:4px; }
</style>

<div class="qris-page-header flex flex-wrap items-start justify-between gap-4">
  <div>
    <h1 class="qris-page-title">Rekonsiliasi <span>Saldo</span></h1>
    <p class="qris-section-sub mt-1">Cocokkan perpindahan uang KELUAR antar-saldo: QRIS → Utama → Madera</p>
  </div>
  <form method="get" style="display:flex;align-items:center;gap:8px">
    <label class="text-xs text-muted-2">Rentang</label>
    <select name="days" onchange="this.form.submit()" class="text-sm" style="padding:6px 10px;border-radius:8px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.15);color:inherit">
      <% [1,3,7,14,30].forEach(function(d){ %><option value="<%= d %>" <%= days===d?'selected':'' %>><%= d %> hari</option><% }); %>
    </select>
  </form>
</div>

<% sections.forEach(function (sec) { %>
  <div class="qris-card p-4 mb-5">
    <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
      <div>
        <h2 class="text-base font-bold text-ink">Hop <%= sec.h %>: <%= sec.title %></h2>
        <p class="text-xs text-muted-2"><%= sec.sub %></p>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-4">
      <div class="rk-stat"><div class="n text-ink"><%= sec.sum.total %></div><div class="l">Total OUT</div></div>
      <div class="rk-stat" style="border-color:rgba(34,197,94,.2)"><div class="n" style="color:#4ade80"><%= sec.sum.match %></div><div class="l">Match</div></div>
      <div class="rk-stat" style="border-color:rgba(251,191,36,.2)"><div class="n" style="color:#fbbf24"><%= sec.sum.pending %></div><div class="l">Pending</div></div>
      <div class="rk-stat" style="border-color:rgba(239,68,68,.2)"><div class="n" style="color:#f87171"><%= sec.sum.unmatch %></div><div class="l">Unmatch</div></div>
      <div class="rk-stat"><div class="n text-ink" style="font-size:14px">Rp <%= sec.sum.selisih.toLocaleString('id-ID') %></div><div class="l">Selisih (belum match)</div></div>
    </div>

    <% if (!sec.rows.length) { %>
      <div class="text-center py-6 text-muted-2 text-sm"><i class="fa-solid fa-circle-check mr-1" style="color:#86efac"></i> Tak ada perpindahan pada rentang ini.</div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full rk-table">
        <thead>
          <tr>
            <th>Waktu Keluar</th>
            <th>Akun</th>
            <th class="text-right">Nominal</th>
            <th>Status</th>
            <th>Pasangan Masuk</th>
            <% if (sec.h === 2) { %><th>Kode P#</th><% } %>
          </tr>
        </thead>
        <tbody>
          <% sec.rows.slice(0, 300).forEach(function (r) { %>
            <tr>
              <td class="whitespace-nowrap text-muted-2"><%= fmtWib(r.outTime) %></td>
              <td class="whitespace-nowrap text-ink font-semibold"><%= r.accountCode %></td>
              <td class="text-right font-mono font-bold whitespace-nowrap text-ink"><%= rp(r.amount) %></td>
              <td><%- badge(r.status) %></td>
              <td class="text-xs">
                <% if (r.inTime) { %>
                  <span class="text-muted-2"><%= fmtWib(r.inTime) %></span>
                  <span class="block text-[10px] text-muted"><%= (r.inKet || '').slice(0, 46) %></span>
                <% } else { %>
                  <span class="text-[11px]" style="color:#f87171">— belum ada uang masuk —</span>
                <% } %>
              </td>
              <% if (sec.h === 2) { %><td class="text-[10px] font-mono text-muted"><%= r.code || '-' %></td><% } %>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <% if (sec.rows.length > 300) { %><p class="text-[11px] text-muted mt-2">Menampilkan 300 dari <%= sec.rows.length %> baris (perbesar rentang untuk memfilter).</p><% } %>
    </div>
    <% } %>
  </div>
<% }); %>

<div class="qris-card p-3" style="border-color:rgba(96,165,250,.2);background:rgba(96,165,250,.04)">
  <p class="text-xs text-muted-2"><i class="fa-solid fa-circle-info mr-1" style="color:#60a5fa"></i>
    <b>MATCH</b> = uang keluar sudah ada pasangan masuknya (normal). <b>PENDING</b> = baru keluar (≤3 mnt), pasangan mungkin menyusul. <b>UNMATCH</b> = sudah lewat 3 menit tapi belum ada uang masuk — <b>perlu dicek</b>. Biaya percepatan 1% menyusul saat ada contohnya.</p>
</div>
