<style>
  .auth-login {
    width: 100%;
    color: var(--ink);
  }

  /* Mobile-only brand (shown when the green aside is hidden) */
  .auth-login-brand {
    display: none;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
  }

  .auth-login-brand-icon {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    display: grid;
    place-items: center;
    font-weight: 800;
    color: #fff;
    background: var(--brand-600);
  }

  .auth-login-brand strong {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--ink);
  }

  @media (max-width: 900px) {
    .auth-login-brand { display: flex; }
  }

  /* ── Heading ──────────────────────────────────── */
  .auth-login-title {
    margin: 0 0 6px;
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .auth-login-subtitle {
    margin: 0 0 28px;
    color: var(--ink-muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  /* ── Error ────────────────────────────────────── */
  .auth-login-error {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 20px;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid #fecaca;
    background: #fef2f2;
    color: #b91c1c;
    font-size: 0.86rem;
    line-height: 1.5;
  }

  /* ── Form ─────────────────────────────────────── */
  .auth-login-form {
    display: grid;
    gap: 18px;
  }

  .auth-login-field {
    display: grid;
    gap: 7px;
  }

  .auth-login-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: #334155;
  }

  .auth-login-input-wrap {
    position: relative;
  }

  .auth-login-input {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: #fff;
    padding: 12px 14px 12px 42px;
    color: var(--ink);
    font-size: 0.94rem;
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .auth-login-input::placeholder {
    color: #94a3b8;
  }

  .auth-login-input:focus {
    border-color: var(--brand-500);
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.14);
  }

  .auth-login-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-size: 0.9rem;
    pointer-events: none;
    transition: color 0.15s ease;
  }

  .auth-login-input-wrap:focus-within .auth-login-icon {
    color: var(--brand-600);
  }

  .auth-login-password-btn {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border: 0;
    border-radius: 8px;
    background: transparent;
    color: #94a3b8;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .auth-login-password-btn:hover {
    background: #f1f5f9;
    color: #475569;
  }

  /* ── Submit ───────────────────────────────────── */
  .auth-login-submit {
    margin-top: 4px;
    border: 0;
    border-radius: 10px;
    padding: 13px 20px;
    width: 100%;
    background: var(--brand-600);
    color: #fff;
    font-size: 0.96rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .auth-login-submit:hover {
    background: var(--brand-700);
  }

  /* ── Footer ───────────────────────────────────── */
  .auth-login-foot {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 26px;
    padding-top: 22px;
    border-top: 1px solid var(--line);
    color: var(--ink-muted);
    font-size: 0.76rem;
  }

  .auth-login-foot span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .auth-login-foot i {
    color: var(--brand-600);
  }
</style>

<div class="auth-login">
  <!-- Brand (visible only on small screens) -->
  <div class="auth-login-brand">
    <div class="auth-login-brand-icon">QK</div>
    <strong>QRISKITA</strong>
  </div>

  <h1 class="auth-login-title">Masuk ke akun Anda</h1>
  <p class="auth-login-subtitle">Silakan masukkan kredensial admin untuk melanjutkan.</p>

  <% if (error) { %>
    <div class="auth-login-error">
      <i class="fa-solid fa-circle-exclamation"></i>
      <span><%= error %></span>
    </div>
  <% } %>

  <form class="auth-login-form" action="<%= url('/login') %>" method="POST">
    <div class="auth-login-field">
      <label class="auth-login-label" for="username">Username</label>
      <div class="auth-login-input-wrap">
        <i class="fa-regular fa-user auth-login-icon"></i>
        <input
          class="auth-login-input"
          type="text"
          id="username"
          name="username"
          autocomplete="username"
          placeholder="Masukkan username admin"
          required
          autofocus
        />
      </div>
    </div>

    <div class="auth-login-field">
      <label class="auth-login-label" for="password">Password</label>
      <div class="auth-login-input-wrap">
        <i class="fa-solid fa-lock auth-login-icon"></i>
        <input
          class="auth-login-input"
          type="password"
          id="password"
          name="password"
          autocomplete="current-password"
          placeholder="Masukkan password"
          required
          style="padding-right: 46px;"
        />
        <button class="auth-login-password-btn" type="button" onclick="toggleAuthPassword()" aria-label="Tampilkan password">
          <i id="auth-eye-icon" class="fa-regular fa-eye"></i>
        </button>
      </div>
    </div>

    <button class="auth-login-submit" type="submit">Sign in</button>
  </form>

  <div class="auth-login-foot">
    <span><i class="fa-solid fa-lock"></i> Session terenkripsi</span>
    <span><i class="fa-solid fa-shield-halved"></i> Operator internal</span>
  </div>
</div>

<script>
  function toggleAuthPassword() {
    const passwordInput = document.getElementById("password");
    const eyeIcon = document.getElementById("auth-eye-icon");
    const showing = passwordInput.type === "text";

    passwordInput.type = showing ? "password" : "text";
    eyeIcon.className = showing ? "fa-regular fa-eye" : "fa-regular fa-eye-slash";
  }
</script>
