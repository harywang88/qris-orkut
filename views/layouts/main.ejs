<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%- typeof title !== 'undefined' ? `${title} | ` : '' %>QRIS Hub</title>

  <!-- Inter Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" /></noscript>

  <!-- Apply saved theme immediately to prevent flash (default: day/light mode) -->
  <script>
    (function() {
      var t = localStorage.getItem('qris-theme');
      // Default ke day mode: light aktif kecuali pengguna memilih dark secara eksplisit
      if (t !== 'dark') document.documentElement.classList.add('light');
    })();
  </script>
  <link rel="stylesheet" href="<%= url('/css/tailwind.css') %>" />

  <link rel="stylesheet" href="<%= url('/vendor/tabulator_simple.min.css') %>" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" /></noscript>
  <link rel="stylesheet" href="<%= url('/css/app.css') %>?v=20260711-sidebar-collapse2" />
  <!-- Tabulator & Chart.js SELF-HOST (dari harywang.online, bukan unpkg/jsdelivr) -> load cepat & tak blocking lama -->
  <script src="<%= url('/vendor/chart.umd.min.js') %>"></script>
  <script src="<%= url('/vendor/tabulator.min.js') %>"></script>
  <%- typeof styles !== 'undefined' ? styles : '' %>
</head>
<body class="qris-shell font-sans antialiased">

  <!-- Mobile sidebar overlay -->
  <div class="qris-sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

  <div class="flex min-h-screen">
    <%- include('../partials/sidebar') %>

    <div class="flex min-w-0 flex-1 flex-col overflow-hidden">
      <%- include('../partials/navbar') %>

      <main class="flex-1 overflow-y-auto px-5 py-6 md:px-7 qris-page-enter">
        <%- include('../partials/flash') %>
        <%- body %>
      </main>
    </div>
  </div>

  <script src="<%= url('/js/qr-modal.js') %>"></script>

  <!-- Theme toggle logic -->
  <script>
    function toggleTheme() {
      var html = document.documentElement;
      var isLight = html.classList.toggle('light');
      localStorage.setItem('qris-theme', isLight ? 'light' : 'dark');

      // Fix inline styles on navbar that reference hardcoded dark rgba values
      fixInlineNavbarStyles(isLight);
    }

    function fixInlineNavbarStyles(isLight) {
      // Settings gear button
      var gear = document.querySelector('.qris-navbar a[title="Pengaturan"]');
      if (gear) {
        if (isLight) {
          gear.style.background = 'rgba(0,0,0,0.04)';
          gear.style.borderColor = 'var(--line)';
          gear.style.color = 'var(--muted)';
          gear.onmouseover = function() { this.style.background='rgba(0,0,0,0.07)'; this.style.color='var(--ink)'; };
          gear.onmouseout = function() { this.style.background='rgba(0,0,0,0.04)'; this.style.color='var(--muted)'; };
        } else {
          gear.style.background = 'rgba(255,255,255,0.04)';
          gear.style.borderColor = 'rgba(255,255,255,0.08)';
          gear.style.color = 'var(--color-muted)';
          gear.onmouseover = function() { this.style.background='rgba(255,255,255,0.08)'; this.style.color='var(--color-ink)'; };
          gear.onmouseout = function() { this.style.background='rgba(255,255,255,0.04)'; this.style.color='var(--color-muted)'; };
        }
      }

      // Logout button
      var logout = document.querySelector('.qris-navbar form[action*="logout"] button');
      if (logout) {
        if (isLight) {
          logout.style.background = 'rgba(239,68,68,0.07)';
          logout.style.borderColor = 'rgba(239,68,68,0.2)';
          logout.style.color = '#dc2626';
          logout.onmouseover = function() { this.style.background='rgba(239,68,68,0.12)'; this.style.borderColor='rgba(239,68,68,0.35)'; };
          logout.onmouseout = function() { this.style.background='rgba(239,68,68,0.07)'; this.style.borderColor='rgba(239,68,68,0.2)'; };
        } else {
          logout.style.background = 'rgba(239,68,68,0.08)';
          logout.style.borderColor = 'rgba(239,68,68,0.25)';
          logout.style.color = '#fca5a5';
          logout.onmouseover = function() { this.style.background='rgba(239,68,68,0.16)'; this.style.borderColor='rgba(239,68,68,0.4)'; };
          logout.onmouseout = function() { this.style.background='rgba(239,68,68,0.08)'; this.style.borderColor='rgba(239,68,68,0.25)'; };
        }
      }

      // Navbar divider
      var divider = document.querySelector('.qris-navbar [style*="width:1px"]');
      if (divider) {
        divider.style.background = isLight ? 'var(--line)' : 'rgba(255,255,255,0.1)';
      }
    }

    // Apply fixes on page load if light theme is active
    document.addEventListener('DOMContentLoaded', function() {
      if (document.documentElement.classList.contains('light')) {
        fixInlineNavbarStyles(true);
      }
    });
  </script>

  <script>
    // Mobile sidebar toggle
    function openSidebar() {
      document.querySelector('.qris-sidebar').classList.add('is-open');
      document.getElementById('sidebarOverlay').classList.add('is-open');
    }
    function closeSidebar() {
      document.querySelector('.qris-sidebar').classList.remove('is-open');
      document.getElementById('sidebarOverlay').classList.remove('is-open');
    }

    // Desktop: ciutkan/besarkan sidebar (mode ikon). State disimpan agar persist antar halaman.
    function applySidebarTitles(collapsed) {
      // Saat ciut, pasang tooltip (title) berisi label menu supaya tetap terbaca saat hover ikon.
      document.querySelectorAll('.qris-sidebar .qris-nav-link, .qris-sidebar .qris-nav-parent').forEach(function (link) {
        var label = link.querySelector('span > span');
        if (collapsed && label) link.setAttribute('title', label.textContent.trim());
        else link.removeAttribute('title');
      });
    }
    function toggleSidebarCollapse() {
      var collapsed = document.body.classList.toggle('sidebar-collapsed');
      try { localStorage.setItem('qris-sidebar-collapsed', collapsed ? '1' : '0'); } catch (e) {}
      applySidebarTitles(collapsed);
    }
    // Terapkan state tersimpan saat halaman dimuat.
    (function restoreSidebarCollapse() {
      var collapsed = false;
      try { collapsed = localStorage.getItem('qris-sidebar-collapsed') === '1'; } catch (e) {}
      if (collapsed) document.body.classList.add('sidebar-collapsed');
      document.addEventListener('DOMContentLoaded', function () { applySidebarTitles(collapsed); });
    })();

    // Animate number counters
    function animateCounter(el) {
      const target = parseFloat(el.dataset.count);
      if (isNaN(target)) return;
      const isCurrency = el.dataset.currency === '1';
      const duration = 1000;
      const steps = 40;
      const increment = target / steps;
      let current = 0;
      let step = 0;
      const timer = setInterval(() => {
        step++;
        current = step >= steps ? target : Math.floor(increment * step);
        el.textContent = isCurrency
          ? 'Rp ' + current.toLocaleString('id-ID')
          : current.toLocaleString('id-ID');
        if (step >= steps) clearInterval(timer);
      }, duration / steps);
    }

    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('[data-count]').forEach(animateCounter);
    });
  </script>
  <% if (user && !user.isMaster) { %>
  <!-- Auto-logout: 60 menit tanpa aktivitas (kecuali master 'harywang'). Peringatan 60 dtk sebelum. -->
  <script>
    (function () {
      var IDLE_MS = 60 * 60 * 1000;   // 60 menit tanpa aktivitas
      var WARN_MS = 60 * 1000;        // munculkan peringatan 60 detik sebelum logout
      var LOGOUT_URL = '<%= url('/logout') %>';
      var idleTimer = null, warnTimer = null, tick = null, warning = false, deadline = 0, last = 0;

      function doLogout() {
        clearInterval(tick); clearTimeout(idleTimer); clearTimeout(warnTimer);
        var f = document.createElement('form');
        f.method = 'POST'; f.action = LOGOUT_URL;
        document.body.appendChild(f); f.submit();
      }
      function overlay() {
        var o = document.getElementById('idle-warn');
        if (o) return o;
        o = document.createElement('div');
        o.id = 'idle-warn';
        o.style.cssText = 'position:fixed;inset:0;z-index:99999;display:none;align-items:center;justify-content:center;background:rgba(0,0,0,0.55);backdrop-filter:blur(2px)';
        o.innerHTML = '<div style="background:var(--surface,#0f172a);color:var(--ink,#fff);border:1px solid var(--line,rgba(255,255,255,0.12));border-radius:16px;padding:24px 22px;max-width:340px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.5);font-family:Inter,system-ui,sans-serif">'
          + '<div style="font-size:34px;margin-bottom:6px">⏳</div>'
          + '<div style="font-size:16px;font-weight:800;margin-bottom:6px">Sesi akan berakhir</div>'
          + '<div style="font-size:13px;opacity:0.8">Tidak ada aktivitas. Anda akan otomatis logout dalam</div>'
          + '<div id="idle-count" style="font-size:30px;font-weight:800;color:#f87171;margin:6px 0 14px">60</div>'
          + '<button id="idle-stay" type="button" style="width:100%;padding:11px;border:0;border-radius:10px;background:#22c55e;color:#04210f;font-weight:800;font-size:14px;cursor:pointer">Tetap Login</button>'
          + '</div>';
        document.body.appendChild(o);
        o.querySelector('#idle-stay').addEventListener('click', function (e) { e.stopPropagation(); reset(); });
        return o;
      }
      function showWarn() {
        warning = true;
        deadline = Date.now() + WARN_MS;
        var o = overlay(); o.style.display = 'flex';
        var cd = document.getElementById('idle-count');
        function upd() {
          var left = Math.max(0, Math.ceil((deadline - Date.now()) / 1000));
          if (cd) cd.textContent = left;
          if (left <= 0) { clearInterval(tick); doLogout(); }
        }
        upd(); clearInterval(tick); tick = setInterval(upd, 250);
      }
      function reset() {
        warning = false;
        var o = document.getElementById('idle-warn'); if (o) o.style.display = 'none';
        clearInterval(tick); clearTimeout(idleTimer); clearTimeout(warnTimer);
        warnTimer = setTimeout(showWarn, IDLE_MS - WARN_MS);
        idleTimer = setTimeout(doLogout, IDLE_MS); // jaring pengaman kalau tab non-fokus
      }
      function onActivity() {
        if (warning) return;               // saat modal muncul, hanya tombol "Tetap Login" yg reset
        var now = Date.now();
        if (now - last < 2000) return;     // throttle: cukup reset tiap 2 dtk (abaikan polling)
        last = now; reset();
      }
      ['mousemove', 'mousedown', 'keydown', 'touchstart', 'scroll', 'click'].forEach(function (ev) {
        window.addEventListener(ev, onActivity, { passive: true });
      });
      reset();
    })();
  </script>
  <% } %>
  <%- typeof scripts !== 'undefined' ? scripts : '' %>
</body>
</html>
