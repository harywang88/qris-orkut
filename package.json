{
  "name": "qris-dashboard",
  "version": "1.0.0",
  "description": "Multi-client QRIS payment dashboard service",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:telegram-bot": "tsx watch src/telegram-control-bot.ts",
    "build:css": "tailwindcss -i src/css/tailwind.css -o public/css/tailwind.css --content 'views/**/*.ejs,src/**/*.ts,public/js/**/*.js'",
    "build": "node scripts/build.cjs",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "start:telegram-bot": "node dist/telegram-control-bot.js",
    "pm2:start": "scripts\\pm2.cmd start ecosystem.config.cjs",
    "pm2:start-all": "scripts\\pm2.cmd start ecosystem.config.cjs",
    "pm2:stop": "scripts\\pm2.cmd stop qris-app qris-worker qris-telegram-bot",
    "pm2:stop-all": "scripts\\pm2.cmd stop qris-app qris-worker qris-telegram-bot",
    "pm2:restart": "scripts\\pm2.cmd restart qris-app qris-worker qris-telegram-bot",
    "pm2:restart-all": "scripts\\pm2.cmd restart qris-app qris-worker qris-telegram-bot",
    "pm2:list": "scripts\\pm2.cmd list",
    "pm2:raw": "scripts\\pm2.cmd list --no-color",
    "pm2:status": "scripts\\pm2.cmd jlist",
    "pm2:logs": "scripts\\pm2.cmd logs --lines 120",
    "db:push": "prisma db push",
    "db:migrate": "prisma db push --skip-generate",
    "db:bootstrap": "npm run db:migrate && npm run db:seed",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset --skip-generate && npm run db:seed",
    "db:migrate-sqlite-to-postgres": "tsx scripts/migrate-sqlite-to-postgres.ts",
    "simulate-payment": "tsx scripts/simulate-payment.ts",
    "watcher:python": "python python/qris_balance_watcher.py",
    "watcher:python:once": "python python/qris_balance_watcher.py --once",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "connect-sqlite3": "^0.9.13",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.1",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "sqlite3": "^5.1.7",
    "undici": "^8.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-sqlite3": "^0.9.5",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/node": "^22.10.10",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.1.9",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
